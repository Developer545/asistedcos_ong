---
const navLinks = [
  { href: '/',          label: 'Inicio' },
  { href: '/nosotros',  label: 'Nosotros' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/noticias',  label: 'Noticias' },
  { href: '/impacto',   label: 'Impacto' },
  { href: '/contacto',  label: 'Contacto' },
];
const current = Astro.url.pathname;
const isHome = current === '/';
---

<header id="main-header" class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${isHome ? 'bg-transparent' : 'bg-white shadow-md'}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0" aria-label="Fundación ASISTEDCOS — Inicio">
        <img src="/images/logo.png" alt="Fundación ASISTEDCOS"
          id="header-logo"
          class="h-12 w-auto transition-all duration-300"
          style={isHome ? 'filter: brightness(0) invert(1);' : ''}
        />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden md:flex items-center gap-7" aria-label="Navegación principal">
        {navLinks.map(link => (
          <a href={link.href}
            class={`text-sm font-semibold transition-colors duration-200 ${
              current === link.href
                ? 'text-amber-400'
                : isHome
                  ? 'text-white/90 hover:text-white'
                  : 'text-gray-700 hover:text-verde-700'
            }`}>
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <div class="hidden md:flex items-center gap-3">
        <a href="/donar"
          class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-white text-sm font-bold px-6 py-2.5 rounded-full transition-all duration-200 shadow-lg hover:shadow-amber-500/30 hover:-translate-y-0.5">
          ♥ Donar ahora
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button id="menu-btn"
        class={`md:hidden p-2 rounded-md transition ${isHome ? 'text-white' : 'text-gray-700'}`}
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu">
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white shadow-lg border-t border-gray-100">
    <nav class="flex flex-col px-4 py-3 gap-1" aria-label="Navegación móvil">
      {navLinks.map(link => (
        <a href={link.href}
          class={`px-3 py-2.5 rounded-md text-sm font-semibold ${
            current === link.href
              ? 'bg-verde-50 text-verde-700'
              : 'text-gray-700 hover:bg-verde-50 hover:text-verde-700'
          }`}>
          {link.label}
        </a>
      ))}
      <a href="/donar"
        class="mt-2 flex items-center justify-center gap-2 bg-amber-500 text-white text-sm font-bold px-5 py-3 rounded-full">
        ♥ Donar ahora
      </a>
    </nav>
  </div>
</header>

<!-- Spacer for non-home pages -->
{!isHome && <div class="h-20"></div>}

<script>
  const header = document.getElementById('main-header') as HTMLElement | null;
  const logo = document.getElementById('header-logo') as HTMLImageElement | null;
  const isHome = window.location.pathname === '/';

  if (isHome && header) {
    function updateHeader() {
      const scrolled = window.scrollY > 80;
      if (!header) return;

      if (scrolled) {
        header.classList.remove('bg-transparent');
        header.classList.add('bg-white', 'shadow-md');
      } else {
        header.classList.add('bg-transparent');
        header.classList.remove('bg-white', 'shadow-md');
      }

      // Update nav link colors
      const navLinks = header.querySelectorAll('nav a');
      navLinks.forEach(link => {
        if (!link.classList.contains('text-amber-400')) {
          if (scrolled) {
            link.classList.remove('text-white/90');
            link.classList.add('text-gray-700');
          } else {
            link.classList.add('text-white/90');
            link.classList.remove('text-gray-700');
          }
        }
      });

      // Logo filter
      if (logo) {
        logo.style.filter = scrolled ? '' : 'brightness(0) invert(1)';
      }

      // Mobile button color
      const btn = document.getElementById('menu-btn');
      if (btn) {
        if (scrolled) {
          btn.classList.remove('text-white');
          btn.classList.add('text-gray-700');
        } else {
          btn.classList.add('text-white');
          btn.classList.remove('text-gray-700');
        }
      }
    }

    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();
  }

  // Mobile menu toggle
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
