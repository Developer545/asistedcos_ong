---
const navLinks = [
  { href: '/',           label: 'Inicio' },
  { href: '/nosotros',   label: 'Nosotros' },
  { href: '/proyectos',  label: 'Proyectos' },
  { href: '/impacto',    label: 'Impacto' },
  { href: '/contacto',   label: 'Contacto' },
];

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white shadow-sm border-b border-verde-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0" aria-label="Fundación ASISTEDCOS — Inicio">
        <img
          src="/images/logo.png"
          alt="Fundación ASISTEDCOS"
          class="h-10 md:h-14 w-auto"
          width="180"
          height="56"
        />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Navegación principal">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors duration-200 ${
              current === link.href
                ? 'text-verde-700 border-b-2 border-verde-600 pb-0.5'
                : 'text-gray-600 hover:text-verde-700'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA donar -->
      <a
        href="/donar"
        class="hidden md:inline-flex items-center gap-2 bg-verde-600 hover:bg-verde-700 text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors duration-200 shadow-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        Donar
      </a>

      <!-- Hamburger móvil -->
      <button
        id="menu-btn"
        class="md:hidden p-2 rounded-md text-gray-600 hover:text-verde-700 hover:bg-verde-50 transition"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Menú móvil -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-verde-100 bg-white">
    <nav class="flex flex-col px-4 py-3 gap-1" aria-label="Navegación móvil">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
            current === link.href
              ? 'bg-verde-50 text-verde-700 font-semibold'
              : 'text-gray-600 hover:bg-verde-50 hover:text-verde-700'
          }`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/donar"
        class="mt-2 flex items-center justify-center gap-2 bg-verde-600 text-white text-sm font-semibold px-5 py-2.5 rounded-full"
      >
        ♥ Donar ahora
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
