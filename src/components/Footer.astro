---
const year = new Date().getFullYear();
---

<footer class="text-verde-100" style="background-color: #081509;">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Col 1: Logo + about -->
      <div class="lg:col-span-1">
        <img src="/images/logo.png" alt="Fundación ASISTEDCOS" class="h-12 w-auto mb-5" style="filter: brightness(0) invert(1);" />
        <p class="text-sm text-gray-400 leading-relaxed mb-5">
          Recuperando ecosistemas para la biodiversidad y la humanidad en El Salvador desde 1997.
        </p>
        <p class="text-xs text-gray-500 mb-5">
          Registrada en el Ministerio de Gobernación y Desarrollo Territorial · D.L. No. 894
        </p>
        <!-- Social -->
        <div class="flex gap-3">
          <a href="https://www.facebook.com/FundacionAsistedcos" target="_blank" rel="noopener noreferrer"
            aria-label="Facebook de Fundación ASISTEDCOS"
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors hover:bg-amber-500"
            style="background-color: rgba(255,255,255,0.1);">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://wa.me/50378412413" target="_blank" rel="noopener noreferrer"
            aria-label="WhatsApp de Fundación ASISTEDCOS"
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors hover:bg-green-500"
            style="background-color: rgba(255,255,255,0.1);">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Nav -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-5">Navegación</h3>
        <ul class="space-y-2.5">
          {[
            { href: '/', label: 'Inicio' },
            { href: '/nosotros', label: 'Quiénes Somos' },
            { href: '/proyectos', label: 'Proyectos' },
            { href: '/noticias', label: 'Noticias' },
            { href: '/impacto', label: 'Nuestro Impacto' },
            { href: '/donar', label: 'Cómo Donar' },
          ].map(l => (
            <li>
              <a href={l.href} class="text-sm text-gray-400 hover:text-amber-400 transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Programs -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-5">Programas</h3>
        <ul class="space-y-2.5">
          {[
            'Reforestación costera',
            'Conservación de manglares',
            'Viveros comunitarios',
            'Monitoreo de cuencas',
            'Distribución de plántulas',
            'Jornadas de voluntariado',
          ].map(p => (
            <li class="text-sm text-gray-400">{p}</li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-5">Contáctanos</h3>
        <ul class="space-y-3 mb-6">
          <li class="flex items-start gap-3 text-sm text-gray-400">
            <svg class="h-4 w-4 mt-0.5 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            La Libertad, El Salvador
          </li>
          <li class="flex items-center gap-3 text-sm">
            <svg class="h-4 w-4 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:info@asistedcos.org" class="text-gray-400 hover:text-amber-400 transition-colors">info@asistedcos.org</a>
          </li>
          <li class="flex items-center gap-3 text-sm">
            <svg class="h-4 w-4 text-amber-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
            </svg>
            <a href="https://wa.me/50378412413" class="text-gray-400 hover:text-amber-400 transition-colors">+503 7841-2413</a>
          </li>
        </ul>
        <a href="/contacto"
          class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-white text-sm font-bold px-5 py-2.5 rounded-full transition-colors">
          Enviar mensaje
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="border-top: 1px solid rgba(255,255,255,0.05);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>© {year} Fundación ASISTEDCOS · Todos los derechos reservados.</p>
      <p>Las donaciones son deducibles de impuestos — Art. 32 Ley de Renta de El Salvador</p>
    </div>
  </div>
</footer>
