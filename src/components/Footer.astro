---
const year = new Date().getFullYear();
---

<footer class="bg-verde-900 text-verde-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Columna 1: Logo + misión -->
      <div>
        <img src="/images/logo.png" alt="Fundación ASISTEDCOS" class="h-12 w-auto mb-4 brightness-0 invert" />
        <p class="text-sm text-verde-200 leading-relaxed">
          Recuperando ecosistemas para la biodiversidad y la humanidad en El Salvador desde 1997.
        </p>
        <p class="mt-3 text-xs text-verde-300">
          Registrada en el Ministerio de Gobernación y Desarrollo Territorial de El Salvador.
        </p>
      </div>

      <!-- Columna 2: Navegación -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-verde-300 mb-4">Navegación</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
          <li><a href="/nosotros" class="hover:text-white transition-colors">Quiénes Somos</a></li>
          <li><a href="/proyectos" class="hover:text-white transition-colors">Proyectos</a></li>
          <li><a href="/impacto" class="hover:text-white transition-colors">Nuestro Impacto</a></li>
          <li><a href="/donar" class="hover:text-white transition-colors">Cómo Donar</a></li>
          <li><a href="/contacto" class="hover:text-white transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Columna 3: Contacto + redes -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-verde-300 mb-4">Contáctanos</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="h-4 w-4 mt-0.5 text-verde-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            La Libertad, El Salvador
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-4 w-4 text-verde-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@asistedcos.org" class="hover:text-white transition-colors">info@asistedcos.org</a>
          </li>
        </ul>

        <!-- Redes sociales -->
        <div class="mt-5 flex items-center gap-3">
          <a
            href="https://www.facebook.com/FundacionAsistedcos"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook de Fundación ASISTEDCOS"
            class="bg-verde-800 hover:bg-verde-700 p-2 rounded-full transition-colors"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Barra inferior -->
    <div class="mt-10 pt-6 border-t border-verde-800 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-verde-400">
      <p>© {year} Fundación ASISTEDCOS. Todos los derechos reservados.</p>
      <p>Las donaciones pueden ser deducibles de impuestos según el Art. 32 Ley de Renta de El Salvador.</p>
    </div>
  </div>
</footer>
