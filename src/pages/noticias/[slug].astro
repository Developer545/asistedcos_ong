---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcos-admin.vercel.app';

const { slug } = Astro.params;

interface News {
  id: string | number;
  title: string;
  slug: string;
  summary?: string;
  coverImage?: string;
  publishedAt?: string;
  body?: string;
}

let noticia: News | null = null;
let fetchError = false;

try {
  const res = await fetch(`${ADMIN_URL}/api/public/noticias/${slug}`, { signal: AbortSignal.timeout(5000) });
  if (res.status === 404) {
    return Astro.redirect('/404');
  }
  if (res.ok) {
    const json = await res.json();
    noticia = json.data ?? null;
    if (!noticia) {
      return Astro.redirect('/404');
    }
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

function formatDate(dateStr?: string): string {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-SV', { year: 'numeric', month: 'long', day: 'numeric' });
}

const bodyParagraphs = noticia?.body
  ? noticia.body.split('\n').filter((line: string) => line.trim().length > 0)
  : [];
---

<Layout
  title={noticia ? noticia.title : 'Noticia'}
  description={noticia?.summary ?? 'Noticias de Fundación ASISTEDCOS'}
  image={noticia?.coverImage ?? '/images/reforestacion-aerea.jpg'}
>

  {fetchError && !noticia ? (
    <section class="py-32 text-center" style="background: linear-gradient(135deg, #1a4721, #112b14);">
      <div class="max-w-2xl mx-auto px-4">
        <h1 class="font-heading text-4xl font-extrabold text-white mb-4">Error al cargar</h1>
        <p class="mb-8" style="color: #bde7c3;">No pudimos cargar esta noticia. Intenta de nuevo más tarde.</p>
        <a href="/noticias"
          class="inline-flex items-center gap-2 font-semibold px-8 py-3 rounded-full transition-colors text-white"
          style="border: 2px solid rgba(255,255,255,0.4);">
          ← Volver a Noticias
        </a>
      </div>
    </section>
  ) : noticia ? (
    <>
      <!-- Hero con imagen de portada -->
      {noticia.coverImage ? (
        <section class="relative h-64 md:h-[28rem] overflow-hidden" style="background-color: #112b14;">
          <img
            src={noticia.coverImage}
            alt={noticia.title}
            class="w-full h-full object-cover"
            style="opacity: 0.55;"
            fetchpriority="high"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(17,43,20,0.85) 0%, transparent 60%);"></div>
          <div class="absolute bottom-0 left-0 right-0 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
            {noticia.publishedAt && (
              <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full mb-3"
                style="background-color: rgba(245,158,11,0.25); color: #fcd34d; border: 1px solid rgba(251,191,36,0.4);">
                {formatDate(noticia.publishedAt)}
              </span>
            )}
          </div>
        </section>
      ) : (
        <section class="py-16" style="background: linear-gradient(135deg, #1a4721, #112b14);"></section>
      )}

      <!-- Contenido principal -->
      <section class="py-12 bg-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

          <!-- Breadcrumb -->
          <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8" aria-label="Breadcrumb">
            <a href="/" class="hover:text-verde-700 transition-colors">Inicio</a>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            <a href="/noticias" class="hover:text-verde-700 transition-colors">Noticias</a>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            <span class="text-gray-600 font-medium truncate max-w-xs">{noticia.title}</span>
          </nav>

          <!-- Metadatos -->
          <div class="flex items-center gap-3 mb-6">
            {noticia.publishedAt && (
              <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full" style="background-color: #ddf3e0; color: #245f2e;">
                {formatDate(noticia.publishedAt)}
              </span>
            )}
            <span class="inline-block bg-gray-100 text-gray-600 text-xs font-semibold px-3 py-1 rounded-full">
              ASISTEDCOS
            </span>
          </div>

          <!-- Título -->
          <h1 class="font-heading text-3xl md:text-4xl font-extrabold leading-tight mb-6" style="color: #112b14;">
            {noticia.title}
          </h1>

          <!-- Resumen destacado -->
          {noticia.summary && (
            <p class="text-xl text-gray-600 leading-relaxed pl-5 mb-8 italic"
              style="border-left: 4px solid #2d7a3a;">
              {noticia.summary}
            </p>
          )}

          <!-- Cuerpo -->
          <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed space-y-5">
            {bodyParagraphs.length > 0 ? (
              bodyParagraphs.map((parrafo: string) => (
                <p>{parrafo}</p>
              ))
            ) : (
              <p class="text-gray-400 italic">Contenido no disponible.</p>
            )}
          </div>

          <!-- Separador -->
          <hr class="my-12 border-gray-200" />

          <!-- Botones -->
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <a
              href="/noticias"
              class="inline-flex items-center gap-2 font-semibold px-6 py-2.5 rounded-full transition-colors"
              style="border: 2px solid #2d7a3a; color: #245f2e;"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
              </svg>
              Volver a Noticias
            </a>
            <a
              href="/donar"
              class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-6 py-2.5 rounded-full transition-colors shadow-md"
            >
              ♥ Apoyar ASISTEDCOS
            </a>
          </div>

        </div>
      </section>

      <!-- CTA al final -->
      <section class="py-14 text-center" style="background-color: #f9fafb;">
        <div class="max-w-2xl mx-auto px-4">
          <p class="text-gray-500 text-sm mb-4">¿Te gustó este contenido? Apoya la misión de ASISTEDCOS</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/donar"
              class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-8 py-3 rounded-full transition-colors">
              ♥ Donar ahora
            </a>
            <a href="/noticias"
              class="inline-flex items-center justify-center gap-2 font-semibold px-8 py-3 rounded-full transition-colors"
              style="border: 2px solid #2d7a3a; color: #245f2e;">
              Más noticias
            </a>
          </div>
        </div>
      </section>
    </>
  ) : null}

</Layout>
