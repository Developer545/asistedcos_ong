---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcosadmin.vercel.app';

const { slug } = Astro.params;

interface News {
  id: string | number;
  title: string;
  slug: string;
  summary?: string;
  coverImage?: string;
  publishedAt?: string;
  categoria?: string;
  body?: string;
  related?: Array<{
    id: string;
    title: string;
    slug: string;
    summary?: string;
    coverImage?: string;
    publishedAt?: string;
    categoria?: string;
  }>;
}

let noticia: News | null = null;
let fetchError = false;

try {
  const res = await fetch(`${ADMIN_URL}/api/public/noticias/${slug}`, { signal: AbortSignal.timeout(5000) });
  if (res.status === 404) {
    return Astro.redirect('/404');
  }
  if (res.ok) {
    const json = await res.json();
    noticia = json.data ?? null;
    if (!noticia) {
      return Astro.redirect('/404');
    }
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

function formatDate(dateStr?: string): string {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-SV', { year: 'numeric', month: 'long', day: 'numeric' });
}

const bodyParagraphs = noticia?.body
  ? noticia.body.split('\n').filter((line: string) => line.trim().length > 0)
  : [];

const pageUrl = Astro.url.href;
const shareTitle = noticia?.title ?? 'Noticia de Fundación ASISTEDCOS';
---

<Layout
  title={noticia ? noticia.title : 'Noticia'}
  description={noticia?.summary ?? 'Noticias de Fundación ASISTEDCOS'}
  image={noticia?.coverImage ?? '/images/reforestacion-aerea.jpg'}
>

  {fetchError && !noticia ? (
    <!-- Error state -->
    <section class="relative py-32 overflow-hidden">
      <div class="absolute inset-0">
        <img src="/images/reforestacion-aerea.jpg" alt="" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-gray-900/90 to-gray-900/70"></div>
      </div>
      <div class="relative max-w-2xl mx-auto px-4 text-center">
        <svg class="h-16 w-16 text-amber-500 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <h1 class="font-heading text-3xl font-extrabold text-white mb-3">Error al cargar</h1>
        <p class="text-gray-300 mb-8">No pudimos cargar esta noticia. Intenta de nuevo más tarde.</p>
        <a href="/noticias" class="inline-flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-gray-900 font-bold px-6 py-3 rounded-sm transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
          Volver a Noticias
        </a>
      </div>
    </section>
  ) : noticia ? (
    <>
      <!-- Article hero -->
      {noticia.coverImage ? (
        <section class="relative h-72 md:h-[32rem] overflow-hidden">
          <img
            src={noticia.coverImage}
            alt={noticia.title}
            class="w-full h-full object-cover"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-gray-900/85 via-gray-900/40 to-gray-900/20"></div>
          <div class="absolute bottom-0 left-0 right-0 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
            <!-- Breadcrumb in hero -->
            <div class="flex items-center gap-2 text-gray-400 text-sm mb-4">
              <a href="/" class="hover:text-amber-400 transition-colors">Inicio</a>
              <span>›</span>
              <a href="/noticias" class="hover:text-amber-400 transition-colors">Noticias</a>
              <span>›</span>
              <span class="text-white truncate max-w-xs">{noticia.title}</span>
            </div>
            <div class="flex flex-wrap items-center gap-3 mb-3">
              {noticia.publishedAt && (
                <span class="inline-flex items-center gap-1.5 bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-sm uppercase">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  {formatDate(noticia.publishedAt)}
                </span>
              )}
              {noticia.categoria && (
                <span class="bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-sm backdrop-blur-sm">
                  {noticia.categoria}
                </span>
              )}
              <span class="bg-verde-600/80 text-white text-xs font-semibold px-3 py-1 rounded-sm">
                ASISTEDCOS
              </span>
            </div>
          </div>
        </section>
      ) : (
        <section class="relative py-24 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-verde-900 to-verde-700"></div>
          <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center gap-2 text-verde-300 text-sm mb-4">
              <a href="/" class="hover:text-amber-400 transition-colors">Inicio</a>
              <span>›</span>
              <a href="/noticias" class="hover:text-amber-400 transition-colors">Noticias</a>
              <span>›</span>
              <span class="text-white truncate max-w-xs">{noticia.title}</span>
            </div>
            <div class="flex flex-wrap items-center gap-3">
              {noticia.publishedAt && (
                <span class="bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-sm uppercase">
                  {formatDate(noticia.publishedAt)}
                </span>
              )}
              <span class="bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-sm">
                ASISTEDCOS
              </span>
            </div>
          </div>
        </section>
      )}

      <!-- Article content -->
      <section class="py-14 bg-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

          <!-- Title -->
          <h1 class="font-heading text-3xl md:text-4xl font-extrabold text-verde-900 leading-tight mb-6">
            {noticia.title}
          </h1>

          <!-- Summary as lead -->
          {noticia.summary && (
            <p class="text-xl text-gray-600 leading-relaxed pl-5 mb-8 italic border-l-4 border-amber-500">
              {noticia.summary}
            </p>
          )}

          <!-- Body -->
          <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed space-y-5">
            {bodyParagraphs.length > 0 ? (
              bodyParagraphs.map((parrafo: string) => (
                <p class="text-gray-700 leading-8">{parrafo}</p>
              ))
            ) : (
              <p class="text-gray-400 italic">Contenido no disponible.</p>
            )}
          </div>

          <!-- Separator -->
          <hr class="my-12 border-gray-200" />

          <!-- Share buttons -->
          <div class="mb-10">
            <p class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4">Compartir este artículo</p>
            <div class="flex flex-wrap gap-3">
              <a
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold px-4 py-2.5 rounded-sm transition-colors text-sm"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
              <a
                href={`https://api.whatsapp.com/send?text=${encodeURIComponent(shareTitle + ' - ' + pageUrl)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold px-4 py-2.5 rounded-sm transition-colors text-sm"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
              <button
                id="copy-link"
                class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-4 py-2.5 rounded-sm transition-colors text-sm"
                data-url={pageUrl}
              >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                Copiar enlace
              </button>
            </div>
          </div>

          <!-- Navigation -->
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <a
              href="/noticias"
              class="inline-flex items-center gap-2 border-2 border-verde-600 text-verde-700 hover:bg-verde-600 hover:text-white font-bold px-6 py-2.5 rounded-sm transition-colors"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
              Volver a Noticias
            </a>
            <a
              href="/donar"
              class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-6 py-2.5 rounded-sm transition-colors shadow-md"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
              Apoyar ASISTEDCOS
            </a>
          </div>

        </div>
      </section>

      <!-- CTA at bottom -->
      <section class="py-20 bg-gray-900 relative overflow-hidden">
        <div class="absolute inset-0">
          <img src="/images/voluntaria-plantando.jpg" alt="" class="w-full h-full object-cover opacity-15" />
        </div>
        <div class="relative max-w-3xl mx-auto px-4 text-center">
          <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Únete a la causa</span>
          <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-white mt-2 mb-4">¿Quieres apoyar nuestro trabajo?</h2>
          <p class="text-gray-300 mb-8 text-lg">Cada donación financia directamente proyectos de reforestación, conservación y comunidades que prosperan en El Salvador.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/donar" class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-8 py-4 rounded-sm transition-colors shadow-lg text-lg">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
              Donar ahora
            </a>
            <a href="/proyectos" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white hover:bg-white hover:text-gray-900 font-bold px-8 py-4 rounded-sm transition-colors text-lg">
              Ver proyectos
            </a>
          </div>
        </div>
      </section>

      <!-- Related articles - dynamic -->
      <section class="py-16 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between mb-8">
            <div>
              <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Más contenido</span>
              <h3 class="font-heading text-2xl font-extrabold text-verde-900 mt-1">Más Noticias</h3>
            </div>
            <a href="/noticias" class="inline-flex items-center gap-1.5 font-bold text-verde-700 hover:text-amber-500 transition-colors text-sm">
              Ver todas
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
          {noticia.related && noticia.related.length > 0 ? (
            <div class="grid md:grid-cols-3 gap-6">
              {noticia.related.map(rel => (
                <a href={`/noticias/${rel.slug}`} class="group bg-white rounded-lg shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 hover:-translate-y-1 overflow-hidden">
                  <div class="h-40 overflow-hidden">
                    {rel.coverImage ? (
                      <img src={rel.coverImage} alt={rel.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    ) : (
                      <div class="w-full h-full bg-gradient-to-br from-verde-800 to-verde-600 flex items-center justify-center">
                        <svg class="h-10 w-10 opacity-30 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                      </div>
                    )}
                  </div>
                  <div class="p-4">
                    {rel.categoria && <span class="text-xs font-bold text-amber-500 uppercase tracking-wider">{rel.categoria}</span>}
                    <h4 class="font-heading font-bold text-verde-900 text-sm mt-1 group-hover:text-verde-600 transition-colors line-clamp-2">{rel.title}</h4>
                    {rel.publishedAt && <p class="text-gray-400 text-xs mt-1">{new Date(rel.publishedAt).toLocaleDateString('es-SV', { year: 'numeric', month: 'long', day: 'numeric' })}</p>}
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-8">
              <a href="/noticias" class="inline-flex items-center gap-2 border-2 border-verde-600 text-verde-700 hover:bg-verde-600 hover:text-white font-bold px-6 py-3 rounded-sm transition-colors">
                Ver todas las noticias
              </a>
            </div>
          )}
        </div>
      </section>
    </>
  ) : null}

</Layout>

<script>
  const copyBtn = document.getElementById('copy-link') as HTMLButtonElement | null;
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const url = copyBtn.dataset.url ?? window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        const original = copyBtn.innerHTML;
        copyBtn.innerHTML = `<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg> ¡Copiado!`;
        copyBtn.style.backgroundColor = '#16a34a';
        setTimeout(() => {
          copyBtn.innerHTML = original;
          copyBtn.style.backgroundColor = '';
        }, 2000);
      } catch {
        // Fallback
      }
    });
  }
</script>
