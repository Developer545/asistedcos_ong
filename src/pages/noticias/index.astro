---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcos-admin.vercel.app';

interface News {
  id: string | number;
  title: string;
  slug: string;
  summary?: string;
  coverImage?: string;
  publishedAt?: string;
  body?: string;
}

let noticias: News[] = [];
let fetchError = false;

try {
  const res = await fetch(`${ADMIN_URL}/api/public/noticias?limit=20`, { signal: AbortSignal.timeout(5000) });
  if (res.ok) {
    const json = await res.json();
    noticias = json.data ?? [];
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

function formatDate(dateStr?: string): string {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-SV', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout
  title="Noticias"
  description="Últimas noticias y novedades de Fundación ASISTEDCOS — proyectos, eventos y logros en la restauración de ecosistemas de El Salvador."
  image="/images/reforestacion-aerea.jpg"
>

  <!-- Encabezado -->
  <section class="py-24 relative overflow-hidden" style="background: linear-gradient(135deg, #1a4721, #112b14);">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/reforestacion-aerea.jpg" alt="" class="w-full h-full object-cover" aria-hidden="true" />
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-amber-400 text-sm font-bold uppercase tracking-widest">Actualidad</span>
      <h1 class="font-heading text-4xl md:text-5xl font-extrabold text-white mt-3 mb-4">Noticias</h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: #bde7c3;">
        Entérate de los últimos avances, eventos y logros de nuestra fundación en El Salvador.
      </p>
    </div>
  </section>

  <!-- Grid de noticias -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      {fetchError || noticias.length === 0 ? (
        <div class="text-center py-24">
          <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6" style="background-color: #ddf3e0;">
            <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #2d7a3a;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h6m-6-4h6" />
            </svg>
          </div>
          <h2 class="font-heading text-2xl font-bold mb-3" style="color: #112b14;">Próximamente</h2>
          <p class="text-gray-500 max-w-sm mx-auto">
            Estamos preparando noticias y novedades. Vuelve pronto para conocer las últimas actualizaciones de ASISTEDCOS.
          </p>
          <a href="/" class="mt-8 inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-full text-white transition-colors"
            style="background-color: #2d7a3a;">
            Volver al inicio
          </a>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {noticias.map(noticia => (
            <article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100 flex flex-col hover:-translate-y-1">
              <!-- Imagen o placeholder -->
              <div class="overflow-hidden aspect-[16/10] relative">
                {noticia.coverImage ? (
                  <img
                    src={noticia.coverImage}
                    alt={noticia.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center" style="background: linear-gradient(135deg, #1a4721, #389e4a);">
                    <svg class="h-12 w-12 opacity-40 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
                {noticia.publishedAt && (
                  <div class="absolute top-3 left-3 text-xs font-semibold px-3 py-1 rounded-full" style="background-color: rgba(255,255,255,0.92); color: #1a4721;">
                    {formatDate(noticia.publishedAt)}
                  </div>
                )}
              </div>

              <div class="p-6 flex flex-col flex-1">
                <h2 class="font-heading font-bold text-lg mb-2 leading-snug transition-colors group-hover:text-verde-600" style="color: #112b14;">
                  {noticia.title}
                </h2>

                {noticia.summary && (
                  <p class="text-gray-500 text-sm leading-relaxed mb-4 flex-1">
                    {noticia.summary}
                  </p>
                )}

                <a
                  href={`/noticias/${noticia.slug}`}
                  class="inline-flex items-center gap-1.5 font-semibold text-sm hover:gap-2.5 transition-all mt-auto group/link"
                  style="color: #2d7a3a;"
                >
                  Leer más
                  <svg class="h-4 w-4 group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}

    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-white text-center" style="background: linear-gradient(135deg, #245f2e, #1a4721);">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-heading text-2xl md:text-3xl font-bold mb-3">¿Quieres apoyar nuestra labor?</h2>
      <p class="mb-8" style="color: #bde7c3;">Cada donación nos permite seguir restaurando ecosistemas y transformando comunidades.</p>
      <a href="/donar"
        class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-10 py-4 rounded-full transition-colors shadow-lg">
        ♥ Donar ahora
      </a>
    </div>
  </section>

</Layout>
