---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcosadmin.vercel.app';

interface Causa {
  id: string;
  titulo: string;
  descripcion?: string;
  tag?: string;
  coverImage?: string;
  ubicacion?: string;
  estado: string;
  meta: number;
  recaudado: number;
  active: boolean;
  order: number;
}

let causas: Causa[] = [];
let fetchError = false;

try {
  const res = await fetch(`${ADMIN_URL}/api/public/causas`, { signal: AbortSignal.timeout(5000) });
  if (res.ok) {
    const json = await res.json();
    causas = (json.data ?? []).filter((c: Causa) => c.active);
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

// Calculate percentage for each cause
function getPct(meta: number, recaudado: number): number {
  if (!meta || meta === 0) return 0;
  return Math.min(100, Math.round((recaudado / meta) * 100));
}

function fmtUSD(n: number): string {
  return n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}

const categorias = ['Todos', ...Array.from(new Set(causas.map(c => c.tag ?? 'General').filter(Boolean)))];
---

<Layout
  title="Proyectos"
  description="Conoce los proyectos de reforestación, conservación de manglares y monitoreo ambiental que realiza Fundación ASISTEDCOS en El Salvador."
  image="/images/reforestacion-aerea.jpg"
>

  <!-- Hero -->
  <section class="relative py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/reforestacion-aerea.jpg" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/90 to-gray-900/60"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-2 text-gray-400 text-sm mb-4">
        <a href="/" class="hover:text-amber-400 transition-colors">Inicio</a>
        <span>›</span>
        <span class="text-white">Proyectos</span>
      </div>
      <span class="inline-block text-amber-500 font-bold text-sm uppercase tracking-wider mb-3">Nuestro trabajo</span>
      <h1 class="font-heading text-4xl md:text-5xl font-extrabold text-white mb-4">Proyectos</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        Cada proyecto es una historia de transformación: ecosistemas que renacen y comunidades que prosperan.
      </p>
    </div>
  </section>

  {/* ── Filter bar ── */}
  {causas.length > 0 && categorias.length > 2 && (
    <section class="bg-white border-b border-gray-100 sticky top-0 z-20 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-2 py-4 overflow-x-auto scrollbar-none">
          <span class="text-gray-500 text-sm font-medium mr-2 whitespace-nowrap flex-shrink-0">Filtrar:</span>
          {categorias.map(cat => (
            <button
              class="filter-btn whitespace-nowrap flex-shrink-0 px-4 py-2 rounded-sm text-sm font-bold transition-all duration-200 border-2"
              data-category={cat}
              data-active={cat === 'Todos' ? 'true' : 'false'}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ── Projects grid ── */}
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      {(fetchError || causas.length === 0) ? (
        <div class="text-center py-24">
          <div class="w-24 h-24 rounded-full bg-white shadow-md flex items-center justify-center mx-auto mb-6">
            <svg class="h-12 w-12 text-verde-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Próximamente</span>
          <h2 class="font-heading text-2xl font-extrabold text-verde-900 mt-2 mb-3">Estamos preparando proyectos</h2>
          <p class="text-gray-500 max-w-sm mx-auto leading-relaxed">
            Nuestros proyectos activos estarán disponibles pronto. Mientras tanto, puedes apoyar nuestra misión.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center mt-8">
            <a href="/donar" class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-6 py-3 rounded-sm transition-colors">
              ♥ Donar ahora
            </a>
            <a href="/" class="inline-flex items-center justify-center gap-2 border-2 border-verde-600 text-verde-700 hover:bg-verde-600 hover:text-white font-bold px-6 py-3 rounded-sm transition-colors">
              Volver al inicio
            </a>
          </div>
        </div>
      ) : (
        <>
          <div id="projects-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {causas.map(c => {
              const pct = getPct(Number(c.meta), Number(c.recaudado));
              const restante = Math.max(0, Number(c.meta) - Number(c.recaudado));
              const img = c.coverImage || '/images/reforestacion-aerea.jpg';
              const tag = c.tag ?? 'Proyecto';
              const estado = c.estado ?? 'Activo';
              const estadoColor = estado === 'Activo' ? 'bg-green-500' : estado === 'Continuo' ? 'bg-blue-500' : 'bg-gray-500';
              return (
                <article
                  class="project-card bg-white rounded-lg shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 hover:-translate-y-1 overflow-hidden flex flex-col"
                  data-category={tag}
                >
                  {/* Image */}
                  <div class="relative overflow-hidden aspect-[16/10]">
                    <img src={img} alt={c.titulo} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
                    <div class="absolute top-3 left-3">
                      <span class="bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-sm uppercase tracking-wide">{tag}</span>
                    </div>
                    <div class="absolute top-3 right-3">
                      <span class={`text-xs font-bold px-2.5 py-1 rounded-sm text-white ${estadoColor}`}>{estado}</span>
                    </div>
                  </div>

                  {/* Content */}
                  <div class="p-6 flex flex-col flex-1">
                    {c.ubicacion && (
                      <div class="flex items-center gap-1.5 text-xs text-gray-400 mb-2">
                        <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        </svg>
                        {c.ubicacion}
                      </div>
                    )}
                    <h2 class="font-heading font-extrabold text-lg text-verde-900 mb-2">{c.titulo}</h2>
                    {c.descripcion && (
                      <p class="text-gray-500 text-sm leading-relaxed mb-4 flex-1">{c.descripcion}</p>
                    )}

                    {/* Progress bar */}
                    {Number(c.meta) > 0 && (
                      <div class="mb-5">
                        <div class="flex justify-between text-xs font-semibold mb-1.5">
                          <span class="text-gray-500">Recaudado: <span class="text-verde-700">${fmtUSD(Number(c.recaudado))}</span></span>
                          <span class="text-amber-600 font-bold">{pct}%</span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-2.5">
                          <div class="bg-amber-500 h-2.5 rounded-full transition-all" style={`width: ${pct}%`}></div>
                        </div>
                        <div class="flex justify-between text-xs text-gray-400 mt-1">
                          <span>Meta: ${fmtUSD(Number(c.meta))}</span>
                          <span class="text-verde-600 font-semibold">${fmtUSD(restante)} restantes</span>
                        </div>
                      </div>
                    )}

                    {/* Buttons */}
                    <div class="flex gap-2 mt-auto">
                      <a href="/donar" class="flex-1 text-center bg-amber-500 hover:bg-amber-400 text-white font-bold px-4 py-2.5 rounded-sm transition-colors text-sm">
                        ♥ Donar
                      </a>
                      <a href="/contacto" class="flex-1 text-center border-2 border-verde-600 text-verde-700 hover:bg-verde-600 hover:text-white font-bold px-4 py-2.5 rounded-sm transition-colors text-sm">
                        Saber más
                      </a>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>

          {/* Empty filter state */}
          <div id="empty-state" class="hidden text-center py-16">
            <p class="text-gray-500 font-medium">No hay proyectos en esta categoría.</p>
          </div>
        </>
      )}
    </div>
  </section>

  {/* ── CTA ── */}
  <section class="py-20 bg-gray-900 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/evento-playa.jpg" alt="" class="w-full h-full object-cover opacity-20" />
    </div>
    <div class="relative max-w-3xl mx-auto px-4 text-center">
      <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Únete a la causa</span>
      <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-white mt-2 mb-4">¿Quieres apoyar estos proyectos?</h2>
      <p class="text-gray-300 mb-8 text-lg">Tu donación financia directamente el trabajo en campo: reforestación, monitoreo y comunidades que prosperan.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/donar" class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-8 py-4 rounded-sm transition-colors shadow-lg text-lg">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
          Donar ahora
        </a>
        <a href="/contacto" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white hover:bg-white hover:text-gray-900 font-bold px-8 py-4 rounded-sm transition-colors text-lg">
          Ser voluntario
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .filter-btn[data-active="true"] {
    background-color: #2d7a3a;
    color: white;
    border-color: #2d7a3a;
  }
  .filter-btn[data-active="false"] {
    background-color: white;
    color: #374151;
    border-color: #e5e7eb;
  }
  .filter-btn[data-active="false"]:hover {
    border-color: #2d7a3a;
    color: #2d7a3a;
  }
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  const emptyState = document.getElementById('empty-state');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category ?? 'Todos';
      filterBtns.forEach(b => b.dataset.active = 'false');
      btn.dataset.active = 'true';
      let visible = 0;
      cards.forEach(card => {
        const match = category === 'Todos' || card.dataset.category === category;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (emptyState) emptyState.classList.toggle('hidden', visible > 0);
    });
  });
</script>
