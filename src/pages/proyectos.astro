---
export const prerender = false;
import Layout from '../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcosadmin.vercel.app';

interface Causa {
  id: string; titulo: string; descripcion?: string; tag?: string;
  coverImage?: string; ubicacion?: string; estado: string;
  meta: number; recaudado: number; active: boolean; order: number;
}

let causas: Causa[] = [];
let fetchError = false;

try {
  const res = await fetch(`${ADMIN_URL}/api/public/causas`, { signal: AbortSignal.timeout(5000) });
  if (res.ok) { const json = await res.json(); causas = (json.data ?? []).filter((c: Causa) => c.active); }
  else fetchError = true;
} catch { fetchError = true; }

function getPct(meta: number, recaudado: number): number {
  if (!meta || meta === 0) return 0;
  return Math.min(100, Math.round((recaudado / meta) * 100));
}
function fmtUSD(n: number): string {
  return n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}
const categorias = ['Todos', ...Array.from(new Set(causas.map(c => c.tag ?? 'General').filter(Boolean)))];
---

<Layout
  title="Proyectos"
  description="Conoce los proyectos de reforestación, conservación de manglares y monitoreo ambiental que realiza Fundación ASISTEDCOS en El Salvador."
  image="/images/reforestacion-aerea.jpg"
>

<!-- HERO -->
<section class="proy-hero">
  <div class="proy-hero-bg"></div>
  <div class="proy-container">
    <nav class="proy-breadcrumb">
      <a href="/">Inicio</a><span>›</span><span>Proyectos</span>
    </nav>
    <p class="proy-eyebrow">Nuestro trabajo</p>
    <h1 class="proy-h1">Proyectos en <span class="proy-accent">campo</span></h1>
    <p class="proy-hero-sub">Cada proyecto es una historia de transformación: ecosistemas que renacen y comunidades que prosperan.</p>
  </div>
  <div class="proy-scroll" aria-hidden="true"><span></span></div>
</section>

<!-- FILTER BAR -->
{causas.length > 0 && categorias.length > 2 && (
<div class="proy-filter-bar">
  <div class="proy-container proy-filter-inner">
    <span class="proy-filter-label">Filtrar:</span>
    {categorias.map(cat => (
      <button class="proy-filter-btn" data-category={cat} data-active={cat === 'Todos' ? 'true' : 'false'}>
        {cat}
      </button>
    ))}
  </div>
</div>
)}

<!-- PROJECTS -->
<section class="proy-section" style="background:#f7f7f7; position:relative;">
  <div class="proy-deco-num" aria-hidden="true">.01</div>
  <div class="proy-container">

    {(fetchError || causas.length === 0) ? (
      <div class="proy-empty">
        <div class="proy-empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <p class="proy-eyebrow">Próximamente</p>
        <h2 class="proy-h2" style="color:#111;">Estamos preparando proyectos</h2>
        <p style="color:#888;max-width:360px;margin:0.75rem auto 2rem;font-size:0.9rem;line-height:1.7;">Nuestros proyectos activos estarán disponibles pronto. Mientras tanto, puedes apoyar nuestra misión.</p>
        <div class="proy-empty-actions">
          <a href="/donar" class="proy-btn">♥ Donar ahora</a>
          <a href="/" class="proy-btn-outline-dark">Volver al inicio</a>
        </div>
      </div>
    ) : (
      <>
        <div id="projects-grid" class="proy-grid">
          {causas.map(c => {
            const pct = getPct(Number(c.meta), Number(c.recaudado));
            const restante = Math.max(0, Number(c.meta) - Number(c.recaudado));
            const img = c.coverImage || '/images/reforestacion-aerea.jpg';
            const tag = c.tag ?? 'Proyecto';
            const estado = c.estado ?? 'Activo';
            const estadoColor = estado === 'Activo' ? '#16a34a' : estado === 'Continuo' ? '#2563eb' : '#6b7280';
            return (
              <article class="proy-card project-card" data-category={tag}>
                <div class="proy-card-img">
                  <img src={img} alt={c.titulo} loading="lazy" />
                  <span class="proy-card-tag">{tag}</span>
                  <span class="proy-card-estado" style={`background:${estadoColor}`}>{estado}</span>
                </div>
                <div class="proy-card-body">
                  {c.ubicacion && (
                    <div class="proy-ubicacion">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                      {c.ubicacion}
                    </div>
                  )}
                  <h2 class="proy-card-title">{c.titulo}</h2>
                  {c.descripcion && <p class="proy-card-desc">{c.descripcion}</p>}

                  {Number(c.meta) > 0 && (
                    <div class="proy-progress">
                      <div class="proy-progress-head">
                        <span>Recaudado: <strong>${fmtUSD(Number(c.recaudado))}</strong></span>
                        <span class="proy-pct">{pct}%</span>
                      </div>
                      <div class="proy-bar-track">
                        <div class="proy-bar-fill" style={`width:${pct}%`}></div>
                      </div>
                      <div class="proy-progress-foot">
                        <span>Meta: ${fmtUSD(Number(c.meta))}</span>
                        <span>${fmtUSD(restante)} restantes</span>
                      </div>
                    </div>
                  )}

                  <div class="proy-card-actions">
                    <a href="/donar" class="proy-btn-sm">♥ Donar</a>
                    <a href="/contacto" class="proy-btn-sm-ghost">Saber más</a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
        <div id="empty-state" class="hidden proy-empty" style="padding:4rem 0;">
          <p style="color:#888;">No hay proyectos en esta categoría.</p>
        </div>
      </>
    )}
  </div>
</section>

<!-- CTA -->
<section class="proy-cta">
  <div class="proy-container" style="text-align:center;">
    <p class="proy-eyebrow" style="color:rgba(245,158,11,0.8);">Únete a la causa</p>
    <h2 class="proy-h2" style="color:#fff;">¿Quieres apoyar <span class="proy-accent">estos proyectos</span>?</h2>
    <p style="color:rgba(255,255,255,0.6);max-width:500px;margin:1rem auto 2.5rem;font-size:1rem;line-height:1.75;">Tu donación financia directamente el trabajo en campo: reforestación, monitoreo y comunidades que prosperan.</p>
    <div class="proy-cta-btns">
      <a href="/donar" class="proy-btn">♥ Donar ahora</a>
      <a href="/contacto" class="proy-btn-outline">Ser voluntario &rarr;</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root {
    --p-accent: #f59e0b;
    --p-dark:   #111;
    --p-forest: #081509;
    --p-head:   'Poppins', system-ui, sans-serif;
    --p-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }
  .proy-container { max-width:1200px; margin:0 auto; padding:0 1.5rem; }
  .proy-section   { padding:5rem 0; overflow:hidden; }
  .proy-eyebrow {
    font-size:.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.28em; color:var(--p-accent); display:block; margin-bottom:.75rem;
  }
  .proy-h1 {
    font-family:var(--p-head); font-weight:800;
    font-size:clamp(2.6rem,6vw,4.5rem); line-height:1.07; color:#fff; margin-bottom:1.25rem;
  }
  .proy-h2 {
    font-family:var(--p-head); font-weight:800;
    font-size:clamp(1.9rem,3.5vw,2.6rem); line-height:1.15; color:#111; margin-bottom:.75rem;
  }
  .proy-accent { color:var(--p-accent); }
  .proy-deco-num {
    position:absolute; top:3rem; left:-1rem;
    font-family:var(--p-head); font-size:clamp(7rem,15vw,14rem);
    font-weight:900; color:rgba(0,0,0,0.035); line-height:1;
    pointer-events:none; user-select:none;
  }

  /* HERO */
  .proy-hero {
    position:relative; min-height:65vh; display:flex; align-items:center;
    padding:8rem 0 5rem; overflow:hidden;
  }
  .proy-hero-bg {
    position:absolute; inset:0;
    background:
      linear-gradient(to right,rgba(8,21,9,.92) 0%,rgba(8,21,9,.72) 60%,rgba(8,21,9,.5) 100%),
      url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1920&q=80') center/cover no-repeat;
  }
  .proy-hero .proy-container { position:relative; z-index:1; }
  .proy-breadcrumb {
    display:flex; gap:.5rem; align-items:center;
    font-size:.8rem; color:rgba(255,255,255,.4); margin-bottom:1.5rem;
  }
  .proy-breadcrumb a { color:rgba(255,255,255,.4); text-decoration:none; }
  .proy-breadcrumb a:hover { color:var(--p-accent); }
  .proy-hero-sub { color:rgba(255,255,255,.72); font-size:1.1rem; max-width:560px; line-height:1.75; }
  .proy-scroll { position:absolute; bottom:2rem; left:50%; transform:translateX(-50%); }
  .proy-scroll span {
    display:block; width:1px; height:60px;
    background:linear-gradient(to bottom,rgba(245,158,11,.8),transparent);
    animation:pscroll 1.8s ease-in-out infinite;
  }
  @keyframes pscroll {
    0%{transform:scaleY(0);transform-origin:top} 50%{transform:scaleY(1);transform-origin:top}
    51%{transform:scaleY(1);transform-origin:bottom} 100%{transform:scaleY(0);transform-origin:bottom}
  }

  /* FILTER */
  .proy-filter-bar {
    background:#fff; border-bottom:1px solid #eee;
    position:sticky; top:0; z-index:20;
  }
  .proy-filter-inner {
    display:flex; align-items:center; gap:.6rem;
    padding:.9rem 1.5rem; overflow-x:auto;
    scrollbar-width:none;
  }
  .proy-filter-inner::-webkit-scrollbar { display:none; }
  .proy-filter-label { font-size:.75rem; font-weight:700; color:#999; white-space:nowrap; }
  .proy-filter-btn {
    white-space:nowrap; flex-shrink:0;
    padding:.35rem 1rem; font-size:.78rem; font-weight:700;
    border:1.5px solid #e5e7eb; background:#fff; color:#555;
    cursor:pointer; transition:all .2s; letter-spacing:.04em; text-transform:uppercase;
  }
  .proy-filter-btn[data-active="true"] { background:var(--p-forest); color:#fff; border-color:var(--p-forest); }
  .proy-filter-btn[data-active="false"]:hover { border-color:var(--p-accent); color:var(--p-accent); }

  /* GRID */
  .proy-grid {
    display:grid; grid-template-columns:repeat(3,1fr);
    gap:1.5px; background:#e0e0e0;
  }
  @media(max-width:900px){ .proy-grid{ grid-template-columns:repeat(2,1fr); } }
  @media(max-width:560px){ .proy-grid{ grid-template-columns:1fr; } }

  .proy-card {
    background:#fff; display:flex; flex-direction:column;
    transition:transform .3s;
  }
  .proy-card:hover { transform:translateY(-4px); z-index:1; box-shadow:var(--p-shadow); }

  .proy-card-img {
    position:relative; height:210px; overflow:hidden;
  }
  .proy-card-img img { width:100%; height:100%; object-fit:cover; transition:transform .6s ease; display:block; }
  .proy-card:hover .proy-card-img img { transform:scale(1.06); }
  .proy-card-tag {
    position:absolute; top:1rem; left:1rem;
    background:var(--p-accent); color:#fff;
    font-size:.65rem; font-weight:700;
    text-transform:uppercase; letter-spacing:.1em; padding:.25rem .65rem;
  }
  .proy-card-estado {
    position:absolute; top:1rem; right:1rem;
    color:#fff; font-size:.65rem; font-weight:700;
    text-transform:uppercase; letter-spacing:.08em; padding:.25rem .65rem;
  }

  .proy-card-body { padding:1.5rem; flex:1; display:flex; flex-direction:column; }
  .proy-ubicacion {
    display:flex; align-items:center; gap:.4rem;
    font-size:.72rem; color:#aaa; margin-bottom:.5rem;
  }
  .proy-ubicacion svg { width:.85rem; height:.85rem; flex-shrink:0; }
  .proy-card-title {
    font-family:var(--p-head); font-weight:700;
    font-size:1rem; color:#111; margin-bottom:.5rem; line-height:1.35;
  }
  .proy-card-desc { font-size:.83rem; color:#777; line-height:1.65; flex:1; margin-bottom:1rem; }

  .proy-progress { margin-bottom:1.25rem; }
  .proy-progress-head {
    display:flex; justify-content:space-between;
    font-size:.72rem; color:#999; margin-bottom:.4rem;
  }
  .proy-progress-head strong { color:#333; }
  .proy-pct { font-weight:700; color:var(--p-accent); }
  .proy-bar-track { height:4px; background:#eee; }
  .proy-bar-fill { height:100%; background:var(--p-accent); transition:width .4s; }
  .proy-progress-foot {
    display:flex; justify-content:space-between;
    font-size:.7rem; color:#bbb; margin-top:.3rem;
  }

  .proy-card-actions { display:flex; gap:.6rem; margin-top:auto; }
  .proy-btn-sm {
    flex:1; text-align:center; background:var(--p-accent); color:#fff;
    font-weight:700; font-size:.78rem; padding:.6rem .5rem;
    text-decoration:none; text-transform:uppercase; letter-spacing:.06em; transition:background .2s;
  }
  .proy-btn-sm:hover { background:#d97706; }
  .proy-btn-sm-ghost {
    flex:1; text-align:center; border:1.5px solid #111; color:#111;
    font-weight:700; font-size:.78rem; padding:.6rem .5rem;
    text-decoration:none; text-transform:uppercase; letter-spacing:.06em; transition:all .2s;
  }
  .proy-btn-sm-ghost:hover { background:#111; color:#fff; }

  /* EMPTY */
  .proy-empty { text-align:center; padding:5rem 0; }
  .proy-empty-icon {
    width:4rem; height:4rem; background:#fff;
    box-shadow:var(--p-shadow); display:flex; align-items:center;
    justify-content:center; margin:0 auto 1.5rem;
  }
  .proy-empty-icon svg { width:2rem; height:2rem; stroke:#6b7280; }
  .proy-empty-actions { display:flex; gap:.75rem; justify-content:center; flex-wrap:wrap; margin-top:1.5rem; }

  /* CTA */
  .proy-cta {
    background:
      linear-gradient(rgba(8,21,9,.88),rgba(8,21,9,.88)),
      url('/images/evento-playa.jpg') center/cover no-repeat fixed;
    padding:7rem 0;
  }
  .proy-cta-btns { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }

  /* SHARED BUTTONS */
  .proy-btn {
    display:inline-block; background:var(--p-accent); color:#fff;
    font-weight:700; font-size:.85rem; padding:.9rem 2.25rem;
    text-decoration:none; text-transform:uppercase; letter-spacing:.08em; transition:background .2s;
  }
  .proy-btn:hover { background:#d97706; }
  .proy-btn-outline {
    display:inline-block; border:2px solid rgba(255,255,255,.3); color:#fff;
    font-weight:700; font-size:.85rem; padding:.9rem 2.25rem;
    text-decoration:none; text-transform:uppercase; letter-spacing:.08em; transition:all .2s;
  }
  .proy-btn-outline:hover { border-color:var(--p-accent); background:rgba(245,158,11,.1); }
  .proy-btn-outline-dark {
    display:inline-block; border:2px solid #333; color:#333;
    font-weight:700; font-size:.85rem; padding:.9rem 2.25rem;
    text-decoration:none; text-transform:uppercase; letter-spacing:.08em; transition:all .2s;
  }
  .proy-btn-outline-dark:hover { background:#111; color:#fff; border-color:#111; }

  @media(max-width:640px){
    .proy-hero { min-height:auto; padding:6rem 0 4rem; }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.proy-filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  const emptyState = document.getElementById('empty-state');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category ?? 'Todos';
      filterBtns.forEach(b => b.dataset.active = 'false');
      btn.dataset.active = 'true';
      let visible = 0;
      cards.forEach(card => {
        const match = category === 'Todos' || card.dataset.category === category;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (emptyState) emptyState.classList.toggle('hidden', visible > 0);
    });
  });
</script>
