---
import Layout from '../layouts/Layout.astro';

const proyectos = [
  {
    img: '/images/area-conservacion.jpg',
    alt: 'Área de conservación Costa del Bálsamo con señalización oficial',
    titulo: 'Conservación Costa del Bálsamo',
    ubicacion: 'Playa San Diego, La Libertad',
    categoria: 'Manglar',
    estado: 'Activo',
    desc: 'Protección y restauración del ecosistema de manglar en la Costa del Bálsamo. Este proyecto, en alianza con Concentrix, establece un área de conservación que protege la biodiversidad costera, previene inundaciones y preserva los medios de vida de comunidades pesqueras.',
    logros: ['Área de conservación establecida', 'Señalización oficial instalada', 'Comunidades sensibilizadas', 'Alianza público-privada activa'],
  },
  {
    img: '/images/distribucion-plantas.jpg',
    alt: 'Comunidad recibiendo plantas para reforestación',
    titulo: 'Distribución de Plántulas Nativas',
    ubicacion: 'La Libertad, San Juan Buena Vista',
    categoria: 'Reforestación',
    estado: 'Activo',
    desc: 'Producción y entrega gratuita de plántulas de especies nativas a familias rurales para reforestar sus terrenos. El proyecto mejora la economía familiar al combinar restauración ecológica con producción agroforestal sostenible.',
    logros: ['+10,000 plántulas distribuidas', 'Familias rurales beneficiadas', 'Especies nativas priorizadas', 'Seguimiento técnico post-siembra'],
  },
  {
    img: '/images/reforestacion-aerea.jpg',
    alt: 'Vista aérea de zona reforestada junto a la costa salvadoreña',
    titulo: 'Reforestación Costera',
    ubicacion: 'Costa de El Salvador',
    categoria: 'Ecosistemas',
    estado: 'Activo',
    desc: 'Reforestación de zonas costeras degradadas con especies autóctonas. Las vistas aéreas documentan la recuperación de la cobertura vegetal y su impacto en la estabilización de suelos y reducción de la erosión costera.',
    logros: ['Cobertura vegetal restaurada', 'Erosión costera reducida', 'Documentación aérea de progreso', 'Hábitat de fauna recuperado'],
  },
  {
    img: '/images/monitoreo-rio.jpg',
    alt: 'Equipo técnico monitoreando cuencas fluviales en bote',
    titulo: 'Monitoreo de Cuencas Hidrográficas',
    ubicacion: 'Ríos de La Libertad',
    categoria: 'Agua',
    estado: 'Continuo',
    desc: 'Vigilancia técnica permanente de la calidad y salud de ríos y cuerpos de agua. El monitoreo identifica amenazas, mide indicadores de biodiversidad acuática y orienta acciones de restauración para garantizar agua limpia a las comunidades.',
    logros: ['Monitoreo periódico de calidad hídrica', 'Índices de biodiversidad acuática', 'Alertas tempranas de contaminación', 'Datos para toma de decisiones'],
  },
  {
    img: '/images/vivero-comunidad.jpg',
    alt: 'Comunidad trabajando en vivero de plantas nativas',
    titulo: 'Viveros Comunitarios',
    ubicacion: 'Comunidades rurales de El Salvador',
    categoria: 'Comunidad',
    estado: 'Activo',
    desc: 'Establecimiento de viveros manejados por las propias comunidades para producir plántulas de especies nativas. El proyecto genera capacidades locales y fuentes de ingreso mientras contribuye a la restauración del paisaje.',
    logros: ['Viveros establecidos en comunidades', 'Capacitación técnica local', 'Generación de ingresos comunitarios', 'Autonomía en producción de plántulas'],
  },
  {
    img: '/images/evento-playa.jpg',
    alt: 'Jornada de reforestación en playa con participación comunitaria',
    titulo: 'Jornadas de Reforestación',
    ubicacion: 'Playas de El Salvador',
    categoria: 'Voluntariado',
    estado: 'Periódico',
    desc: 'Eventos participativos de plantación masiva que involucran a voluntarios, instituciones y comunidades costeras. Cada jornada fortalece el sentido de pertenencia ambiental y el compromiso colectivo con la conservación.',
    logros: ['Eventos comunitarios realizados', 'Voluntarios movilizados', 'Instituciones aliadas', 'Cobertura mediática local'],
  },
];

const categorias = [...new Set(proyectos.map(p => p.categoria))];
---

<Layout
  title="Proyectos"
  description="Conoce los proyectos de reforestación, conservación de manglares y monitoreo ambiental que realiza Fundación ASISTEDCOS en El Salvador."
  image="/images/reforestacion-aerea.jpg"
>

  <!-- Encabezado -->
  <section class="bg-verde-800 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-verde-300 text-sm font-semibold uppercase tracking-widest">Nuestro trabajo</span>
      <h1 class="font-heading text-4xl md:text-5xl font-extrabold text-white mt-3 mb-4">Proyectos</h1>
      <p class="text-verde-200 text-lg max-w-2xl mx-auto">
        Cada proyecto es una historia de transformación: ecosistemas que renacen y comunidades que prosperan.
      </p>
    </div>
  </section>

  <!-- Grid de proyectos -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {proyectos.map(p => (
          <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300 border border-gray-100 flex flex-col">
            <div class="relative overflow-hidden aspect-[16/10]">
              <img
                src={p.img}
                alt={p.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute top-3 left-3 flex gap-2">
                <span class="bg-verde-600 text-white text-xs font-semibold px-2.5 py-1 rounded-full">{p.categoria}</span>
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${p.estado === 'Activo' ? 'bg-green-500 text-white' : p.estado === 'Continuo' ? 'bg-azul-600 text-white' : 'bg-amber-500 text-white'}`}>
                  {p.estado}
                </span>
              </div>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-center gap-1.5 text-xs text-gray-400 mb-2">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
                {p.ubicacion}
              </div>
              <h2 class="font-heading font-bold text-lg text-verde-900 mb-2">{p.titulo}</h2>
              <p class="text-gray-500 text-sm leading-relaxed mb-4 flex-1">{p.desc}</p>
              <div class="border-t border-gray-100 pt-4">
                <p class="text-xs font-semibold text-verde-700 uppercase tracking-wider mb-2">Logros</p>
                <ul class="space-y-1">
                  {p.logros.map(logro => (
                    <li class="flex items-center gap-2 text-xs text-gray-500">
                      <svg class="h-3.5 w-3.5 text-verde-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                      {logro}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-verde-700 text-white text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-heading text-2xl md:text-3xl font-bold mb-3">¿Quieres apoyar estos proyectos?</h2>
      <p class="text-verde-200 mb-8">Tu donación financia directamente el trabajo en campo.</p>
      <a href="/donar" class="inline-flex items-center gap-2 bg-white text-verde-800 hover:bg-verde-50 font-bold px-10 py-4 rounded-full transition-colors shadow">
        ♥ Donar ahora
      </a>
    </div>
  </section>

</Layout>
