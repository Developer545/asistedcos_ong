---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Nuestro Impacto"
  description="Conoce el impacto de Fundación ASISTEDCOS: más de 27 años restaurando ecosistemas y transformando comunidades en El Salvador."
  image="/images/reforestacion-aerea.jpg"
>

  <!-- Hero -->
  <section class="relative py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/reforestacion-aerea.jpg" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-gray-900/90 to-gray-900/60"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-2 text-gray-400 text-sm mb-4">
        <a href="/" class="hover:text-amber-400 transition-colors">Inicio</a>
        <span>›</span>
        <span class="text-white">Impacto</span>
      </div>
      <span class="inline-block text-amber-500 font-bold text-sm uppercase tracking-wider mb-3">Resultados reales</span>
      <h1 class="font-heading text-4xl md:text-5xl font-extrabold text-white mb-4">Nuestro Impacto</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        Más de 27 años de trabajo continuo han dejado huella en los ecosistemas y comunidades de El Salvador.
      </p>
    </div>
  </section>

  <!-- Big stats -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">En números</span>
        <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-verde-900 mt-2">27+ Años de Resultados</h2>
        <p class="text-gray-500 mt-3 max-w-lg mx-auto">Cada cifra representa vidas transformadas, ecosistemas recuperados y comunidades fortalecidas.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          {
            value: '1997',
            label: 'Año de fundación',
            sub: '27+ años de experiencia',
            icon: `<svg class="h-7 w-7 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
          },
          {
            value: '+50',
            label: 'Comunidades',
            sub: 'Rurales y urbanas atendidas',
            icon: `<svg class="h-7 w-7 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
          },
          {
            value: '+10K',
            label: 'Árboles plantados',
            sub: 'Especies nativas',
            icon: `<svg class="h-7 w-7 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
          },
          {
            value: '3+',
            label: 'Áreas de conservación',
            sub: 'Ecosistemas protegidos',
            icon: `<svg class="h-7 w-7 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
          },
        ].map(stat => (
          <div class="bg-white rounded-lg shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 hover:-translate-y-1 p-8 text-center">
            <div class="w-14 h-14 rounded-full bg-amber-50 flex items-center justify-center mx-auto mb-4" set:html={stat.icon} />
            <p
              class="font-heading text-4xl md:text-5xl font-extrabold text-verde-700 mb-1"
              data-count={stat.value}
            >
              {stat.value}
            </p>
            <p class="font-bold text-verde-900 mt-1">{stat.label}</p>
            <p class="text-xs text-gray-400 mt-1">{stat.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Achievements list -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Logros destacados</span>
        <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-verde-900 mt-2">Áreas de Impacto</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            img: '/images/area-conservacion.jpg',
            alt: 'Conservación de manglares en Costa del Bálsamo',
            titulo: 'Conservación de Ecosistemas Costeros',
            desc: 'Establecimiento y mantenimiento de áreas de conservación de manglares, ecosistemas clave para la pesca artesanal, protección costera y captura de carbono. El área Costa del Bálsamo es uno de nuestros logros más importantes.',
            logros: ['Área de conservación establecida', 'Biodiversidad costera protegida', 'Alianza público-privada con Concentrix'],
          },
          {
            img: '/images/distribucion-plantas.jpg',
            alt: 'Distribución de plántulas a familias rurales salvadoreñas',
            titulo: 'Desarrollo Económico Comunitario',
            desc: 'La distribución de plántulas nativas no solo restaura ecosistemas, sino que mejora directamente la economía familiar de comunidades rurales, generando recursos adicionales y fortaleciendo la soberanía alimentaria.',
            logros: ['+10,000 plántulas distribuidas', 'Familias rurales beneficiadas', 'Ingresos adicionales generados'],
          },
          {
            img: '/images/monitoreo-rio.jpg',
            alt: 'Monitoreo de ríos y cuencas en El Salvador',
            titulo: 'Gestión Hídrica Sostenible',
            desc: 'El monitoreo continuo de cuencas hidrográficas garantiza la disponibilidad de agua limpia para comunidades y ecosistemas. Nuestros datos técnicos informan políticas ambientales a nivel municipal y nacional.',
            logros: ['Monitoreo periódico de cuencas', 'Datos para políticas ambientales', 'Alertas tempranas de contaminación'],
          },
          {
            img: '/images/evento-playa.jpg',
            alt: 'Jornada de reforestación comunitaria en playa salvadoreña',
            titulo: 'Movilización Social y Voluntariado',
            desc: 'Creamos cultura ambiental mediante jornadas participativas que involucran a ciudadanos, estudiantes, empresas y gobiernos locales. La conciencia ambiental es el cambio más duradero que podemos generar.',
            logros: ['Eventos comunitarios realizados', 'Voluntarios movilizados', 'Cobertura mediática local'],
          },
        ].map(area => (
          <div class="bg-white rounded-lg shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100 hover:-translate-y-1 overflow-hidden">
            <div class="relative overflow-hidden h-48">
              <img src={area.img} alt={area.alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
            </div>
            <div class="p-6">
              <h3 class="font-heading font-extrabold text-lg text-verde-900 mb-2">{area.titulo}</h3>
              <p class="text-gray-500 text-sm leading-relaxed mb-4">{area.desc}</p>
              <div class="space-y-1.5">
                {area.logros.map(logro => (
                  <div class="flex items-center gap-2 text-sm">
                    <div class="w-5 h-5 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0">
                      <svg class="h-3 w-3 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <span class="text-gray-600">{logro}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Photo gallery -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Galería de impacto</span>
        <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-verde-900 mt-2">Nuestro Trabajo en Imágenes</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {[
          { src: '/images/area-conservacion.jpg', alt: 'Área de conservación Costa del Bálsamo' },
          { src: '/images/voluntaria-plantando.jpg', alt: 'Voluntaria plantando árboles' },
          { src: '/images/reforestacion-aerea.jpg', alt: 'Vista aérea de reforestación' },
          { src: '/images/distribucion-plantas.jpg', alt: 'Distribución de plántulas' },
          { src: '/images/monitoreo-rio.jpg', alt: 'Monitoreo de cuencas' },
          { src: '/images/vivero-comunidad.jpg', alt: 'Vivero comunitario' },
        ].map((photo, index) => (
          <div class={`relative overflow-hidden rounded-lg ${index === 0 || index === 5 ? 'md:col-span-2' : ''}`}>
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full h-48 md:h-64 object-cover hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gray-900/0 hover:bg-gray-900/30 transition-colors duration-300 flex items-center justify-center">
              <span class="text-white font-semibold text-sm opacity-0 hover:opacity-100 transition-opacity px-3 text-center">{photo.alt}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="py-16 bg-gray-50 border-y border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Quienes nos apoyan</span>
      <h2 class="font-heading text-2xl md:text-3xl font-extrabold text-verde-900 mt-2 mb-3">Aliados Estratégicos</h2>
      <p class="text-gray-500 mb-10 max-w-lg mx-auto">Trabajamos con empresas, instituciones y organismos internacionales para maximizar nuestro impacto.</p>
      <div class="flex flex-wrap justify-center gap-4">
        {[
          { name: 'Concentrix', type: 'Empresa privada' },
          { name: 'Ministerio de Medio Ambiente', type: 'Gobierno' },
          { name: 'Alcaldías Municipales', type: 'Gobierno local' },
          { name: 'Cooperación Internacional', type: 'Organismos internacionales' },
          { name: 'Comunidades Locales', type: 'Sociedad civil' },
        ].map(aliado => (
          <div class="bg-white border border-gray-200 rounded-lg px-6 py-4 shadow-sm hover:shadow-md hover:border-amber-300 transition-all duration-300">
            <p class="font-bold text-verde-900 text-sm">{aliado.name}</p>
            <p class="text-xs text-gray-400 mt-0.5">{aliado.type}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gray-900 relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/voluntaria-plantando.jpg" alt="" class="w-full h-full object-cover opacity-15" />
    </div>
    <div class="relative max-w-3xl mx-auto px-4 text-center">
      <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Únete al cambio</span>
      <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-white mt-2 mb-4">Sé parte de este impacto</h2>
      <p class="text-gray-300 text-lg mb-8">Cada donación amplifica nuestro trabajo en el territorio y multiplica el impacto para El Salvador.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/donar" class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-8 py-4 rounded-sm transition-colors shadow-lg text-lg">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
          Donar ahora
        </a>
        <a href="/proyectos" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white hover:bg-white hover:text-gray-900 font-bold px-8 py-4 rounded-sm transition-colors text-lg">
          Ver proyectos
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Animated counters
  const counters = document.querySelectorAll<HTMLElement>('[data-count]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const raw = el.dataset.count ?? '';
        // Only animate pure numbers
        const num = parseInt(raw.replace(/\D/g, ''), 10);
        if (isNaN(num)) return;
        const prefix = raw.startsWith('+') ? '+' : '';
        const suffix = raw.endsWith('K') ? 'K' : '';
        const duration = 1500;
        const start = performance.now();
        const animate = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(eased * num);
          el.textContent = prefix + current.toLocaleString() + suffix;
          if (progress < 1) requestAnimationFrame(animate);
        };
        requestAnimationFrame(animate);
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.3 });

  counters.forEach(counter => observer.observe(counter));
</script>
