---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

const valores = [
  { icon: '01', titulo: 'Integridad', desc: 'Actuamos con honestidad y transparencia en cada proyecto, rendición de cuentas y relación con la comunidad.' },
  { icon: '02', titulo: 'Compromiso', desc: 'Nos involucramos profundamente con cada comunidad, garantizando que el impacto sea real y duradero.' },
  { icon: '03', titulo: 'Innovación', desc: 'Aplicamos metodologías técnicas actualizadas y enfoques creativos para maximizar el impacto ambiental.' },
  { icon: '04', titulo: 'Colaboración', desc: 'Articulamos sectores público, privado y sociedad civil para construir soluciones compartidas.' },
];

const areas = [
  {
    titulo: 'Restauración de Ecosistemas',
    desc: 'Rehabilitación de bosques, manglares y cuencas hidrográficas con especies nativas.',
    num: '01',
  },
  {
    titulo: 'Reforestación Comunitaria',
    desc: 'Producción y distribución de plántulas a familias campesinas para restaurar cobertura vegetal.',
    num: '02',
  },
  {
    titulo: 'Monitoreo Ambiental',
    desc: 'Seguimiento técnico de la salud de ríos, bosques y zonas costeras protegidas.',
    num: '03',
  },
  {
    titulo: 'Capacitación Técnica',
    desc: 'Formación de líderes comunitarios en gestión ambiental y prácticas agroecológicas.',
    num: '04',
  },
  {
    titulo: 'Gestión de Alianzas',
    desc: 'Articulación entre comunidades, empresas privadas, gobierno y cooperación internacional.',
    num: '05',
  },
  {
    titulo: 'Compensación Ambiental',
    desc: 'Implementación de programas de compensación ecológica en áreas protegidas.',
    num: '06',
  },
];

const timeline = [
  { year: '1997', titulo: 'Fundación', desc: 'ASISTEDCOS nace en el período de posguerra para atender los problemas socioambientales que dejó el conflicto armado en comunidades rurales.' },
  { year: '2000s', titulo: 'Primeros Proyectos', desc: 'Inicio de programas de reforestación comunitaria y distribución de plántulas nativas a familias rurales de La Libertad.' },
  { year: '2010s', titulo: 'Expansión y Alianzas', desc: 'Alianzas estratégicas con empresas privadas, municipalidades y organismos internacionales para ampliar el alcance territorial.' },
  { year: '2020', titulo: 'Costa del Bálsamo', desc: 'Lanzamiento del área de conservación de manglares Costa del Bálsamo, en alianza con Concentrix — uno de los proyectos más emblemáticos.' },
  { year: 'Hoy', titulo: '+27 Años', desc: 'Continuamos restaurando ecosistemas, formando comunidades y construyendo un El Salvador más verde para las generaciones futuras.' },
];

const legal = [
  { label: 'Registro', value: 'Ministerio de Gobernación de El Salvador' },
  { label: 'Tipo de entidad', value: 'Fundación sin fines de lucro' },
  { label: 'Donaciones', value: 'Deducibles de impuestos — Art. 32 Ley de Renta' },
];
---

<Layout
  title="Quiénes Somos"
  description="Conoce la historia, misión y visión de Fundación ASISTEDCOS, organización salvadoreña de gestión socioambiental fundada en 1997."
  image="/images/voluntaria-plantando.jpg"
>

<!-- ══════════════════════════════════════════════
     HERO
══════════════════════════════════════════════════ -->
<section class="n-hero">
  <div class="n-hero-bg"></div>
  <div class="n-container">
    <nav class="n-breadcrumb">
      <a href="/">Inicio</a>
      <span>›</span>
      <span>Quiénes Somos</span>
    </nav>
    <p class="n-eyebrow">Fundada en 1997</p>
    <h1 class="n-h1">Quiénes <span class="n-accent">Somos</span></h1>
    <p class="n-hero-sub">
      Una organización apolítica y sin fines de lucro comprometida con la restauración ecológica y el desarrollo comunitario sostenible en El Salvador.
    </p>
  </div>
  <div class="n-hero-scroll" aria-hidden="true"><span></span></div>
</section>

<!-- ══════════════════════════════════════════════
     STATS
══════════════════════════════════════════════════ -->
<div class="n-stats-bar">
  {[
    { value: '1997', label: 'Año de fundación' },
    { value: '+27',  label: 'Años de experiencia' },
    { value: '+50',  label: 'Comunidades atendidas' },
    { value: '100%', label: 'Sin fines de lucro' },
  ].map(s => (
    <div class="n-stat">
      <p class="n-stat-val">{s.value}</p>
      <p class="n-stat-lbl">{s.label}</p>
    </div>
  ))}
</div>

<!-- ══════════════════════════════════════════════
     HISTORIA
══════════════════════════════════════════════════ -->
<section class="n-section" style="background:#fff; position:relative;">
  <div class="n-deco-num" aria-hidden="true">.01</div>
  <div class="n-container">
    <div class="n-split">

      <!-- Texto -->
      <div class="n-split-text">
        <p class="n-eyebrow">Nuestra historia</p>
        <h2 class="n-h2">Más de 27 años transformando <span class="n-accent">El Salvador</span></h2>
        <div class="n-historia-body">
          <p class="n-historia-lead">
            <strong>ASISTEDCOS</strong> — Fundación de Asistencia Técnica para el Desarrollo Comunal Salvadoreño — nació en <strong>1997</strong>, en el período de posguerra, para atender los problemas socioambientales que dejó el conflicto armado en las comunidades rurales del país.
          </p>
          <p class="n-historia-p">
            Bajo la coordinación de la <strong>Lic. Blanca Estela Juárez</strong>, la fundación se enfocó desde sus inicios en brindar asistencia técnica especializada en gestión socioambiental, reconociendo que la conservación de la biodiversidad solo es efectiva cuando se involucra activamente a las comunidades que dependen de los recursos naturales.
          </p>
          <p class="n-historia-p">
            Registrada oficialmente en el <strong>Ministerio de Gobernación y Desarrollo Territorial</strong>, ASISTEDCOS ha desarrollado planes, programas y proyectos que contribuyen tanto a la rehabilitación de ecosistemas como a la mejora de la economía familiar de las poblaciones locales.
          </p>
        </div>
        <a href="/proyectos" class="n-btn">Ver nuestros proyectos &rarr;</a>
      </div>

      <!-- Fotos -->
      <div class="n-split-photos">
        <div class="n-photo-main">
          <img src="/images/area-conservacion.jpg" alt="Área de conservación Costa del Bálsamo" loading="lazy" />
          <div class="n-photo-badge">Costa del Bálsamo</div>
        </div>
        <div class="n-photo-row">
          <div class="n-photo-sm">
            <img src="/images/voluntaria-plantando.jpg" alt="Voluntaria plantando" loading="lazy" />
          </div>
          <div class="n-photo-sm">
            <img src="/images/vivero-comunidad.jpg" alt="Vivero comunitario" loading="lazy" />
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     MISIÓN · VISIÓN · VALORES
══════════════════════════════════════════════════ -->
<section class="n-section" style="background:#f7f7f7; position:relative; overflow:hidden;">
  <div class="n-deco-num n-deco-right" aria-hidden="true">.02</div>
  <div class="n-container">
    <div class="n-section-head n-center">
      <p class="n-eyebrow">Nuestro propósito</p>
      <h2 class="n-h2">Misión, Visión <span class="n-accent">y Valores</span></h2>
    </div>

    <div class="n-mvv-grid">
      <!-- Misión -->
      <div class="n-mvv-card n-mvv-featured">
        <div class="n-mvv-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <p class="n-mvv-tag">Misión</p>
        <p class="n-mvv-text">Proveer asistencia técnica especializada en gestión socioambiental a comunidades rurales, semi-rurales y urbanas de El Salvador, contribuyendo a la restauración de ecosistemas y al desarrollo sostenible de las familias.</p>
      </div>

      <!-- Visión -->
      <div class="n-mvv-card">
        <div class="n-mvv-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
        </div>
        <p class="n-mvv-tag">Visión</p>
        <p class="n-mvv-text">Promover la autosuficiencia y resiliencia de las comunidades salvadoreñas mediante enfoques innovadores que impulsen su bienestar integral y el equilibrio ambiental del país.</p>
      </div>

      <!-- Valores grid 2x2 -->
      <div class="n-valores-grid">
        {valores.map(v => (
          <div class="n-valor-item">
            <span class="n-valor-num">{v.icon}</span>
            <h4 class="n-valor-title">{v.titulo}</h4>
            <p class="n-valor-desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     ÁREAS DE TRABAJO
══════════════════════════════════════════════════ -->
<section class="n-section" style="background:#fff; position:relative;">
  <div class="n-container">
    <div class="n-section-head n-center">
      <p class="n-eyebrow">Lo que hacemos</p>
      <h2 class="n-h2">Áreas de <span class="n-accent">Trabajo</span></h2>
      <p class="n-section-sub">Intervención integral desde la restauración ecológica hasta el fortalecimiento comunitario.</p>
    </div>
    <div class="n-areas-grid">
      {areas.map(a => (
        <div class="n-area-card">
          <span class="n-area-num">{a.num}</span>
          <h3 class="n-area-title">{a.titulo}</h3>
          <p class="n-area-desc">{a.desc}</p>
          <div class="n-area-line"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     TIMELINE
══════════════════════════════════════════════════ -->
<section class="n-timeline-section">
  <div class="n-deco-num" style="color:rgba(255,255,255,0.03);" aria-hidden="true">.03</div>
  <div class="n-container">
    <div class="n-section-head n-center">
      <p class="n-eyebrow" style="color:rgba(245,158,11,0.8);">Nuestra trayectoria</p>
      <h2 class="n-h2" style="color:#fff;">Historia de <span class="n-accent">Impacto</span></h2>
    </div>

    <div class="n-timeline">
      <div class="n-timeline-line"></div>
      {timeline.map((item, i) => (
        <div class={`n-timeline-item ${i % 2 === 0 ? 'n-tl-left' : 'n-tl-right'}`}>
          <div class="n-tl-card">
            <span class="n-tl-year">{item.year}</span>
            <h3 class="n-tl-title">{item.titulo}</h3>
            <p class="n-tl-desc">{item.desc}</p>
          </div>
          <div class="n-tl-dot"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     MARCO LEGAL
══════════════════════════════════════════════════ -->
<section class="n-legal-section">
  <div class="n-container">
    <div class="n-section-head n-center">
      <p class="n-eyebrow" style="color:rgba(245,158,11,0.8);">Transparencia</p>
      <h2 class="n-h2" style="color:#fff;">Marco <span class="n-accent">Legal</span></h2>
      <p class="n-section-sub" style="color:rgba(255,255,255,0.55);">
        Operamos bajo la <strong style="color:#fff;">Ley de Asociaciones y Fundaciones Sin Fines de Lucro</strong> (D.L. No. 894, 1996) de El Salvador, con registro activo en el Ministerio de Gobernación y Desarrollo Territorial.
      </p>
    </div>
    <div class="n-legal-grid">
      {legal.map(l => (
        <div class="n-legal-card">
          <p class="n-legal-label">{l.label}</p>
          <p class="n-legal-value">{l.value}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     CTA
══════════════════════════════════════════════════ -->
<section class="n-cta">
  <div class="n-container n-center">
    <p class="n-eyebrow" style="color:rgba(245,158,11,0.8);">Únete a la misión</p>
    <h2 class="n-h2" style="color:#fff;">Sé parte del <span class="n-accent">cambio</span></h2>
    <p class="n-cta-sub">Tu apoyo nos permite seguir restaurando ecosistemas y transformando comunidades en El Salvador.</p>
    <div class="n-cta-actions">
      <a href="/donar" class="n-btn-accent">♥ Donar ahora</a>
      <a href="/contacto" class="n-btn-outline">Ser voluntario &rarr;</a>
    </div>
  </div>
</section>

</Layout>

<style>
  /* ══════════════════════════════════════
     TOKENS
  ══════════════════════════════════════ */
  :root {
    --n-accent:  #f59e0b;
    --n-dark:    #111111;
    --n-forest:  #081509;
    --n-head:    'Poppins', system-ui, sans-serif;
    --n-shadow:  0 8px 30px rgba(0,0,0,0.08);
  }

  /* ══════════════════════════════════════
     LAYOUT
  ══════════════════════════════════════ */
  .n-container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .n-section   { padding: 6rem 0; overflow: hidden; }
  .n-center    { text-align: center; }
  .n-section-head { margin-bottom: 3.5rem; }
  .n-section-sub {
    color: #666; font-size: 1rem; max-width: 500px;
    margin: 0.5rem auto 0; line-height: 1.7;
  }
  .n-deco-num {
    position: absolute; top: 3rem; left: -1rem;
    font-family: var(--n-head); font-size: clamp(7rem,15vw,14rem);
    font-weight: 900; color: rgba(0,0,0,0.035);
    line-height: 1; pointer-events: none; user-select: none;
  }
  .n-deco-right { left: auto; right: -1rem; }

  /* ══════════════════════════════════════
     TYPOGRAPHY
  ══════════════════════════════════════ */
  .n-eyebrow {
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.28em;
    color: var(--n-accent); display: block; margin-bottom: 0.75rem;
  }
  .n-h1 {
    font-family: var(--n-head); font-weight: 800;
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    line-height: 1.07; color: #fff; margin-bottom: 1.25rem;
  }
  .n-h2 {
    font-family: var(--n-head); font-weight: 800;
    font-size: clamp(1.9rem, 3.5vw, 2.6rem);
    line-height: 1.15; color: var(--n-dark); margin-bottom: 0.75rem;
  }
  .n-accent { color: var(--n-accent); }

  /* ══════════════════════════════════════
     HERO
  ══════════════════════════════════════ */
  .n-hero {
    position: relative; min-height: 72vh;
    display: flex; align-items: center;
    padding: 8rem 0 5rem; overflow: hidden;
  }
  .n-hero-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right, rgba(8,21,9,0.90) 0%, rgba(8,21,9,0.72) 60%, rgba(8,21,9,0.55) 100%),
      url('https://images.unsplash.com/photo-1503785640985-f62e3aeee448?w=1920&q=80') center center / cover no-repeat;
  }
  .n-hero .n-container { position: relative; z-index: 1; }
  .n-breadcrumb {
    display: flex; gap: 0.5rem; align-items: center;
    font-size: 0.8rem; color: rgba(255,255,255,0.4);
    margin-bottom: 1.5rem;
  }
  .n-breadcrumb a { color: rgba(255,255,255,0.4); text-decoration: none; }
  .n-breadcrumb a:hover { color: var(--n-accent); }
  .n-hero-sub {
    color: rgba(255,255,255,0.72); font-size: 1.1rem;
    max-width: 580px; line-height: 1.75; margin-top: 1rem;
  }
  .n-hero-scroll {
    position: absolute; bottom: 2rem; left: 50%;
    transform: translateX(-50%);
  }
  .n-hero-scroll span {
    display: block; width: 1px; height: 60px;
    background: linear-gradient(to bottom, rgba(245,158,11,0.8), transparent);
    animation: n-scroll 1.8s ease-in-out infinite;
  }
  @keyframes n-scroll {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ══════════════════════════════════════
     STATS BAR
  ══════════════════════════════════════ */
  .n-stats-bar {
    background: var(--n-forest);
    display: flex; justify-content: center;
  }
  .n-stat {
    flex: 1; max-width: 220px; text-align: center;
    padding: 2.5rem 1rem;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .n-stat:last-child { border-right: none; }
  .n-stat-val {
    font-family: var(--n-head); font-size: 2.4rem;
    font-weight: 800; color: var(--n-accent); line-height: 1;
    margin-bottom: 0.4rem;
  }
  .n-stat-lbl {
    font-size: 0.72rem; color: rgba(255,255,255,0.45);
    text-transform: uppercase; letter-spacing: 0.12em;
  }

  /* ══════════════════════════════════════
     HISTORIA
  ══════════════════════════════════════ */
  .n-split {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: center;
  }
  @media(max-width:900px){ .n-split { grid-template-columns: 1fr; gap: 3rem; } }

  .n-split-text {}
  .n-historia-lead {
    font-size: 1rem; line-height: 1.8; color: #444;
    border-left: 3px solid var(--n-accent);
    padding-left: 1.25rem; margin: 1.5rem 0 1rem;
  }
  .n-historia-p {
    font-size: 0.95rem; line-height: 1.8; color: #666;
    margin-bottom: 1rem;
  }
  .n-btn {
    display: inline-block;
    margin-top: 1.5rem;
    background: var(--n-accent); color: #fff;
    font-weight: 700; font-size: 0.85rem;
    text-transform: uppercase; letter-spacing: 0.08em;
    padding: 0.85rem 2rem; text-decoration: none;
    transition: background 0.2s;
  }
  .n-btn:hover { background: #d97706; }

  .n-photo-main {
    position: relative; overflow: hidden;
    aspect-ratio: 4/3; margin-bottom: 0.75rem;
  }
  .n-photo-main img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .n-photo-main:hover img { transform: scale(1.05); }
  .n-photo-badge {
    position: absolute; bottom: 1rem; left: 1rem;
    background: rgba(8,21,9,0.82);
    color: var(--n-accent); font-size: 0.7rem;
    font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; padding: 0.3rem 0.75rem;
  }
  .n-photo-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .n-photo-sm { overflow: hidden; aspect-ratio: 1; }
  .n-photo-sm img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .n-photo-sm:hover img { transform: scale(1.07); }

  /* ══════════════════════════════════════
     MISIÓN · VISIÓN · VALORES
  ══════════════════════════════════════ */
  .n-mvv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5px; background: #e0e0e0;
  }
  @media(max-width:900px){ .n-mvv-grid { grid-template-columns: 1fr; } }

  .n-mvv-card {
    background: #fff; padding: 2.5rem 2rem;
    display: flex; flex-direction: column; gap: 1rem;
    transition: transform 0.3s; position: relative;
  }
  .n-mvv-card:hover { transform: translateY(-4px); z-index: 1; box-shadow: var(--n-shadow); }
  .n-mvv-featured { border-top: 3px solid var(--n-accent); }

  .n-mvv-icon {
    width: 3rem; height: 3rem;
    background: var(--n-forest);
    display: flex; align-items: center; justify-content: center;
  }
  .n-mvv-icon svg { width: 1.4rem; height: 1.4rem; stroke: var(--n-accent); }
  .n-mvv-tag {
    font-family: var(--n-head); font-size: 1.2rem;
    font-weight: 800; color: var(--n-dark);
  }
  .n-mvv-text { font-size: 0.88rem; color: #666; line-height: 1.75; }

  .n-valores-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1.5px; background: #e0e0e0;
  }
  .n-valor-item {
    background: #fff; padding: 1.75rem 1.5rem;
    display: flex; flex-direction: column; gap: 0.4rem;
    transition: background 0.2s;
  }
  .n-valor-item:hover { background: #fefce8; }
  .n-valor-num {
    font-family: var(--n-head); font-size: 0.65rem;
    font-weight: 800; color: var(--n-accent);
    letter-spacing: 0.15em;
  }
  .n-valor-title {
    font-family: var(--n-head); font-size: 0.95rem;
    font-weight: 700; color: var(--n-dark);
  }
  .n-valor-desc { font-size: 0.78rem; color: #888; line-height: 1.6; }

  /* ══════════════════════════════════════
     ÁREAS DE TRABAJO
  ══════════════════════════════════════ */
  .n-areas-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px; background: #e0e0e0;
  }
  @media(max-width:900px){ .n-areas-grid { grid-template-columns: repeat(2,1fr); } }
  @media(max-width:560px){ .n-areas-grid { grid-template-columns: 1fr; } }

  .n-area-card {
    background: #fff; padding: 2rem 1.75rem;
    position: relative; overflow: hidden;
