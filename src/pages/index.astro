    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="inline-flex items-center gap-2 text-amber-500 font-bold text-xs uppercase tracking-widest mb-2">
          <span class="w-6 h-px bg-amber-400 inline-block"></span>
          Juntos es posible
          <span class="w-6 h-px bg-amber-400 inline-block"></span>
        </span>
        <h2 class="font-heading text-2xl md:text-3xl font-extrabold text-gray-900 mt-1">Nuestros aliados</h2>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
        {partners.map(partner => (
