---
export const prerender = false;
import Layout from '../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcosadmin.vercel.app';

type NewsItem    = { id: string; title: string; slug: string; summary?: string; coverImage?: string; publishedAt?: string };
type CauseItem   = { id: string; titulo: string; descripcion?: string; tag?: string; coverImage?: string; meta: number; recaudado: number };
type FaqItem     = { id: string; question: string; answer: string };
type GalleryItem = { id: string; title?: string; url: string; category?: string };
type PartnerItem = { id: string; name: string; logo?: string; url?: string };

let latestNews: NewsItem[]     = [];
let causeCards: CauseItem[]    = [];
let faqItems: FaqItem[]        = [];
let galleryItems: GalleryItem[] = [];
let partners: PartnerItem[]    = [];
let siteContent: Record<string, string> = {};

await Promise.allSettled([
  fetch(`${ADMIN_URL}/api/public/noticias?limit=3`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) latestNews = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/causas`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) causeCards = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/faq`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) faqItems = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/galeria`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) galleryItems = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/aliados`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) partners = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/contenido`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null)
    .then(d => {
      if (d?.data) {
        d.data.forEach((item: { section: string; key: string; value: string }) => {
          siteContent[`${item.section}__${item.key}`] = item.value;
        });
      }
    }),
]);

const testimonials = [
  { quote: 'Gracias a ASISTEDCOS aprendimos a proteger los manglares que nos dan vida. El apoyo técnico fue fundamental para nuestra comunidad.', name: 'María López', role: 'Pescadora, La Libertad', initials: 'ML' },
  { quote: 'Como empresa, nuestra alianza con ASISTEDCOS nos permitió recuperar el área de conservación en la Costa del Bálsamo. Un impacto real y medible.', name: 'Representante Concentrix', role: 'Aliado Estratégico', initials: 'CO' },
  { quote: 'Los viveros comunitarios cambiaron nuestra forma de ver el territorio. Hoy somos guardianes del bosque.', name: 'Juan García', role: 'Comunidad Rural, La Libertad', initials: 'JG' },
];

const teamMembers = [
  { initials: 'BJ', nombre: 'Lic. Blanca Estela Juárez', cargo: 'Directora Ejecutiva' },
  { initials: 'ET', nombre: 'Equipo Técnico', cargo: 'Gestión Ambiental' },
  { initials: 'CM', nombre: 'Campo y Monitoreo', cargo: 'Reforestación' },
  { initials: '+20', nombre: 'Voluntarios', cargo: 'Colaboradores activos' },
];
---

<Layout
  title="Fundación ASISTEDCOS"
  description="Recuperando ecosistemas para la biodiversidad y la humanidad en El Salvador desde 1997."
>

<!-- ══════════════════════════════════════════════
     HERO  — split layout + collage + deco number
══════════════════════════════════════════════════ -->
<section class="ds-hero">
  <!-- Decorative number -->
  <div class="ds-deco-num" aria-hidden="true">.01</div>

  <div class="ds-container ds-hero-inner">

    <!-- Left: text -->
    <div class="ds-hero-text animate-fade-up">
      <p class="ds-eyebrow">ONG Ambiental &mdash; El Salvador, desde 1997</p>
      <h1 class="ds-h1">
        Recuperando<br/>
        <span class="ds-accent">ecosistemas</span><br/>
        para la vida
      </h1>
      <p class="ds-hero-sub">
        Trabajamos con comunidades rurales de El Salvador para restaurar bosques, proteger manglares y construir un futuro sostenible.
      </p>
      <div class="ds-hero-actions">
        <a href="/donar" class="ds-btn">Apoya la misión</a>
        <a href="/proyectos" class="ds-btn-ghost">Ver proyectos &rarr;</a>
      </div>
    </div>

    <!-- Right: photo collage -->
    <div class="ds-hero-collage animate-fade-up-delay">
      <div class="ds-collage-main">
        <img
          src={siteContent['hero__imagen'] || '/images/reforestacion-aerea.jpg'}
          alt="Reforestación costera El Salvador"
          fetchpriority="high"
        />
      </div>
      <div class="ds-collage-over">
        <img
          src={siteContent['about__imagen'] || '/images/voluntaria-plantando.jpg'}
          alt="Voluntaria plantando"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     STATS BAR
══════════════════════════════════════════════════ -->
<section class="ds-stats-bar">
  <div class="ds-container">
    <div class="ds-stats-grid" id="counters-section">
      {[
        { count: 125,  suffix: '',  label: 'Comunidades apoyadas' },
        { count: 27,   suffix: '+', label: 'Años de trayectoria' },
        { count: 10000,suffix: '+', label: 'Árboles plantados' },
        { count: 6,    suffix: '',  label: 'Proyectos activos' },
      ].map(s => (
        <div class="ds-stat">
          <div class="ds-stat-num">
            <span data-count={s.count} class="counter-num">0</span>
            <span class="ds-stat-suffix">{s.suffix}</span>
          </div>
          <div class="ds-stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     ABOUT  — text left + overlapping photos right
══════════════════════════════════════════════════ -->
<section class="ds-section ds-about">
  <!-- Decorative number -->
  <div class="ds-deco-num ds-deco-right" aria-hidden="true">.02</div>

  <div class="ds-container ds-about-inner">

    <!-- Left text -->
    <div class="ds-about-text">
      <p class="ds-eyebrow">Quiénes somos</p>
      <h2 class="ds-h2">
        Somos el equipo<br/>
        que cuida el<br/>
        <span class="ds-accent">planeta</span>
      </h2>
      <p class="ds-body">
        ASISTEDCOS nació en 1997 para atender las secuelas ambientales y sociales de la posguerra en El Salvador. A través de asistencia técnica especializada, promovemos la autogestión comunitaria y la restauración ecológica.
      </p>
      <p class="ds-body">
        Trabajamos con comunidades rurales, semi-rurales y urbanas, facilitando la cooperación entre el sector público, privado y organismos internacionales.
      </p>
      <a href="/nosotros" class="ds-btn ds-btn-sm">Conoce nuestra historia</a>
    </div>

    <!-- Right: overlapping photos -->
    <div class="ds-about-collage">
      <div class="ds-about-img-back">
        <img
          src={siteContent['about__imagen'] || '/images/voluntaria-plantando.jpg'}
          alt="Trabajo comunitario ASISTEDCOS"
          loading="lazy"
        />
      </div>
      <div class="ds-about-img-front">
        <img
          src={siteContent['hero__imagen'] || '/images/reforestacion-aerea.jpg'}
          alt="Reforestación en El Salvador"
          loading="lazy"
          style="filter: grayscale(30%);"
        />
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     SERVICIOS / CÓMO AYUDAR  — minimal icon cards
══════════════════════════════════════════════════ -->
<section class="ds-section" style="background:#f7f7f7;">
  <div class="ds-deco-num ds-deco-left" aria-hidden="true">.03</div>
  <div class="ds-container">
    <div class="ds-section-head ds-center">
      <p class="ds-eyebrow">Súmate</p>
      <h2 class="ds-h2">¿Cómo puedes<br/><span class="ds-accent">ayudar</span>?</h2>
    </div>

    <div class="ds-services-grid">
      {[
        {
          icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`,
          titulo: 'Donar',
          desc: 'Tu aporte financia proyectos de reforestación y protección de manglares en El Salvador.',
          href: '/donar', cta: 'Donar ahora',
        },
        {
          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
          titulo: 'Voluntariar',
          desc: 'Únete a jornadas de trabajo comunitario, plantación y monitoreo de ecosistemas.',
          href: '/contacto', cta: 'Ser voluntario',
        },
        {
          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
          titulo: 'Aliarte',
          desc: 'Las empresas que nos apoyan generan impacto ambiental real y medible en conservación.',
          href: '/contacto', cta: 'Ser aliado',
        },
        {
          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>`,
          titulo: 'Difundir',
          desc: 'Comparte nuestra misión en redes sociales y ayúdanos a llegar a más personas.',
          href: 'https://www.facebook.com/FundacionAsistedcos', cta: 'Compartir',
        },
      ].map(s => (
        <div class="ds-service group">
          <div class="ds-service-icon">{<Fragment set:html={s.icon} />}</div>
          <h3 class="ds-service-title">{s.titulo}</h3>
          <p class="ds-service-desc">{s.desc}</p>
          <a href={s.href} class="ds-link">{s.cta} &rarr;</a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     CAUSAS  — portfolio grid
══════════════════════════════════════════════════ -->
{causeCards.length > 0 && (
<section class="ds-section bg-white">
  <div class="ds-container">
    <div class="ds-section-head">
      <div>
        <p class="ds-eyebrow">Lo que hacemos</p>
        <h2 class="ds-h2">Causas que<br/><span class="ds-accent">impulsamos</span></h2>
      </div>
      <a href="/proyectos" class="ds-link ds-link-lg">Ver todos los proyectos &rarr;</a>
    </div>

    <div class="ds-causes-grid">
      {causeCards.map(cause => {
        const meta = Number(cause.meta);
        const rec  = Number(cause.recaudado);
        const pct  = meta > 0 ? Math.round((rec / meta) * 100) : 0;
        return (
          <div class="ds-cause group">
            <div class="ds-cause-img">
              <img
                src={cause.coverImage || '/images/reforestacion-aerea.jpg'}
                alt={cause.titulo}
                class="group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
              {cause.tag && <span class="ds-cause-tag">{cause.tag}</span>}
            </div>
            <div class="ds-cause-body">
              <h3 class="ds-cause-title">{cause.titulo}</h3>
              <p class="ds-cause-desc">{cause.descripcion}</p>
              <!-- progress -->
              <div class="ds-progress-wrap">
                <div class="ds-progress-bar">
                  <div class="ds-progress-fill" style={`width:${Math.min(pct,100)}%`}></div>
                </div>
                <div class="ds-progress-meta">
                  <span class="ds-progress-pct">{pct}% logrado</span>
                  <span class="ds-progress-goal">Meta: <strong>${(meta/1000).toFixed(0)}k</strong></span>
                </div>
              </div>
              <a href="/donar" class="ds-btn ds-btn-sm ds-btn-block">Donar a esta causa</a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
)}

<!-- ══════════════════════════════════════════════
     CTA BANNER OSCURO  — Desart style dark band
══════════════════════════════════════════════════ -->
<section class="ds-cta-band">
  <!-- Foto que sangra a la derecha -->
  <div class="ds-cta-img">
    <img
      src={siteContent['about__imagen'] || '/images/voluntaria-plantando.jpg'}
      alt="Voluntaria ASISTEDCOS"
      loading="lazy"
    />
  </div>

  <div class="ds-container ds-cta-inner">
    <div class="ds-cta-content">
      <p class="ds-eyebrow ds-eyebrow-light">Haz la diferencia hoy</p>
      <h2 class="ds-h2 text-white">
        Tu donación<br/>
        <span class="ds-accent">restaura ecosistemas</span>
      </h2>
      <p class="ds-cta-sub">Cada aporte nos permite plantar más árboles, proteger más manglares y acompañar más comunidades.</p>
      <p class="ds-cta-legal">
        <svg class="inline w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Donaciones deducibles &mdash; Art. 32 Ley de Renta El Salvador
      </p>
      <!-- Amount buttons -->
      <div class="ds-amounts">
        {['$10','$25','$50','$100','$250','Otro monto'].map(a => (
          <a href="/donar" class="ds-amount-btn amount-btn">{a}</a>
        ))}
      </div>
      <div class="ds-cta-btns">
        <a href="/donar" class="ds-btn">Donar ahora</a>
        <a href="/contacto" class="ds-btn-ghost-light">Ser voluntario &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     GALERÍA
══════════════════════════════════════════════════ -->
{galleryItems.length > 0 && (
<section class="ds-section" style="background:#f7f7f7;">
  <div class="ds-container">
    <div class="ds-section-head ds-center">
      <p class="ds-eyebrow">Nuestro trabajo</p>
      <h2 class="ds-h2">Galería de <span class="ds-accent">impacto</span></h2>
    </div>
    <div class="ds-gallery-grid">
      {galleryItems.slice(0,6).map(item => (
        <div class="ds-gallery-item group">
          <img
            src={item.url}
            alt={item.title || 'Galería ASISTEDCOS'}
            class="group-hover:scale-110 transition-transform duration-700"
            loading="lazy"
          />
          <div class="ds-gallery-overlay">
            {item.title && <p class="ds-gallery-title">{item.title}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<!-- ══════════════════════════════════════════════
     CÓMO TRABAJAMOS  — 3 steps horizontal
══════════════════════════════════════════════════ -->
<section class="ds-section bg-white">
  <div class="ds-deco-num ds-deco-right" aria-hidden="true">.04</div>
  <div class="ds-container">
    <div class="ds-section-head ds-center">
      <p class="ds-eyebrow">Nuestro proceso</p>
      <h2 class="ds-h2">¿Cómo <span class="ds-accent">trabajamos</span>?</h2>
    </div>

    <div class="ds-process-grid">
      {[
        {
          num: '01', titulo: 'Identificamos',
          desc: 'Realizamos diagnósticos ambientales y sociales para entender las necesidades específicas de cada comunidad y ecosistema.',
          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>`,
        },
        {
          num: '02', titulo: 'Actuamos',
          desc: 'Implementamos proyectos de reforestación, conservación y desarrollo comunitario con participación local activa.',
          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
        },
        {
          num: '03', titulo: 'Medimos',
          desc: 'Monitoreamos y evaluamos el impacto de cada intervención para garantizar resultados tangibles y sostenibles.',
          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
        },
      ].map((step, i) => (
        <div class={`ds-process-step ${i < 2 ? 'ds-process-divider' : ''}`}>
          <div class="ds-process-num">{step.num}</div>
          <div class="ds-process-icon"><Fragment set:html={step.icon} /></div>
          <h3 class="ds-process-title">{step.titulo}</h3>
          <p class="ds-process-desc">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     TESTIMONIOS
══════════════════════════════════════════════════ -->
<section class="ds-section" style="background:#f7f7f7;">
  <div class="ds-container">
    <div class="ds-section-head ds-center">
      <p class="ds-eyebrow">Testimonios</p>
      <h2 class="ds-h2">Lo que dice<br/><span class="ds-accent">nuestra comunidad</span></h2>
    </div>

    <div class="ds-testi-grid">
      {testimonials.map(t => (
        <div class="ds-testi group">
          <!-- Stars -->
          <div class="ds-stars">
            {[1,2,3,4,5].map(() => (
              <svg class="ds-star" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <p class="ds-testi-quote">&ldquo;{t.quote}&rdquo;</p>
          <div class="ds-testi-author">
            <div class="ds-testi-avatar">{t.initials}</div>
            <div>
              <p class="ds-testi-name">{t.name}</p>
              <p class="ds-testi-role">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     FAQ
══════════════════════════════════════════════════ -->
{faqItems.length > 0 && (
<section class="ds-section bg-white">
  <div class="ds-container ds-faq-wrap">
    <div class="ds-faq-head">
      <p class="ds-eyebrow">Dudas frecuentes</p>
      <h2 class="ds-h2">Preguntas<br/><span class="ds-accent">frecuentes</span></h2>
    </div>
    <div class="ds-faq-list" id="faq-list">
      {faqItems.map((item, idx) => (
        <div class="ds-faq-item">
          <button class="faq-trigger ds-faq-trigger" data-index={idx} aria-expanded="false">
            <span>{item.question}</span>
            <span class="faq-icon ds-faq-icon">+</span>
          </button>
          <div class="faq-answer ds-faq-answer hidden">
            <p>{item.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<!-- ══════════════════════════════════════════════
     EQUIPO  — portrait cards
══════════════════════════════════════════════════ -->
<section class="ds-section" style="background:#f7f7f7;">
  <div class="ds-container">
    <div class="ds-section-head ds-center">
      <p class="ds-eyebrow">Equipo</p>
      <h2 class="ds-h2">Expertos en<br/><span class="ds-accent">su área</span></h2>
    </div>

    <div class="ds-team-grid">
      {teamMembers.map(m => (
        <div class="ds-team-card group">
          <div class="ds-team-photo">
            <span class="ds-team-initials">{m.initials}</span>
            <div class="ds-team-overlay"></div>
          </div>
          <div class="ds-team-info">
            <h3 class="ds-team-name">{m.nombre}</h3>
            <p class="ds-team-role">{m.cargo}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     NOTICIAS  — article cards
══════════════════════════════════════════════════ -->
{latestNews.length > 0 && (
<section class="ds-section bg-white">
  <div class="ds-deco-num ds-deco-right" aria-hidden="true">.05</div>
  <div class="ds-container">
    <div class="ds-section-head">
      <div>
        <p class="ds-eyebrow">Últimas novedades</p>
        <h2 class="ds-h2">Noticias y<br/><span class="ds-accent">artículos</span></h2>
      </div>
      <a href="/noticias" class="ds-link ds-link-lg">Ver todas &rarr;</a>
    </div>

    <div class="ds-news-grid">
      {latestNews.map(item => (
        <a href={`/noticias/${item.slug}`} class="ds-news-card group">
          <div class="ds-news-img">
            {item.coverImage
              ? <img src={item.coverImage} alt={item.title} class="group-hover:scale-105 transition-transform duration-700" loading="lazy" />
              : <div class="ds-news-placeholder">
                  <svg class="w-12 h-12 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#2d7a3a;">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                  </svg>
                </div>
            }
          </div>
          <div class="ds-news-body">
            {item.publishedAt && (
              <p class="ds-news-date">
                {new Date(item.publishedAt).toLocaleDateString('es-SV', { day:'numeric', month:'long', year:'numeric' })}
              </p>
            )}
            <h3 class="ds-news-title line-clamp-2">{item.title}</h3>
            {item.summary && <p class="ds-news-summary line-clamp-2">{item.summary}</p>}
            <span class="ds-link">Leer artículo &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<!-- ══════════════════════════════════════════════
     ALIADOS
══════════════════════════════════════════════════ -->
<section class="ds-partners">
  <div class="ds-container">
    <p class="ds-partners-label">Aliados que nos respaldan</p>
    <div class="ds-partners-logos">
      {[
        { nombre: 'CONCENTRIX', sub: 'Costa del Bálsamo' },
        { nombre: 'MINISTERIO DE GOBERNACIÓN', sub: 'Registro oficial' },
        { nombre: 'COMUNIDADES RURALES', sub: '+50 comunidades' },
      ].map(a => (
        <div class="ds-partner-item">
          <span class="ds-partner-name">{a.nombre}</span>
          <span class="ds-partner-sub">{a.sub}</span>
        </div>
      ))}
      {partners.map(p => (
        <a href={p.url || '#'} target={p.url ? '_blank' : '_self'} rel="noopener noreferrer" class="ds-partner-item">
          {p.logo
            ? <img src={p.logo} alt={p.name} class="h-8 object-contain grayscale hover:grayscale-0 transition-all duration-300" />
            : <span class="ds-partner-name">{p.name}</span>
          }
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     NEWSLETTER  — dark band with email input
══════════════════════════════════════════════════ -->
<section class="ds-newsletter">
  <div class="ds-deco-num" style="font-size:20vw; color:rgba(255,255,255,0.025);" aria-hidden="true">NEWS</div>
  <div class="ds-container ds-newsletter-inner">
    <div class="ds-newsletter-text">
      <p class="ds-eyebrow ds-eyebrow-light">Boletín informativo</p>
      <h2 class="ds-h2 text-white">
        ¿Quieres estar<br/>
        <span class="ds-accent">siempre informado</span>?
      </h2>
    </div>
    <form class="ds-newsletter-form" onsubmit="return false;">
      <div class="ds-input-wrap">
        <svg class="ds-input-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <input type="email" placeholder="Tu correo electrónico" class="ds-input" />
      </div>
      <button type="submit" class="ds-btn">Suscribirme</button>
    </form>
    <p class="ds-newsletter-note">Sin spam &middot; Solo contenido relevante sobre conservación</p>
  </div>
</section>

</Layout>

<!-- ══════════════════════════════════════════════
     DESIGN SYSTEM CSS  — inspirado en Desart
══════════════════════════════════════════════════ -->
<style>
  /* ── Variables ── */
  :root {
    --ds-accent:   #f59e0b;
    --ds-dark:     #222222;
    --ds-darker:   #111111;
    --ds-gray:     #757575;
    --ds-light:    #f7f7f7;
    --ds-border:   #e2e2e2;
    --ds-green:    #2d7a3a;
    --ds-forest:   #081509;
    --ds-shadow:   -11px -11px 35px 0px rgba(0,0,0,0.10);
    --ds-section:  9rem;
    --ds-font:     'Inter', system-ui, sans-serif;
    --ds-heading:  'Poppins', system-ui, sans-serif;
  }

  /* ── Container ── */
  .ds-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  @media(min-width:1400px){ .ds-container{ max-width:1280px; } }

  /* ── Decorative numbers (Desart .01 .02) ── */
  .ds-deco-num {
    position: absolute;
    font-family: var(--ds-heading);
    font-weight: 800;
    font-size: clamp(6rem, 18vw, 18rem);
    line-height: 1;
    color: rgba(0,0,0,0.04);
    pointer-events: none;
    user-select: none;
    z-index: 0;
    top: 50%; transform: translateY(-50%);
    right: -2rem;
  }
  .ds-deco-left  { right: auto; left: -2rem; }
  .ds-deco-right { left: auto; right: -2rem; }

  /* ── Typography ── */
  .ds-h1 {
    font-family: var(--ds-heading);
    font-weight: 800;
    font-size: clamp(2.8rem, 6.5vw, 5.5rem);
    line-height: 1.05;
    color: var(--ds-dark);
    margin-bottom: 1.5rem;
  }
  .ds-h2 {
    font-family: var(--ds-heading);
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.15;
    color: var(--ds-dark);
  }
  .ds-accent { color: var(--ds-accent); }
  .ds-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--ds-gray);
    margin-bottom: 0.75rem;
    display: block;
  }
  .ds-eyebrow-light { color: rgba(255,255,255,0.45); }
  .ds-body { font-size: 1rem; color: var(--ds-gray); line-height: 1.75; margin-bottom: 1rem; }

  /* ── Buttons ── */
  .ds-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background-color: var(--ds-accent);
    color: #fff;
    font-weight: 700; font-size: 0.78rem;
    text-transform: uppercase; letter-spacing: 0.15em;
    padding: 0.9rem 2.5rem;
    border: 2px solid var(--ds-accent);
    transition: background-color 0.3s, color 0.3s;
    cursor: pointer;
  }
  .ds-btn:hover { background-color: var(--ds-dark); border-color: var(--ds-dark); color: #fff; }
  .ds-btn-sm { padding: 0.7rem 1.8rem; font-size: 0.72rem; }
  .ds-btn-block { display: block; text-align: center; width: 100%; justify-content: center; }

  .ds-btn-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-weight: 700; font-size: 0.78rem;
    text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--ds-dark);
    border: 2px solid var(--ds-dark);
    padding: 0.9rem 2.5rem;
    transition: background-color 0.3s, color 0.3s;
  }
  .ds-btn-ghost:hover { background-color: var(--ds-dark); color: #fff; }

  .ds-btn-ghost-light {
    font-weight: 700; font-size: 0.78rem;
    text-transform: uppercase; letter-spacing: 0.15em;
    color: rgba(255,255,255,0.6);
    transition: color 0.3s;
  }
  .ds-btn-ghost-light:hover { color: var(--ds-accent); }

  /* ── Links ── */
  .ds-link {
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.18em;
    color: var(--ds-green);
    transition: color 0.3s;
  }
  .ds-link:hover { color: var(--ds-accent); }
  .ds-link-lg { font-size: 0.78rem; align-self: flex-end; }

  /* ── Sections ── */
  .ds-section { position: relative; overflow: hidden; padding: var(--ds-section) 0; }
  @media(max-width:768px){ .ds-section{ padding: 5rem 0; } }

  .ds-section-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    margin-bottom: 4rem; gap: 2rem; flex-wrap: wrap;
  }
  .ds-section-head.ds-center {
    flex-direction: column; align-items: center;
    text-align: center; justify-content: center;
  }

  /* ══════════════════════════════════════
     HERO
  ══════════════════════════════════════ */
  .ds-hero {
    position: relative; overflow: hidden;
    background-color: #fff;
    padding: 7rem 0 5rem;
    min-height: 90vh; display: flex; align-items: center;
  }
  @media(max-width:768px){ .ds-hero{ padding:6rem 0 3rem; min-height: auto; } }

  .ds-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative; z-index: 1;
  }
  @media(max-width:900px){ .ds-hero-inner{ grid-template-columns:1fr; } }

  .ds-hero-text {}
  .ds-hero-sub {
    font-size: 1.05rem; color: var(--ds-gray);
    line-height: 1.7; max-width: 480px; margin-bottom: 2.5rem;
  }
  .ds-hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; }

  /* Photo collage */
  .ds-hero-collage {
    position: relative;
    height: 560px;
  }
  @media(max-width:900px){ .ds-hero-collage{ height:320px; } }

  .ds-collage-main {
    position: absolute;
    top: 0; right: 0;
    width: 75%; height: 85%;
    overflow: hidden;
  }
  .ds-collage-main img { width:100%; height:100%; object-fit:cover; }

  .ds-collage-over {
    position: absolute;
    bottom: 0; left: 0;
    width: 55%; height: 60%;
    overflow: hidden;
    border: 5px solid #fff;
    box-shadow: var(--ds-shadow);
  }
  .ds-collage-over img { width:100%; height:100%; object-fit:cover; filter: grayscale(20%); }

  /* ══════════════════════════════════════
     STATS BAR
  ══════════════════════════════════════ */
  .ds-stats-bar {
    background-color: var(--ds-dark);
    padding: 3.5rem 0;
  }
  .ds-stats-grid {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 0;
  }
  @media(max-width:600px){ .ds-stats-grid{ grid-template-columns:repeat(2,1fr); } }

  .ds-stat {
    padding: 1rem 2rem;
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.1);
  }
  .ds-stat:last-child { border-right: none; }
  .ds-stat-num {
    font-family: var(--ds-heading);
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--ds-accent);
    line-height: 1;
  }
  .ds-stat-suffix { color: var(--ds-accent); }
  .ds-stat-label {
    font-size: 0.7rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.2em;
    color: rgba(255,255,255,0.4);
    margin-top: 0.4rem;
  }

  /* ══════════════════════════════════════
     ABOUT
  ══════════════════════════════════════ */
  .ds-about { background-color: #fff; }
  .ds-about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    position: relative; z-index:1;
  }
  @media(max-width:900px){ .ds-about-inner{ grid-template-columns:1fr; } }

  /* Overlapping photos */
  .ds-about-collage { position: relative; height: 480px; }
  @media(max-width:900px){ .ds-about-collage{ height:280px; } }

  .ds-about-img-back {
    position: absolute;
    top: 0; right: 0;
    width: 72%; height: 80%;
    overflow: hidden;
  }
  .ds-about-img-back img { width:100%; height:100%; object-fit:cover; }

  .ds-about-img-front {
    position: absolute;
    bottom: 0; left: 0;
    width: 58%; height: 65%;
    overflow: hidden;
    border: 6px solid #fff;
    box-shadow: var(--ds-shadow);
  }
  .ds-about-img-front img { width:100%; height:100%; object-fit:cover; }

  /* ══════════════════════════════════════
     SERVICES (minimal — no card bg)
  ══════════════════════════════════════ */
  .ds-services-grid {
    display: grid;
    grid-template-columns: repeat(4,1fr);
    gap: 0;
    border-top: 1px solid var(--ds-border);
  }
  @media(max-width:900px){ .ds-services-grid{ grid-template-columns:repeat(2,1fr); } }
  @media(max-width:500px){ .ds-services-grid{ grid-template-columns:1fr; } }

  .ds-service {
    padding: 3rem 2.5rem;
    border-right: 1px solid var(--ds-border);
    border-bottom: 1px solid var(--ds-border);
    transition: box-shadow 0.3s;
    position: relative;
  }
  .ds-service:last-child { border-right: none; }
  .ds-service:hover { box-shadow: var(--ds-shadow); }

  /* Accent top border on hover */
  .ds-service::before {
    content: '';
    position: absolute; top: -1px; left: 0; right: 0;
    height: 3px; background-color: var(--ds-accent);
    transform: scaleX(0); transition: transform 0.3s;
  }
  .ds-service:hover::before { transform: scaleX(1); }

  .ds-service-icon {
    width: 3rem; height: 3rem;
    color: var(--ds-accent);
    margin-bottom: 1.5rem;
  }
  .ds-service-icon svg { width:100%; height:100%; }
  .ds-service-title {
    font-family: var(--ds-heading);
    font-weight: 700; font-size: 1.1rem;
    color: var(--ds-dark); margin-bottom: 0.75rem;
  }
  .ds-service-desc { font-size: 0.88rem; color: var(--ds-gray); line-height: 1.65; margin-bottom: 1.5rem; }

  /* ══════════════════════════════════════
     CAUSAS / PORTFOLIO
  ══════════════════════════════════════ */
  .ds-causes-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 2rem;
  }
  @media(max-width:900px){ .ds-causes-grid{ grid-template-columns:repeat(2,1fr); } }
  @media(max-width:580px){ .ds-causes-grid{ grid-template-columns:1fr; } }

  .ds-cause {
    border: 1px solid var(--ds-border);
    overflow: hidden;
    transition: box-shadow 0.3s;
  }
  .ds-cause:hover { box-shadow: var(--ds-shadow); }

  .ds-cause-img {
    position: relative; overflow: hidden; height: 210px;
  }
  .ds-cause-img img { width:100%; height:100%; object-fit:cover; }
  .ds-cause-tag {
    position: absolute; bottom: 1rem; left: 1rem;
    background: var(--ds-accent); color: #fff;
    font-size: 0.65rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 0.3rem 0.8rem;
  }
  .ds-cause-body { padding: 1.5rem; }
  .ds-cause-title {
    font-family: var(--ds-heading);
    font-weight: 700; font-size: 1rem;
    color: var(--ds-dark); margin-bottom: 0.5rem;
  }
  .ds-cause-desc { font-size: 0.85rem; color: var(--ds-gray); line-height: 1.6; margin-bottom: 1.25rem; }

  .ds-progress-wrap { margin-bottom: 1.25rem; }
  .ds-progress-bar { height: 3px; background: var(--ds-border); margin-bottom: 0.5rem; }
  .ds-progress-fill { height: 3px; background: var(--ds-accent); transition: width 1s; }
  .ds-progress-meta {
    display: flex; justify-content: space-between;
    font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.1em;
  }
  .ds-progress-pct { color: var(--ds-green); }
  .ds-progress-goal { color: var(--ds-gray); }

  /* ══════════════════════════════════════
     CTA DARK BAND  (Desart pattern)
  ══════════════════════════════════════ */
  .ds-cta-band {
    position: relative;
    background-color: var(--ds-forest);
    overflow: hidden;
    padding: var(--ds-section) 0;
  }
  @media(max-width:768px){ .ds-cta-band{ padding:5rem 0; } }

  /* Photo bleeding right */
  .ds-cta-img {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 38%;
    overflow: hidden;
  }
  .ds-cta-img img {
    width: 100%; height: 100%; object-fit: cover;
    filter: grayscale(30%);
    mix-blend-mode: luminosity;
    opacity: 0.5;
  }
  @media(max-width:900px){ .ds-cta-img{ width:100%; opacity:0.15; } }

  .ds-cta-inner { position: relative; z-index: 1; }
  .ds-cta-content { max-width: 560px; }

  .ds-cta-sub {
    font-size: 1rem; color: rgba(189,231,195,0.7);
    line-height: 1.7; margin: 1.25rem 0 0.75rem;
  }
  .ds-cta-legal {
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--ds-accent); margin-bottom: 2rem;
    display: flex; align-items: center; gap: 0.4rem;
  }

  .ds-amounts { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2rem; }
  .ds-amount-btn {
    font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    padding: 0.6rem 1.2rem;
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.2);
    transition: background-color 0.3s, border-color 0.3s, color 0.3s;
  }
  .ds-amount-btn:hover,
  .ds-amount-btn.ds-active {
    background-color: var(--ds-accent);
    border-color: var(--ds-accent);
    color: #fff;
  }

  .ds-cta-btns { display: flex; flex-wrap: wrap; gap: 1rem; }

  /* ══════════════════════════════════════
     GALLERY
  ══════════════════════════════════════ */
  .ds-gallery-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 0.75rem;
  }
  @media(max-width:600px){ .ds-gallery-grid{ grid-template-columns:repeat(2,1fr); } }

  .ds-gallery-item {
    position: relative; overflow: hidden; aspect-ratio: 4/3; cursor: pointer;
  }
  .ds-gallery-item img { width:100%; height:100%; object-fit:cover; }
  .ds-gallery-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(8,21,9,0.8) 0%, transparent 60%);
    display: flex; align-items: flex-end;
    opacity: 0; transition: opacity 0.3s;
  }
  .ds-gallery-item:hover .ds-gallery-overlay { opacity: 1; }
  .ds-gallery-title {
    color: #fff; font-size: 0.85rem; font-weight: 600;
    padding: 1.25rem; line-height: 1.3;
  }

  /* ══════════════════════════════════════
     PROCESS  — 3 step horizontal
  ══════════════════════════════════════ */
  .ds-process-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 0;
    border: 1px solid var(--ds-border);
  }
  @media(max-width:700px){ .ds-process-grid{ grid-template-columns:1fr; } }

  .ds-process-step {
    padding: 3.5rem 3rem;
    position: relative;
    transition: background-color 0.3s;
  }
  .ds-process-step:hover { background-color: var(--ds-light); }
  .ds-process-divider { border-right: 1px solid var(--ds-border); }
  @media(max-width:700px){ .ds-process-divider{ border-right:none; border-bottom:1px solid var(--ds-border); } }

  .ds-process-num {
    position: absolute; top: 2rem; right: 2rem;
    font-family: var(--ds-heading); font-weight: 800;
    font-size: 5rem; line-height: 1;
    color: #f0f0f0; user-select: none;
    transition: color 0.3s;
  }
  .ds-process-step:hover .ds-process-num { color: #fef3c7; }

  .ds-process-icon {
    width: 2.5rem; height: 2.5rem;
    color: var(--ds-accent);
    margin-bottom: 1.25rem;
  }
  .ds-process-icon svg { width:100%; height:100%; }
  .ds-process-title {
    font-family: var(--ds-heading);
    font-weight: 700; font-size: 1.15rem;
    color: var(--ds-dark); margin-bottom: 0.75rem;
  }
  .ds-process-desc { font-size: 0.88rem; color: var(--ds-gray); line-height: 1.65; }

  /* ══════════════════════════════════════
     TESTIMONIALS
  ══════════════════════════════════════ */
  .ds-testi-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 2rem;
  }
  @media(max-width:800px){ .ds-testi-grid{ grid-template-columns:1fr; } }

  .ds-testi {
    background: #fff;
    border: 1px solid var(--ds-border);
    padding: 2.5rem;
    transition: box-shadow 0.3s, border-color 0.3s;
    display: flex; flex-direction: column;
  }
  .ds-testi:hover { box-shadow: var(--ds-shadow); border-color: var(--ds-accent); }

  .ds-stars { display: flex; gap: 0.25rem; margin-bottom: 1.25rem; }
  .ds-star { width: 1rem; height: 1rem; fill: var(--ds-accent); }

  .ds-testi-quote {
    font-size: 0.9rem; color: var(--ds-gray);
    line-height: 1.75; flex: 1; margin-bottom: 1.5rem;
    font-style: italic;
  }
  .ds-testi-author { display: flex; align-items: center; gap: 0.875rem; border-top: 1px solid var(--ds-border); padding-top: 1.25rem; }
  .ds-testi-avatar {
    width: 2.75rem; height: 2.75rem; flex-shrink: 0;
    background-color: var(--ds-dark);
    color: #fff; font-weight: 700; font-size: 0.8rem;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--ds-heading);
  }
  .ds-testi-name { font-weight: 700; font-size: 0.85rem; color: var(--ds-dark); }
  .ds-testi-role { font-size: 0.72rem; color: var(--ds-gray); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.1rem; }

  /* ══════════════════════════════════════
     FAQ
  ══════════════════════════════════════ */
  .ds-faq-wrap {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 5rem;
    align-items: start;
