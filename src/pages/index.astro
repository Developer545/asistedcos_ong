---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcos-admin.vercel.app';

interface ContenidoItem {
  section: string;
  key: string;
  value: string;
}

const defaultStats = {
  anos: '+27',
  comunidades: '+50',
  arboles: '+10K',
  donaciones: '100%',
};

let stats = { ...defaultStats };

try {
  const res = await fetch(`${ADMIN_URL}/api/public/contenido`);
  if (res.ok) {
    const json = await res.json();
    const contenido: ContenidoItem[] = json.data ?? [];
    const statsItems = contenido.filter((item: ContenidoItem) => item.section === 'stats');
    for (const item of statsItems) {
      if (item.key === 'anos') stats.anos = item.value;
      if (item.key === 'comunidades') stats.comunidades = item.value;
      if (item.key === 'arboles') stats.arboles = item.value;
      if (item.key === 'donaciones') stats.donaciones = item.value;
    }
  }
} catch {
  // Silently fall back to default stats
}
---

<Layout
  title="Fundación ASISTEDCOS"
  description="Recuperando ecosistemas para la biodiversidad y la humanidad en El Salvador desde 1997. Únete a nuestra misión de reforestación y conservación ambiental."
>

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden bg-verde-900">
    <!-- Imagen de fondo con overlay -->
    <div class="absolute inset-0">
      <img
        src="/images/reforestacion-aerea.jpg"
        alt="Reforestación costera en El Salvador"
        class="w-full h-full object-cover opacity-40"
        fetchpriority="high"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-verde-900/80 to-verde-800/50"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="max-w-2xl">
        <span class="inline-block bg-verde-600/80 text-verde-100 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-6">
          Desde 1997 · El Salvador
        </span>
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Recuperando ecosistemas<br />
          <span class="text-verde-300">para la vida</span>
        </h1>
        <p class="text-verde-100 text-lg sm:text-xl leading-relaxed mb-8 max-w-xl">
          Trabajamos con comunidades rurales y urbanas de El Salvador para restaurar bosques, proteger manglares y construir un futuro sostenible.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/donar"
            class="inline-flex items-center justify-center gap-2 bg-verde-500 hover:bg-verde-400 text-white font-bold px-8 py-4 rounded-full text-base transition-colors shadow-lg"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
            Apoya nuestra misión
          </a>
          <a
            href="/proyectos"
            class="inline-flex items-center justify-center gap-2 border-2 border-verde-300 text-verde-100 hover:bg-verde-300 hover:text-verde-900 font-semibold px-8 py-4 rounded-full text-base transition-colors"
          >
            Ver proyectos
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-verde-300 animate-bounce">
      <span class="text-xs tracking-widest uppercase">Descubrir</span>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- ===== NÚMEROS DE IMPACTO ===== -->
  <section class="bg-white py-16 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { valor: stats.anos, label: 'años de trabajo', color: 'text-verde-700' },
          { valor: stats.comunidades, label: 'comunidades atendidas', color: 'text-verde-700' },
          { valor: stats.arboles, label: 'árboles plantados', color: 'text-verde-700' },
          { valor: stats.donaciones, label: 'sin fines de lucro', color: 'text-verde-700' },
        ].map(item => (
          <div class="flex flex-col items-center">
            <span class={`font-heading text-4xl md:text-5xl font-extrabold ${item.color}`}>{item.valor}</span>
            <span class="text-sm text-gray-500 mt-1 font-medium">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== MISIÓN ===== -->
  <section class="py-20 bg-verde-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-verde-600 font-semibold text-sm uppercase tracking-wider">Nuestra misión</span>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-verde-900 mt-2 mb-6 leading-tight">
            Ecosistemas saludables,<br />comunidades prósperas
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            ASISTEDCOS nació en 1997 para atender las secuelas ambientales y sociales de la guerra civil en El Salvador. A través de asistencia técnica especializada, promovemos la autogestión comunitaria y la restauración ecológica.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Trabajamos con comunidades rurales, semi-rurales y urbanas, facilitando la cooperación entre el sector público, privado y organismos internacionales para lograr un impacto duradero.
          </p>
          <a href="/nosotros" class="inline-flex items-center gap-2 text-verde-700 font-semibold hover:text-verde-900 transition-colors group">
            Conoce nuestra historia
            <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="relative">
          <img
            src="/images/voluntaria-plantando.jpg"
            alt="Voluntaria de ASISTEDCOS plantando árboles en El Salvador"
            class="rounded-2xl shadow-xl w-full object-cover aspect-[4/3]"
          />
          <div class="absolute -bottom-4 -left-4 bg-verde-600 text-white rounded-xl px-5 py-3 shadow-lg">
            <p class="font-heading font-bold text-lg">1997</p>
            <p class="text-xs text-verde-200">Fundada en El Salvador</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROYECTOS DESTACADOS ===== -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-verde-600 font-semibold text-sm uppercase tracking-wider">Lo que hacemos</span>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-verde-900 mt-2">Proyectos en acción</h2>
        <p class="text-gray-500 mt-3 max-w-xl mx-auto">Cada proyecto transforma vidas y restaura el equilibrio natural de nuestros ecosistemas.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            img: '/images/area-conservacion.jpg',
            alt: 'Área de conservación Costa del Bálsamo con señalización de ASISTEDCOS',
            titulo: 'Conservación Costa del Bálsamo',
            desc: 'Protección y restauración del manglar en Playa San Diego, La Libertad. Alianza con Concentrix para la preservación de este ecosistema vital.',
            tag: 'Manglar',
          },
          {
            img: '/images/distribucion-plantas.jpg',
            alt: 'Distribución de plantas a comunidades salvadoreñas',
            titulo: 'Distribución de Plántulas',
            desc: 'Entregamos miles de plántulas nativas a familias campesinas para reforestar sus terrenos y mejorar su economía familiar mediante la restauración ecológica.',
            tag: 'Reforestación',
          },
          {
            img: '/images/monitoreo-rio.jpg',
            alt: 'Monitoreo de cuencas hidrográficas en El Salvador',
            titulo: 'Monitoreo de Cuencas',
            desc: 'Vigilancia continua de ríos y cuerpos de agua para asegurar la salud hídrica de las comunidades y los ecosistemas acuáticos de El Salvador.',
            tag: 'Agua',
          },
        ].map(proyecto => (
          <article class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-gray-100">
            <div class="overflow-hidden aspect-[16/10]">
              <img
                src={proyecto.img}
                alt={proyecto.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <span class="inline-block bg-verde-100 text-verde-700 text-xs font-semibold px-3 py-1 rounded-full mb-3">
                {proyecto.tag}
              </span>
              <h3 class="font-heading font-bold text-lg text-verde-900 mb-2">{proyecto.titulo}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{proyecto.desc}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href="/proyectos"
          class="inline-flex items-center gap-2 border-2 border-verde-600 text-verde-700 hover:bg-verde-600 hover:text-white font-semibold px-8 py-3 rounded-full transition-colors"
        >
          Ver todos los proyectos
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CTA DONACIÓN ===== -->
  <section class="py-20 bg-gradient-to-br from-verde-700 to-verde-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/images/evento-playa.jpg" alt="" class="w-full h-full object-cover" aria-hidden="true" />
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-verde-300 mx-auto mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
      <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-white mb-4">
        Tu donación restaura ecosistemas
      </h2>
      <p class="text-verde-200 text-lg mb-4 max-w-xl mx-auto">
        Cada aporte nos permite plantar más árboles, proteger más manglares y acompañar más comunidades en El Salvador.
      </p>
      <p class="text-verde-300 text-sm mb-10 font-medium">
        ★ Las donaciones son deducibles de impuestos en El Salvador (Art. 32, Ley de Renta)
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/donar"
          class="inline-flex items-center justify-center gap-2 bg-white text-verde-800 hover:bg-verde-50 font-bold px-10 py-4 rounded-full text-base transition-colors shadow-lg"
        >
          ♥ Donar ahora
        </a>
        <a
          href="/contacto"
          class="inline-flex items-center justify-center gap-2 border-2 border-verde-300 text-verde-100 hover:bg-verde-300 hover:text-verde-900 font-semibold px-8 py-4 rounded-full text-base transition-colors"
        >
          Ser voluntario
        </a>
      </div>
    </div>
  </section>

  <!-- ===== GALERÍA / TESTIMONIO VISUAL ===== -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-verde-900">El campo, nuestra oficina</h2>
        <p class="text-gray-500 mt-2">Imágenes reales de nuestro trabajo comunitario</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {[
          { src: '/images/vivero-comunidad.jpg', alt: 'Comunidad trabajando en vivero de plantas' },
          { src: '/images/transporte-plantas.jpg', alt: 'Transporte de plantas en La Libertad, El Salvador' },
          { src: '/images/evento-playa.jpg', alt: 'Evento de plantación en playa con bandera salvadoreña' },
          { src: '/images/reforestacion-aerea.jpg', alt: 'Vista aérea de zona reforestada junto al mar' },
        ].map(img => (
          <div class="overflow-hidden rounded-xl aspect-square">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
