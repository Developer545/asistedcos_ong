---
export const prerender = false;
import Layout from '../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcosadmin.vercel.app';

type NewsItem = { id: string; title: string; slug: string; summary?: string; coverImage?: string; publishedAt?: string };
type CauseItem = { id: string; titulo: string; descripcion?: string; tag?: string; coverImage?: string; meta: number; recaudado: number };
type FaqItem = { id: string; question: string; answer: string };
type GalleryItem = { id: string; title?: string; url: string; category?: string };
type PartnerItem = { id: string; name: string; logo?: string; url?: string };

let latestNews: NewsItem[] = [];
let causeCards: CauseItem[] = [];
let faqItems: FaqItem[] = [];
let galleryItems: GalleryItem[] = [];
let partners: PartnerItem[] = [];

await Promise.allSettled([
  fetch(`${ADMIN_URL}/api/public/noticias?limit=3`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) latestNews = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/causas`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) causeCards = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/faq`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) faqItems = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/galeria`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) galleryItems = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/aliados`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) partners = d.data ?? []; }),
]);

// Fallback cause cards if API is unavailable
if (causeCards.length === 0) {
  causeCards = [
    { id: '1', titulo: 'Conservación Costa del Bálsamo', descripcion: 'Protección y restauración del manglar en Playa San Diego, La Libertad.', tag: 'Manglar', meta: 15000, recaudado: 8550 },
    { id: '2', titulo: 'Distribución de Plántulas Nativas', descripcion: 'Entregamos plántulas nativas a familias rurales para reforestar sus terrenos.', tag: 'Reforestación', meta: 8000, recaudado: 6560 },
    { id: '3', titulo: 'Monitoreo de Cuencas Hidrográficas', descripcion: 'Vigilancia continua de ríos y cuerpos de agua para asegurar la salud hídrica.', tag: 'Agua', meta: 12000, recaudado: 5160 },
  ];
}

const testimonials = [
  {
    quote: 'Gracias a ASISTEDCOS aprendimos a proteger los manglares que nos dan vida. El apoyo técnico fue fundamental para nuestra comunidad.',
    name: 'María López',
    role: 'Pescadora, La Libertad',
    initials: 'ML',
    color: 'bg-verde-700',
  },
  {
    quote: 'Como empresa, nuestra alianza con ASISTEDCOS nos permitió recuperar el área de conservación en la Costa del Bálsamo. Un impacto real y medible.',
    name: 'Representante Concentrix',
    role: 'Aliado Estratégico',
    initials: 'CO',
    color: 'bg-amber-600',
  },
  {
    quote: 'Los viveros comunitarios cambiaron nuestra forma de ver el territorio. Hoy somos guardianes del bosque.',
    name: 'Juan García',
    role: 'Comunidad Rural, La Libertad',
    initials: 'JG',
    color: 'bg-verde-500',
  },
];

const teamMembers = [
  {
    initials: 'BJ',
    nombre: 'Lic. Blanca Estela Juárez',
    cargo: 'Directora Ejecutiva',
    color: 'bg-verde-700',
  },
  {
    initials: 'ET',
    nombre: 'Equipo Técnico',
    cargo: 'Especialistas en Gestión Ambiental',
    color: 'bg-amber-600',
  },
  {
    initials: '+20',
    nombre: 'Voluntarios',
    cargo: 'Colaboradores activos en campo',
    color: 'bg-verde-500',
  },
];
---

<Layout
  title="Fundación ASISTEDCOS"
  description="Recuperando ecosistemas para la biodiversidad y la humanidad en El Salvador desde 1997. Únete a nuestra misión de reforestación y conservación ambiental."
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="height: 700px; max-height: 90vh;">
    <div class="absolute inset-0">
      <img src="/images/reforestacion-aerea.jpg" alt="Reforestación costera en El Salvador"
        class="w-full h-full object-cover" fetchpriority="high" />
    </div>
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(8,21,9,0.93) 0%, rgba(17,43,20,0.80) 55%, rgba(26,71,33,0.40) 100%);"></div>

    <div class="relative h-full flex items-center">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="max-w-2xl">
          <div class="animate-fade-up">
            <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-sm mb-6"
              style="background-color: rgba(245,158,11,0.2); border: 1px solid rgba(251,191,36,0.4); color: #fcd34d;">
              <span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>
              Desde 1997 · El Salvador
            </span>
          </div>
          <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6 animate-fade-up-delay">
            Recuperando<br/>
            <span class="text-amber-400">ecosistemas</span><br/>
            para la vida
          </h1>
          <p class="text-lg sm:text-xl leading-relaxed mb-10 max-w-xl animate-fade-up-delay-2" style="color: rgba(255,255,255,0.82);">
            Trabajamos con comunidades rurales de El Salvador para restaurar bosques, proteger manglares y construir un futuro sostenible.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 animate-fade-up-delay-2">
            <a href="/donar"
              class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-white font-bold px-8 py-4 rounded-sm text-base transition-all duration-200 shadow-xl hover:-translate-y-1">
              ♥ Apoya nuestra misión
            </a>
            <a href="/proyectos"
              class="inline-flex items-center justify-center gap-2 font-semibold px-8 py-4 rounded-sm text-base transition-all duration-200 text-white"
              style="border: 2px solid rgba(255,255,255,0.4);">
              Ver proyectos
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2" style="color: rgba(255,255,255,0.5);">
      <span class="text-xs tracking-widest uppercase font-medium">Descubrir</span>
      <div class="w-px h-10 animate-bounce" style="background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);"></div>
    </div>
  </section>

  <!-- ===== WAYS TO HELP ===== -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Súmate</span>
        <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-gray-900 mt-2">¿Cómo puedes ayudar?</h2>
        <p class="text-gray-500 mt-3 max-w-xl mx-auto">Hay muchas formas de contribuir a la recuperación de nuestros ecosistemas.</p>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6">
        {[
          {
            icon: `<svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
            titulo: 'Donar',
            desc: 'Tu aporte financia proyectos de reforestación y protección de manglares en El Salvador.',
            href: '/donar',
            cta: 'Donar ahora',
          },
          {
            icon: `<svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
            titulo: 'Voluntariar',
            desc: 'Únete a jornadas de trabajo comunitario, plantación y monitoreo de ecosistemas.',
            href: '/contacto',
            cta: 'Ser voluntario',
          },
          {
            icon: `<svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
            titulo: 'Aliarte',
            desc: 'Las empresas que nos apoyan generan impacto ambiental real y medible en conservación.',
            href: '/contacto',
            cta: 'Ser aliado',
          },
          {
            icon: `<svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>`,
            titulo: 'Difundir',
            desc: 'Comparte nuestra misión en redes sociales y ayúdanos a llegar a más personas.',
            href: 'https://www.facebook.com/FundacionAsistedcos',
            cta: 'Compartir',
          },
        ].map(item => (
          <div class="group flex flex-col items-center text-center p-8 rounded-lg border border-gray-100 hover:border-amber-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 bg-white">
            <div class="w-20 h-20 rounded-full flex items-center justify-center mb-5 text-white transition-colors duration-300"
              style="background-color: #2d7a3a;">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="font-heading font-bold text-xl text-gray-900 mb-3">{item.titulo}</h3>
            <p class="text-gray-500 text-sm leading-relaxed flex-1 mb-5">{item.desc}</p>
            <a href={item.href}
              class="text-sm font-bold text-verde-700 border-b-2 border-amber-400 pb-0.5 hover:text-amber-500 transition-colors">
              {item.cta} →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ABOUT + STATS ===== -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <!-- Image side -->
        <div class="relative">
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-amber-100 rounded-lg -z-10"></div>
          <div class="absolute -bottom-4 -right-4 w-32 h-32 rounded-lg -z-10" style="background-color: #ddf3e0;"></div>
          <img src="/images/voluntaria-plantando.jpg"
            alt="Voluntaria de ASISTEDCOS plantando árboles"
            class="rounded-lg shadow-2xl w-full object-cover aspect-[4/3]" />
          <div class="absolute -bottom-5 -left-5 bg-white rounded-lg px-5 py-4 shadow-xl border border-gray-100">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-lg flex items-center justify-center text-white font-bold text-lg" style="background-color: #2d7a3a;">97</div>
              <div>
                <p class="font-bold text-sm" style="color: #112b14;">Fundada en 1997</p>
                <p class="text-xs text-gray-500">+27 años transformando El Salvador</p>
              </div>
            </div>
          </div>
        </div>
        <!-- Text + counters -->
        <div>
          <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Nuestra misión</span>
          <h2 class="font-heading text-3xl md:text-4xl font-extrabold mt-3 mb-6 leading-tight" style="color: #112b14;">
            Ecosistemas saludables,<br/>comunidades prósperas
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            ASISTEDCOS nació en 1997 para atender las secuelas ambientales y sociales de la posguerra en El Salvador. A través de asistencia técnica especializada, promovemos la autogestión comunitaria y la restauración ecológica.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Trabajamos con comunidades rurales, semi-rurales y urbanas, facilitando la cooperación entre el sector público, privado y organismos internacionales.
          </p>
          <!-- Counters 2x2 grid -->
          <div class="grid grid-cols-2 gap-4 mb-8" id="counters-section">
            {[
              { count: 27,    suffix: '',    label: 'Años de trabajo' },
              { count: 50,    suffix: '+',   label: 'Comunidades' },
              { count: 10000, suffix: '+',   label: 'Árboles plantados' },
              { count: 6,     suffix: '',    label: 'Proyectos activos' },
            ].map(item => (
              <div class="bg-white rounded-lg p-5 shadow-sm border border-gray-100 text-center">
                <div class="font-heading text-3xl font-extrabold text-amber-500 flex items-baseline justify-center gap-0.5">
                  <span data-count={item.count} class="counter-num">0</span>
                  <span>{item.suffix}</span>
                </div>
                <p class="text-xs text-gray-500 font-medium mt-1">{item.label}</p>
              </div>
            ))}
          </div>
          <a href="/nosotros"
            class="inline-flex items-center gap-2 text-white font-semibold px-6 py-3 rounded-sm transition-colors"
            style="background-color: #2d7a3a;">
            Conoce nuestra historia
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CAUSE CARDS WITH PROGRESS BARS ===== -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
        <div>
          <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Lo que hacemos</span>
          <h2 class="font-heading text-3xl md:text-4xl font-extrabold mt-2" style="color: #112b14;">Causas que impulsamos</h2>
          <p class="text-gray-500 mt-2 max-w-lg">Proyectos activos con metas de financiamiento. Tu aporte hace la diferencia.</p>
        </div>
        <a href="/proyectos" class="inline-flex items-center gap-2 font-semibold text-sm group flex-shrink-0 transition-colors" style="color: #245f2e;">
          Ver todos los proyectos
          <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {causeCards.map(cause => {
          const meta = Number(cause.meta);
          const rec = Number(cause.recaudado);
          const pct = meta > 0 ? Math.round((rec / meta) * 100) : 0;
          return (
            <div class="bg-white rounded-xl shadow-md overflow-hidden flex flex-col group hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
              {/* Image */}
              <div class="relative overflow-hidden" style="height: 210px;">
                <img
                  src={cause.coverImage || `/images/reforestacion-aerea.jpg`}
                  alt={cause.titulo}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                {cause.tag && (
                  <span class="absolute top-3 left-3 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full text-white"
                    style="background-color: #16a34a;">
                    {cause.tag}
                  </span>
                )}
              </div>
              {/* Content */}
              <div class="p-5 flex flex-col flex-1">
                <h3 class="font-heading font-bold text-lg text-gray-900 mb-2 leading-snug">{cause.titulo}</h3>
                <p class="text-gray-500 text-sm leading-relaxed flex-1 mb-4">{cause.descripcion}</p>
                {/* Progress bar */}
                <div class="mb-3">
                  <div class="flex justify-between text-xs font-semibold mb-1.5">
                    <span class="text-gray-600">Meta: <span class="text-gray-900">${meta.toLocaleString()}</span></span>
                    <span style="color: #16a34a;">{pct}%</span>
                  </div>
                  <div class="w-full h-2 rounded-full" style="background-color: rgba(22,163,74,0.15);">
                    <div class="h-2 rounded-full transition-all duration-700" style={`width: ${Math.min(pct, 100)}%; background-color: #16a34a;`}></div>
                  </div>
                </div>
                {/* Goal / Raised / To Go */}
                <div class="grid grid-cols-3 gap-2 text-center border-t pt-3" style="border-color: #f1f5f9;">
                  <div>
                    <div class="text-xs text-gray-400 mb-0.5">Meta</div>
                    <div class="text-sm font-bold text-gray-800">${(meta/1000).toFixed(0)}k</div>
                  </div>
                  <div>
                    <div class="text-xs text-gray-400 mb-0.5">Recaudado</div>
                    <div class="text-sm font-bold" style="color: #16a34a;">${rec.toLocaleString()}</div>
                  </div>
                  <div>
                    <div class="text-xs text-gray-400 mb-0.5">Faltante</div>
                    <div class="text-sm font-bold text-amber-600">${Math.max(0, meta - rec).toLocaleString()}</div>
                  </div>
                </div>
                <a href="/donar"
                  class="mt-4 block text-center py-2.5 rounded-lg text-sm font-bold text-white transition-colors"
                  style="background-color: #16a34a;">
                  Donar a esta causa
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ===== GALERÍA ===== -->
  {galleryItems.length > 0 && (
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Nuestro trabajo</span>
          <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-gray-900 mt-2">Galería de impacto</h2>
          <p class="text-gray-500 mt-3 max-w-xl mx-auto">Imágenes de nuestros proyectos en el campo, documentando el cambio real.</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {galleryItems.slice(0, 6).map(item => (
            <div class="relative overflow-hidden rounded-xl group" style="aspect-ratio: 4/3;">
              <img
                src={item.url}
                alt={item.title || 'Galería ASISTEDCOS'}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
              {item.title && (
                <div class="absolute inset-0 flex items-end opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                  style="background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);">
                  <p class="text-white text-sm font-medium p-4">{item.title}</p>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ===== HOW WE WORK ===== -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Nuestro proceso</span>
        <h2 class="font-heading text-3xl md:text-4xl font-extrabold mt-2" style="color: #112b14;">¿Cómo trabajamos?</h2>
        <p class="text-gray-500 mt-3 max-w-xl mx-auto">Un proceso metodológico que garantiza impacto real y sostenible en cada comunidad.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            num: '01',
            titulo: 'Identificamos',
            desc: 'Realizamos diagnósticos ambientales y sociales para entender las necesidades específicas de cada comunidad y ecosistema.',
            iconColor: '#2d7a3a',
            icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>`,
          },
          {
            num: '02',
            titulo: 'Actuamos',
            desc: 'Implementamos proyectos de reforestación, conservación y desarrollo comunitario con participación local activa.',
            iconColor: '#f59e0b',
            icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
          },
          {
            num: '03',
            titulo: 'Medimos',
            desc: 'Monitoreamos y evaluamos el impacto de cada intervención para garantizar resultados tangibles y sostenibles.',
            iconColor: '#245f2e',
            icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
          },
        ].map(step => (
          <div class="relative bg-white rounded-lg p-8 shadow-sm hover:shadow-lg transition-shadow duration-300 border border-gray-100">
