---
export const prerender = false;
import Layout from '../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcosadmin.vercel.app';

type NewsItem = { id: string; title: string; slug: string; summary?: string; coverImage?: string; publishedAt?: string };
type CauseItem = { id: string; titulo: string; descripcion?: string; tag?: string; coverImage?: string; meta: number; recaudado: number };
type FaqItem = { id: string; question: string; answer: string };
type GalleryItem = { id: string; title?: string; url: string; category?: string };
type PartnerItem = { id: string; name: string; logo?: string; url?: string };

let latestNews: NewsItem[] = [];
let causeCards: CauseItem[] = [];
let faqItems: FaqItem[] = [];
let galleryItems: GalleryItem[] = [];
let partners: PartnerItem[] = [];
let siteContent: Record<string, string> = {};

await Promise.allSettled([
  fetch(`${ADMIN_URL}/api/public/noticias?limit=3`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) latestNews = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/causas`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) causeCards = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/faq`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) faqItems = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/galeria`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) galleryItems = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/aliados`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) partners = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/contenido`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null)
    .then(d => {
      if (d?.data) {
        d.data.forEach((item: { section: string; key: string; value: string }) => {
          siteContent[`${item.section}__${item.key}`] = item.value;
        });
      }
    }),
]);

const testimonials = [
  {
    quote: 'Gracias a ASISTEDCOS aprendimos a proteger los manglares que nos dan vida. El apoyo técnico fue fundamental para nuestra comunidad.',
    name: 'María López',
    role: 'Pescadora, La Libertad',
    initials: 'ML',
    gradFrom: '#245f2e',
    gradTo: '#112b14',
  },
  {
    quote: 'Como empresa, nuestra alianza con ASISTEDCOS nos permitió recuperar el área de conservación en la Costa del Bálsamo. Un impacto real y medible.',
    name: 'Representante Concentrix',
    role: 'Aliado Estratégico',
    initials: 'CO',
    gradFrom: '#d97706',
    gradTo: '#92400e',
  },
  {
    quote: 'Los viveros comunitarios cambiaron nuestra forma de ver el territorio. Hoy somos guardianes del bosque.',
    name: 'Juan García',
    role: 'Comunidad Rural, La Libertad',
    initials: 'JG',
    gradFrom: '#389e4a',
    gradTo: '#245f2e',
  },
];

const teamMembers = [
  { initials: 'BJ', nombre: 'Lic. Blanca Estela Juárez', cargo: 'Directora Ejecutiva', gradFrom: '#245f2e', gradTo: '#112b14' },
  { initials: 'ET', nombre: 'Equipo Técnico', cargo: 'Especialistas en Gestión Ambiental', gradFrom: '#d97706', gradTo: '#92400e' },
  { initials: '+20', nombre: 'Voluntarios', cargo: 'Colaboradores activos en campo', gradFrom: '#389e4a', gradTo: '#245f2e' },
];
---

<Layout
  title="Fundación ASISTEDCOS"
  description="Recuperando ecosistemas para la biodiversidad y la humanidad en El Salvador desde 1997. Únete a nuestra misión de reforestación y conservación ambiental."
>

<!-- ========== HERO ========== -->
<section class="relative overflow-hidden" style="height: 100vh; min-height: 580px; max-height: 900px;">
  <div class="absolute inset-0">
    <img
      src={siteContent['hero__imagen'] || '/images/reforestacion-aerea.jpg'}
      alt="Reforestación costera en El Salvador"
      class="w-full h-full object-cover"
      fetchpriority="high"
    />
  </div>
  <!-- Gradient overlay -->
  <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(8,21,9,0.96) 0%, rgba(17,43,20,0.88) 55%, rgba(26,71,33,0.45) 100%);"></div>
  <!-- Dot pattern -->
  <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>

  <div class="relative h-full flex flex-col justify-center pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="max-w-2xl">
        <!-- Badge -->
        <div class="animate-fade-up mb-6">
          <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full"
            style="background-color: rgba(245,158,11,0.15); border: 1px solid rgba(251,191,36,0.35); color: #fcd34d;">
            <span class="w-2 h-2 bg-amber-400 rounded-full animate-pulse"></span>
            Fundada en 1997 &middot; La Libertad, El Salvador
          </span>
        </div>

        <!-- Heading -->
        <h1 class="font-heading font-extrabold text-white leading-[1.1] mb-6 animate-fade-up-delay"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
          Recuperando<br/>
          <span class="text-amber-400">ecosistemas</span><br/>
          para la vida
        </h1>

        <!-- Subtitle -->
        <p class="text-lg sm:text-xl leading-relaxed mb-10 max-w-xl animate-fade-up-delay-2" style="color: rgba(255,255,255,0.80);">
          Trabajamos con comunidades rurales de El Salvador para restaurar bosques, proteger manglares y construir un futuro sostenible.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-up-delay-2">
          <a href="/donar"
            class="inline-flex items-center justify-center gap-2.5 font-bold px-8 py-4 rounded-2xl text-base transition-all duration-200 shadow-2xl hover:-translate-y-1 text-white"
            style="background: linear-gradient(135deg, #f59e0b, #d97706);">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            Apoya nuestra misión
          </a>
          <a href="/proyectos"
            class="inline-flex items-center justify-center gap-2.5 font-semibold px-8 py-4 rounded-2xl text-base transition-all duration-200 text-white hover:bg-white/10"
            style="border: 2px solid rgba(255,255,255,0.3);">
            Ver proyectos
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats bar pinned at bottom -->
  <div class="absolute bottom-0 left-0 right-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 rounded-t-2xl overflow-hidden"
        style="background: rgba(8,21,9,0.80); border: 1px solid rgba(255,255,255,0.08); border-bottom: none; backdrop-filter: blur(12px);">
        {[
          { num: '27+', label: 'Años de trabajo' },
          { num: '50+', label: 'Comunidades' },
          { num: '10K+', label: 'Árboles plantados' },
          { num: '6', label: 'Proyectos activos' },
        ].map((s, i) => (
          <div class={`px-6 py-5 text-center ${i < 3 ? 'border-r border-white/10' : ''} ${i >= 2 ? 'hidden md:block' : ''}`}>
            <div class="font-heading text-2xl font-extrabold text-amber-400">{s.num}</div>
            <div class="text-xs font-medium mt-0.5" style="color: rgba(255,255,255,0.55);">{s.label}</div>
          </div>
        ))}
        <!-- Mobile: show all 4 in 2x2 -->
        <div class="md:hidden col-span-2 grid grid-cols-2">
          {[
            { num: '10K+', label: 'Árboles plantados' },
            { num: '6', label: 'Proyectos activos' },
          ].map((s) => (
            <div class="px-6 py-5 text-center border-t border-white/10 border-r last:border-r-0">
              <div class="font-heading text-2xl font-extrabold text-amber-400">{s.num}</div>
              <div class="text-xs font-medium mt-0.5" style="color: rgba(255,255,255,0.55);">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========== CÓMO PUEDES AYUDAR ========== -->
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-flex items-center gap-2 text-amber-500 font-bold text-xs uppercase tracking-widest">
        <span class="w-6 h-px bg-amber-400 inline-block"></span>
        Súmate al cambio
        <span class="w-6 h-px bg-amber-400 inline-block"></span>
      </span>
      <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-gray-900 mt-3">¿Cómo puedes ayudar?</h2>
      <p class="text-gray-500 mt-3 max-w-lg mx-auto leading-relaxed">Hay muchas formas de contribuir a la recuperación de nuestros ecosistemas. Encuentra la que se ajuste a ti.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        {
          icon: `<svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`,
          titulo: 'Donar',
          desc: 'Tu aporte financia proyectos de reforestación y protección de manglares en El Salvador.',
          href: '/donar',
          cta: 'Donar ahora',
          g1: '#f59e0b', g2: '#d97706',
        },
        {
          icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
          titulo: 'Voluntariar',
          desc: 'Únete a jornadas de trabajo comunitario, plantación y monitoreo de ecosistemas.',
          href: '/contacto',
          cta: 'Ser voluntario',
          g1: '#389e4a', g2: '#245f2e',
        },
        {
          icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
          titulo: 'Aliarte',
          desc: 'Las empresas que nos apoyan generan impacto ambiental real y medible en conservación.',
          href: '/contacto',
          cta: 'Ser aliado',
          g1: '#245f2e', g2: '#112b14',
        },
        {
          icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>`,
          titulo: 'Difundir',
          desc: 'Comparte nuestra misión en redes sociales y ayúdanos a llegar a más personas.',
          href: 'https://www.facebook.com/FundacionAsistedcos',
          cta: 'Compartir',
          g1: '#2563eb', g2: '#1d4ed8',
        },
      ].map(item => (
        <div class="group relative flex flex-col p-8 rounded-2xl border border-gray-100 bg-white hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 overflow-hidden">
          <!-- Top accent line -->
          <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
            style={`background: linear-gradient(90deg, ${item.g1}, ${item.g2});`}></div>
          <!-- Icon -->
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6 text-white shadow-lg"
            style={`background: linear-gradient(135deg, ${item.g1}, ${item.g2});`}>
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="font-heading font-bold text-xl text-gray-900 mb-3">{item.titulo}</h3>
          <p class="text-gray-500 text-sm leading-relaxed flex-1 mb-6">{item.desc}</p>
          <a href={item.href}
            class="inline-flex items-center gap-2 text-sm font-bold transition-all duration-200"
            style="color: #245f2e;">
            {item.cta}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ========== ABOUT + COUNTERS ========== -->
<section class="py-24" style="background-color: #f7faf7;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Image -->
      <div class="relative">
        <div class="absolute -top-5 -left-5 w-28 h-28 rounded-2xl opacity-40" style="background-color: #ddf3e0;"></div>
        <div class="absolute -bottom-5 -right-5 w-20 h-20 rounded-2xl opacity-30" style="background-color: #fef3c7;"></div>
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <img
            src={siteContent['about__imagen'] || '/images/voluntaria-plantando.jpg'}
            alt="Voluntaria de ASISTEDCOS plantando árboles"
            class="w-full object-cover aspect-[4/3]"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(8,21,9,0.35) 0%, transparent 55%);"></div>
        </div>
        <!-- Floating badge bottom-left -->
        <div class="absolute -bottom-5 -left-5 bg-white rounded-2xl px-5 py-4 shadow-2xl border border-gray-100">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white font-bold text-base"
              style="background: linear-gradient(135deg, #2d7a3a, #112b14);">97</div>
            <div>
              <p class="font-bold text-sm text-gray-900">Fundada en 1997</p>
              <p class="text-xs text-gray-500">+27 años transformando El Salvador</p>
            </div>
          </div>
        </div>
        <!-- Verified badge top-right -->
        <div class="absolute -top-4 -right-4 rounded-2xl px-4 py-3 shadow-xl"
          style="background: linear-gradient(135deg, #f59e0b, #d97706);">
          <div class="flex items-center gap-1.5 text-white">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-xs font-bold">ONG registrada</span>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div>
        <span class="inline-flex items-center gap-2 text-amber-500 font-bold text-xs uppercase tracking-widest mb-4">
          <span class="w-6 h-px bg-amber-400 inline-block"></span>
          Nuestra misión
        </span>
        <h2 class="font-heading text-3xl md:text-4xl font-extrabold mb-6 leading-tight" style="color: #112b14;">
          Ecosistemas saludables,<br/>
          <span style="color: #2d7a3a;">comunidades prósperas</span>
        </h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          ASISTEDCOS nació en 1997 para atender las secuelas ambientales y sociales de la posguerra en El Salvador. A través de asistencia técnica especializada, promovemos la autogestión comunitaria y la restauración ecológica.
        </p>
        <p class="text-gray-600 leading-relaxed mb-8">
          Trabajamos con comunidades rurales, semi-rurales y urbanas, facilitando la cooperación entre el sector público, privado y organismos internacionales.
        </p>

        <!-- Counters -->
        <div class="grid grid-cols-2 gap-4 mb-8" id="counters-section">
          {[
            { count: 27,    suffix: '+', label: 'Años de trabajo',    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>` },
            { count: 50,    suffix: '+', label: 'Comunidades',        icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>` },
            { count: 10000, suffix: '+', label: 'Árboles plantados',  icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>` },
            { count: 6,     suffix: '',  label: 'Proyectos activos',  icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>` },
          ].map(item => (
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 hover:border-amber-200 hover:shadow-md transition-all duration-300">
              <div class="w-9 h-9 rounded-xl flex items-center justify-center mb-3 text-amber-500"
                style="background-color: #fef3c7;">
                <Fragment set:html={item.icon} />
              </div>
              <div class="font-heading text-3xl font-extrabold flex items-baseline gap-0.5" style="color: #245f2e;">
                <span data-count={item.count} class="counter-num">0</span>
                <span class="text-amber-500">{item.suffix}</span>
              </div>
              <p class="text-xs text-gray-500 font-medium mt-1">{item.label}</p>
            </div>
          ))}
        </div>

        <a href="/nosotros"
          class="inline-flex items-center gap-2.5 text-white font-semibold px-7 py-3.5 rounded-2xl transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg shadow-sm"
          style="background: linear-gradient(135deg, #2d7a3a, #112b14);">
          Conoce nuestra historia
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ========== CAUSAS ========== -->
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-4">
      <div>
        <span class="inline-flex items-center gap-2 text-amber-500 font-bold text-xs uppercase tracking-widest mb-3">
          <span class="w-6 h-px bg-amber-400 inline-block"></span>
          Lo que hacemos
        </span>
        <h2 class="font-heading text-3xl md:text-4xl font-extrabold" style="color: #112b14;">Causas que impulsamos</h2>
        <p class="text-gray-500 mt-2 max-w-lg">Proyectos activos con metas de financiamiento. Tu aporte hace la diferencia.</p>
      </div>
      <a href="/proyectos"
        class="inline-flex items-center gap-2 font-bold text-sm group flex-shrink-0 px-5 py-2.5 rounded-2xl border-2 transition-all duration-200 hover:-translate-y-0.5"
        style="color: #245f2e; border-color: #ddf3e0;">
        Ver todos los proyectos
        <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {causeCards.map(cause => {
        const meta = Number(cause.meta);
        const rec  = Number(cause.recaudado);
        const pct  = meta > 0 ? Math.round((rec / meta) * 100) : 0;
        return (
          <div class="group bg-white rounded-2xl shadow-md overflow-hidden flex flex-col hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 border border-gray-100">
            <!-- Image -->
            <div class="relative overflow-hidden" style="height: 220px;">
              <img
                src={cause.coverImage || '/images/reforestacion-aerea.jpg'}
                alt={cause.titulo}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.25) 0%, transparent 60%);"></div>
              {cause.tag && (
