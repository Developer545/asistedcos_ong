---
export const prerender = false;
import Layout from '../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcosadmin.vercel.app';

type NewsItem     = { id: string; title: string; slug: string; summary?: string; coverImage?: string; publishedAt?: string };
type CauseItem    = { id: string; titulo: string; descripcion?: string; tag?: string; coverImage?: string; meta: number; recaudado: number };
type FaqItem      = { id: string; question: string; answer: string };
type GalleryItem  = { id: string; title?: string; url: string; category?: string };
type PartnerItem  = { id: string; name: string; logo?: string; url?: string };

let latestNews: NewsItem[]    = [];
let causeCards: CauseItem[]   = [];
let faqItems: FaqItem[]       = [];
let galleryItems: GalleryItem[] = [];
let partners: PartnerItem[]   = [];
let siteContent: Record<string, string> = {};

await Promise.allSettled([
  fetch(`${ADMIN_URL}/api/public/noticias?limit=3`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) latestNews = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/causas`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) causeCards = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/faq`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) faqItems = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/galeria`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) galleryItems = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/aliados`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null).then(d => { if (d) partners = d.data ?? []; }),
  fetch(`${ADMIN_URL}/api/public/contenido`, { signal: AbortSignal.timeout(5000) })
    .then(r => r.ok ? r.json() : null)
    .then(d => {
      if (d?.data) {
        d.data.forEach((item: { section: string; key: string; value: string }) => {
          siteContent[`${item.section}__${item.key}`] = item.value;
        });
      }
    }),
]);

const testimonials = [
  { quote: 'Gracias a ASISTEDCOS aprendimos a proteger los manglares que nos dan vida. El apoyo técnico fue fundamental para nuestra comunidad.', name: 'María López', role: 'Pescadora, La Libertad', initials: 'ML' },
  { quote: 'Como empresa, nuestra alianza con ASISTEDCOS nos permitió recuperar el área de conservación en la Costa del Bálsamo. Un impacto real y medible.', name: 'Representante Concentrix', role: 'Aliado Estratégico', initials: 'CO' },
  { quote: 'Los viveros comunitarios cambiaron nuestra forma de ver el territorio. Hoy somos guardianes del bosque.', name: 'Juan García', role: 'Comunidad Rural, La Libertad', initials: 'JG' },
];

const teamMembers = [
  { initials: 'BJ', nombre: 'Lic. Blanca Estela Juárez', cargo: 'Directora Ejecutiva' },
  { initials: 'ET', nombre: 'Equipo Técnico', cargo: 'Especialistas en Gestión Ambiental' },
  { initials: '+20', nombre: 'Voluntarios', cargo: 'Colaboradores activos en campo' },
];
---

<Layout
  title="Fundación ASISTEDCOS"
  description="Recuperando ecosistemas para la biodiversidad y la humanidad en El Salvador desde 1997."
>

<!-- ===================== HERO ===================== -->
<section class="hero-section relative overflow-hidden" style="background-color:#081509; height:100vh; min-height:620px; max-height:960px;">

  <!-- Background image with blend -->
  <div class="absolute inset-0">
    <img
      src={siteContent['hero__imagen'] || '/images/reforestacion-aerea.jpg'}
      alt="Reforestación costera El Salvador"
      class="w-full h-full object-cover"
      fetchpriority="high"
      style="opacity:0.35; mix-blend-mode: luminosity;"
    />
  </div>
  <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(8,21,9,0.98) 35%, rgba(8,21,9,0.55) 70%, rgba(8,21,9,0.20) 100%);"></div>

  <!-- Slide counter — right side vertical (Desart pattern) -->
  <div class="absolute right-8 top-1/2 -translate-y-1/2 hidden lg:flex flex-col items-center gap-3" style="writing-mode: vertical-rl; transform: translateY(-50%) rotate(180deg);">
    <span class="text-amber-500 font-bold text-xs tracking-[0.3em]">01 / 01</span>
    <div class="w-px h-16 bg-white/20"></div>
    <span class="text-white/30 text-xs tracking-[0.3em] uppercase">Inicio</span>
  </div>

  <!-- Content -->
  <div class="relative h-full flex items-center">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 w-full">
      <div class="max-w-3xl">

        <!-- Section tag -->
        <div class="flex items-center gap-4 mb-8 animate-fade-up">
          <div class="w-12 h-px bg-amber-500"></div>
          <span class="text-amber-500 text-xs font-bold uppercase tracking-[0.35em]">Desde 1997 &middot; El Salvador</span>
        </div>

        <!-- Heading -->
        <h1 class="font-heading font-extrabold text-white leading-none mb-8 animate-fade-up-delay hero-title">
          Recuperando<br/>
          <em class="not-italic text-amber-400">ecosistemas</em><br/>
          para la vida
        </h1>

        <!-- Subtitle -->
        <p class="mb-10 max-w-lg leading-relaxed animate-fade-up-delay-2" style="color:rgba(255,255,255,0.65); font-size:1.15rem;">
          Trabajamos con comunidades rurales de El Salvador para restaurar bosques, proteger manglares y construir un futuro sostenible.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-up-delay-2">
          <a href="/donar" class="hero-btn-primary inline-flex items-center justify-center gap-3 font-bold text-sm uppercase tracking-wider px-10 py-4 transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            Apoya la misión
          </a>
          <a href="/proyectos" class="hero-btn-secondary inline-flex items-center justify-center gap-3 font-bold text-sm uppercase tracking-wider px-10 py-4 transition-all duration-300 text-white">
            Ver proyectos
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

      </div>
    </div>
  </div>

  <!-- Stats strip -->
  <div class="absolute bottom-0 left-0 right-0" style="background:rgba(0,0,0,0.5); border-top:1px solid rgba(255,255,255,0.08); backdrop-filter:blur(10px);">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid grid-cols-2 md:grid-cols-4">
        {[
          { num: '27+',  label: 'Años de trabajo' },
          { num: '50+',  label: 'Comunidades' },
          { num: '10K+', label: 'Árboles plantados' },
          { num: '6',    label: 'Proyectos activos' },
        ].map((s, i) => (
          <div class={`px-6 py-5 text-center ${i < 3 ? 'border-r border-white/10' : ''}`}>
            <div class="font-heading text-2xl font-extrabold text-amber-400">{s.num}</div>
            <div class="text-xs uppercase tracking-wider mt-1" style="color:rgba(255,255,255,0.40);">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ===================== CÓMO AYUDAR ===================== -->
<section class="section-lg bg-white">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <div class="section-label mb-4">
          <span class="label-line"></span>
          <span>¿Cómo puedes ayudar?</span>
        </div>
        <h2 class="section-title">Formas de<br/><span class="text-amber-500">contribuir</span></h2>
      </div>
      <p class="text-gray-500 max-w-sm leading-relaxed text-sm md:text-right">
        Hay muchas formas de contribuir a la recuperación de nuestros ecosistemas. Encuentra la que se ajuste a ti.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        {
          num: '01',
          icon: `<svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`,
          titulo: 'Donar',
          desc: 'Tu aporte financia proyectos de reforestación y protección de manglares en El Salvador.',
          href: '/donar', cta: 'Donar ahora',
        },
        {
          num: '02',
          icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
          titulo: 'Voluntariar',
          desc: 'Únete a jornadas de trabajo comunitario, plantación y monitoreo de ecosistemas.',
          href: '/contacto', cta: 'Ser voluntario',
        },
        {
          num: '03',
          icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
          titulo: 'Aliarte',
          desc: 'Las empresas que nos apoyan generan impacto ambiental real y medible en conservación.',
          href: '/contacto', cta: 'Ser aliado',
        },
        {
          num: '04',
          icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>`,
          titulo: 'Difundir',
          desc: 'Comparte nuestra misión en redes sociales y ayúdanos a llegar a más personas.',
          href: 'https://www.facebook.com/FundacionAsistedcos', cta: 'Compartir',
        },
      ].map(item => (
        <div class="service-card group">
          <div class="service-card-num">{item.num}</div>
          <div class="service-card-icon text-amber-500 mb-5">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="font-heading font-bold text-xl text-gray-900 mb-3">{item.titulo}</h3>
          <p class="text-gray-500 text-sm leading-relaxed flex-1 mb-6" style="font-size:0.95rem;">{item.desc}</p>
          <a href={item.href} class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider transition-colors duration-300" style="color:#2d7a3a;">
            {item.cta}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== ABOUT + COUNTERS ===================== -->
<section class="section-lg" style="background-color:#f7f7f7;">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Image stack -->
      <div class="relative">
        <div class="about-img-main">
          <img
            src={siteContent['about__imagen'] || '/images/voluntaria-plantando.jpg'}
            alt="Voluntaria de ASISTEDCOS plantando árboles"
            class="w-full h-full object-cover"
          />
        </div>
        <!-- Shadow block Desart style -->
        <div class="about-img-shadow"></div>
        <!-- Year badge -->
        <div class="absolute bottom-6 right-6 bg-white px-6 py-5 shadow-card">
          <div class="font-heading text-4xl font-extrabold" style="color:#081509;">27<span class="text-amber-500">+</span></div>
          <div class="text-xs uppercase tracking-wider text-gray-500 mt-1">Años de experiencia</div>
        </div>
      </div>

      <!-- Text -->
      <div>
        <div class="section-label mb-5">
          <span class="label-line"></span>
          <span>Nuestra misión</span>
        </div>
        <h2 class="section-title mb-6">
          Ecosistemas<br/>saludables,<br/><span class="text-amber-500">comunidades</span><br/>prósperas
        </h2>
        <p class="text-gray-500 leading-relaxed mb-4" style="font-size:1rem;">
          ASISTEDCOS nació en 1997 para atender las secuelas ambientales y sociales de la posguerra en El Salvador. A través de asistencia técnica especializada, promovemos la autogestión comunitaria y la restauración ecológica.
        </p>
        <p class="text-gray-500 leading-relaxed mb-10" style="font-size:1rem;">
          Trabajamos con comunidades rurales, semi-rurales y urbanas, facilitando la cooperación entre el sector público, privado y organismos internacionales.
        </p>

        <!-- Counters 2×2 -->
        <div class="grid grid-cols-2 gap-6 mb-10" id="counters-section">
          {[
            { count: 27,    suffix: '+', label: 'Años de trabajo' },
            { count: 50,    suffix: '+', label: 'Comunidades apoyadas' },
            { count: 10000, suffix: '+', label: 'Árboles plantados' },
            { count: 6,     suffix: '',  label: 'Proyectos activos' },
          ].map(item => (
            <div class="counter-box">
              <div class="font-heading text-4xl font-extrabold flex items-baseline gap-0.5" style="color:#081509;">
                <span data-count={item.count} class="counter-num">0</span>
                <span class="text-amber-500">{item.suffix}</span>
              </div>
              <div class="w-8 h-0.5 bg-amber-500 mt-2 mb-2"></div>
              <p class="text-xs uppercase tracking-wider text-gray-400">{item.label}</p>
            </div>
          ))}
        </div>

        <a href="/nosotros" class="btn-primary inline-flex items-center gap-3">
          Conoce nuestra historia
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===================== CAUSAS ===================== -->
<section class="section-lg bg-white">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <div class="section-label mb-4">
          <span class="label-line"></span>
          <span>Lo que hacemos</span>
        </div>
        <h2 class="section-title">Causas que<br/><span class="text-amber-500">impulsamos</span></h2>
      </div>
      <a href="/proyectos" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider group transition-colors duration-300" style="color:#2d7a3a;">
        Ver todos los proyectos
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {causeCards.map(cause => {
        const meta = Number(cause.meta);
        const rec  = Number(cause.recaudado);
        const pct  = meta > 0 ? Math.round((rec / meta) * 100) : 0;
        return (
          <div class="cause-card group">
            <!-- Image -->
            <div class="cause-img-wrap">
              <img
                src={cause.coverImage || '/images/reforestacion-aerea.jpg'}
                alt={cause.titulo}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
              {cause.tag && (
                <span class="cause-tag">{cause.tag}</span>
              )}
              <span class="cause-pct">{pct}%</span>
            </div>
            <!-- Body -->
            <div class="p-6">
              <h3 class="font-heading font-bold text-lg text-gray-900 mb-2 leading-snug">{cause.titulo}</h3>
              <p class="text-gray-500 text-sm leading-relaxed mb-5" style="font-size:0.9rem;">{cause.descripcion}</p>
              <!-- Progress bar -->
              <div class="mb-4">
                <div class="flex justify-between text-xs font-bold mb-2">
                  <span class="text-gray-400 uppercase tracking-wider">Progreso</span>
                  <span style="color:#2d7a3a;">{pct}%</span>
                </div>
                <div class="w-full h-1.5 bg-gray-100">
                  <div class="h-1.5 bg-amber-500 transition-all duration-1000" style={`width:${Math.min(pct, 100)}%;`}></div>
                </div>
              </div>
              <!-- Stats row -->
              <div class="grid grid-cols-3 text-center border-t border-gray-100 pt-4 mb-5">
                <div>
                  <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">Meta</div>
                  <div class="font-bold text-sm text-gray-800">${(meta/1000).toFixed(0)}k</div>
                </div>
                <div class="border-x border-gray-100">
                  <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">Logrado</div>
                  <div class="font-bold text-sm" style="color:#2d7a3a;">${rec.toLocaleString()}</div>
                </div>
                <div>
                  <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">Faltante</div>
                  <div class="font-bold text-sm text-amber-500">${Math.max(0, meta - rec).toLocaleString()}</div>
                </div>
              </div>
              <a href="/donar" class="btn-primary block text-center text-sm">Donar a esta causa</a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- ===================== GALERÍA ===================== -->
{galleryItems.length > 0 && (
  <section class="section-lg" style="background-color:#081509;">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">

      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14">
        <div>
          <div class="section-label mb-4" style="--label-color:#f59e0b; --label-text:rgba(255,255,255,0.5);">
            <span class="label-line" style="background:#f59e0b;"></span>
            <span style="color:rgba(255,255,255,0.5);">Nuestro trabajo</span>
          </div>
          <h2 class="section-title text-white">Galería de<br/><span class="text-amber-400">impacto</span></h2>
        </div>
        <p class="text-white/40 text-sm max-w-xs leading-relaxed">Imágenes de nuestros proyectos en el campo, documentando el cambio real.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {galleryItems.slice(0, 6).map(item => (
          <div class="gallery-item group" style="aspect-ratio:4/3;">
            <img
              src={item.url}
              alt={item.title || 'Galería ASISTEDCOS'}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              loading="lazy"
            />
            <div class="gallery-overlay">
              {item.title && (
                <div class="p-5">
                  <p class="text-white text-sm font-semibold">{item.title}</p>
                  {item.category && <p class="text-amber-400 text-xs mt-1 uppercase tracking-wider">{item.category}</p>}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ===================== CÓMO TRABAJAMOS ===================== -->
<section class="section-lg bg-white">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    <div class="text-center mb-16">
      <div class="section-label justify-center mb-4">
        <span class="label-line"></span>
        <span>Nuestro proceso</span>
        <span class="label-line"></span>
      </div>
      <h2 class="section-title mx-auto">¿Cómo <span class="text-amber-500">trabajamos</span>?</h2>
      <p class="text-gray-500 mt-4 max-w-xl mx-auto leading-relaxed" style="font-size:0.95rem;">Un proceso metodológico que garantiza impacto real y sostenible en cada comunidad.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-0 border border-gray-100">
      {[
        {
          num: '01',
          titulo: 'Identificamos',
          desc: 'Realizamos diagnósticos ambientales y sociales para entender las necesidades específicas de cada comunidad y ecosistema.',
          icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>`,
        },
        {
          num: '02',
          titulo: 'Actuamos',
          desc: 'Implementamos proyectos de reforestación, conservación y desarrollo comunitario con participación local activa.',
          icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
        },
        {
          num: '03',
          titulo: 'Medimos',
          desc: 'Monitoreamos y evaluamos el impacto de cada intervención para garantizar resultados tangibles y sostenibles.',
