<style>
  /* ---- Layout ---- */
  .section-lg { padding-top: 9rem; padding-bottom: 9rem; }
  @media (max-width: 768px) { .section-lg { padding-top: 5rem; padding-bottom: 5rem; } }

  /* ---- Hero title responsive ---- */
  .hero-title { font-size: clamp(3rem, 7vw, 5.5rem); line-height: 1.0; }

  /* ---- Buttons ---- */
  .btn-primary {
    background-color: #f59e0b;
    color: #ffffff;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 1rem 2.5rem;
    border: 2px solid #f59e0b;
    transition: background-color 0.3s, color 0.3s;
  }
  .btn-primary:hover { background-color: #081509; border-color: #081509; color: #fff; }

  .btn-outline-white {
    border: 2px solid rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.7);
    transition: border-color 0.3s, color 0.3s;
  }
  .btn-outline-white:hover { border-color: #f59e0b; color: #f59e0b; }

  .hero-btn-primary {
    background-color: #f59e0b;
    color: #fff;
    border: 2px solid #f59e0b;
    transition: background-color 0.3s, color 0.3s;
  }
  .hero-btn-primary:hover { background-color: transparent; color: #f59e0b; }

  .hero-btn-secondary {
    border: 2px solid rgba(255,255,255,0.25);
    transition: border-color 0.3s, color 0.3s;
  }
  .hero-btn-secondary:hover { border-color: #f59e0b; color: #f59e0b; }

  /* ---- Section label ---- */
  .section-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #757575;
  }
  .label-line {
    display: inline-block;
    height: 1px;
    width: 2rem;
    background-color: #f59e0b;
    flex-shrink: 0;
  }

  /* ---- Section title ---- */
  .section-title {
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.15;
    color: #222222;
  }

  /* ---- Service cards ---- */
  .service-card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
    background: #fff;
    border: 1px solid #e2e2e2;
    position: relative;
    transition: box-shadow 0.3s, border-color 0.3s;
  }
  .service-card:hover { box-shadow: -11px -11px 35px 0px rgba(0,0,0,0.08); border-color: #f59e0b; }
  .service-card-num {
    position: absolute;
    top: 1.5rem;
    right: 1.75rem;
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
    font-size: 3.5rem;
    line-height: 1;
    color: #f7f7f7;
    user-select: none;
    transition: color 0.3s;
  }
  .service-card:hover .service-card-num { color: #fef3c7; }

  /* ---- About image ---- */
  .about-img-main {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
    z-index: 1;
  }
  .about-img-shadow {
    position: absolute;
    bottom: -18px;
    left: -18px;
    width: 70%;
    height: 70%;
    border: 3px solid #f59e0b;
    z-index: 0;
  }

  /* ---- Shadow card Desart ---- */
  .shadow-card { box-shadow: -11px -11px 35px 0px rgba(0,0,0,0.10); }

  /* ---- Counter box ---- */
  .counter-box {
    padding: 1.5rem;
    background: #fff;
    border: 1px solid #e2e2e2;
    transition: box-shadow 0.3s;
  }
  .counter-box:hover { box-shadow: -11px -11px 35px 0px rgba(0,0,0,0.08); }

  /* ---- Cause card ---- */
  .cause-card {
    background: #fff;
    border: 1px solid #e2e2e2;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s, border-color 0.3s;
  }
  .cause-card:hover { box-shadow: -11px -11px 35px 0px rgba(0,0,0,0.10); border-color: #d1d5db; }
  .cause-img-wrap { position: relative; overflow: hidden; height: 215px; }
  .cause-tag {
    position: absolute; top: 1rem; left: 1rem;
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    padding: 0.3rem 0.75rem; background-color: #2d7a3a; color: #fff;
  }
  .cause-pct {
    position: absolute; top: 1rem; right: 1rem;
    font-size: 0.7rem; font-weight: 700;
    padding: 0.3rem 0.75rem; background-color: rgba(255,255,255,0.95); color: #2d7a3a;
  }

  /* ---- Gallery ---- */
  .gallery-item { position: relative; overflow: hidden; cursor: pointer; }
  .gallery-overlay {
    position: absolute; inset: 0;
    display: flex; align-items: flex-end;
    background: linear-gradient(to top, rgba(8,21,9,0.85) 0%, transparent 60%);
    opacity: 0; transition: opacity 0.3s;
  }
  .gallery-item:hover .gallery-overlay { opacity: 1; }

  /* ---- Process step ---- */
  .process-step {
    padding: 3rem 2.5rem;
    background: #fff;
    position: relative;
    transition: background-color 0.3s;
  }
  .process-step:hover { background-color: #f7f7f7; }
  .process-num {
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
    font-size: 5rem;
    line-height: 1;
    color: #f3f4f6;
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    user-select: none;
    transition: color 0.3s;
  }
  .process-step:hover .process-num { color: #fef3c7; }

  /* ---- Testimonial card ---- */
  .testimonial-card {
    background: #fff;
    border: 1px solid #e2e2e2;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s, border-color 0.3s;
  }
  .testimonial-card:hover { box-shadow: -11px -11px 35px 0px rgba(0,0,0,0.08); border-color: #f59e0b; }

  /* ---- Team card ---- */
  .team-card {
    background: #fff;
    border: 1px solid #e2e2e2;
    padding: 2.5rem;
    text-align: center;
    transition: box-shadow 0.3s, border-color 0.3s;
  }
  .team-card:hover { box-shadow: -11px -11px 35px 0px rgba(0,0,0,0.08); border-color: #f59e0b; }
  .team-avatar {
    width: 5rem; height: 5rem;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Poppins', sans-serif;
    font-weight: 700; font-size: 1.2rem; color: #fff;
    margin: 0 auto;
    transition: background-color 0.3s;
  }
  .team-card:hover .team-avatar { background-color: #f59e0b !important; }

  /* ---- News card ---- */
  .news-card {
    background: #fff;
    border: 1px solid #e2e2e2;
    overflow: hidden;
    display: block;
    transition: box-shadow 0.3s, border-color 0.3s;
  }
  .news-card:hover { box-shadow: -11px -11px 35px 0px rgba(0,0,0,0.10); border-color: #d1d5db; }
  .news-img-wrap { aspect-ratio: 16/10; overflow: hidden; position: relative; background-color: #ddf3e0; }
  .news-date {
    position: absolute; top: 0.75rem; left: 0.75rem;
    font-size: 0.7rem; font-weight: 700;
    padding: 0.3rem 0.75rem; background: rgba(255,255,255,0.95); color: #1a4721;
  }

  /* ---- Amount button ---- */
  .amount-btn { transition: background-color 0.3s, border-color 0.3s, color 0.3s; }
  .amount-btn:hover { background-color: #f59e0b; border-color: #f59e0b; }

  /* ---- Utility ---- */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // ---- Counter animation ----
  function initCounters() {
    const counters = document.querySelectorAll<HTMLElement>('[data-count]');
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target as HTMLElement;
        const target = parseInt(el.dataset.count || '0');
        const start = performance.now();
        const duration = 2000;
        function tick(now: number) {
          const p = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.floor(ease * target).toLocaleString();
          if (p < 1) requestAnimationFrame(tick);
          else el.textContent = target.toLocaleString();
        }
        requestAnimationFrame(tick);
        obs.unobserve(el);
      });
    }, { threshold: 0.5 });
    counters.forEach(c => obs.observe(c));
  }

  // ---- FAQ accordion ----
  function initFaq() {
    document.querySelectorAll('.faq-trigger').forEach(btn => {
      btn.addEventListener('click', () => {
        const item   = btn.closest('.faq-item');
        const answer = item?.querySelector('.faq-answer');
        const icon   = btn.querySelector('.faq-icon') as HTMLElement | null;
        const isOpen = !answer?.classList.contains('hidden');

        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll<HTMLElement>('.faq-icon').forEach(i => {
          i.textContent = '+';
          i.style.backgroundColor = '#081509';
        });
        document.querySelectorAll('.faq-trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));

        if (!isOpen && answer && icon) {
          answer.classList.remove('hidden');
          icon.textContent = '−';
          icon.style.backgroundColor = '#f59e0b';
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initCounters();
    initFaq();
  });
</script>
