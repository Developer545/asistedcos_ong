---
export const prerender = false;
import Layout from '../layouts/Layout.astro';

const ADMIN_URL = import.meta.env.PUBLIC_ADMIN_URL || 'https://asistedcosadmin.vercel.app';
let siteContent: Record<string, string> = {};

await fetch(`${ADMIN_URL}/api/public/contenido`, { signal: AbortSignal.timeout(5000) })
  .then(r => r.ok ? r.json() : null)
  .then(d => {
    if (d?.data) {
      d.data.forEach((item: { section: string; key: string; value: string }) => {
        siteContent[`${item.section}__${item.key}`] = item.value;
      });
    }
  })
  .catch(() => null);

const impactos = [
  { amount: 10,  logro: 'Kit de vivero comunitario', desc: 'Insumos para preparar plántulas de mangle antes de la jornada.' },
  { amount: 25,  logro: 'Siembra familiar',          desc: 'Apoya plantas, transporte y materiales para una familia voluntaria.' },
  { amount: 50,  logro: 'Brigada de manglar',        desc: 'Logística básica para una jornada de restauración costera.' },
  { amount: 100, logro: 'Punto de hidratación',      desc: 'Agua, sombra y seguridad para voluntarios en campo.' },
  { amount: 250, logro: 'Cuadrilla completa',        desc: 'Movilización y herramientas para sembrar en zonas priorizadas.' },
];
const fallbackCampaignImage = 'https://upload.wikimedia.org/wikipedia/commons/thumb/3/3c/Mangroves_%2853575624549%29.jpg/3840px-Mangroves_%2853575624549%29.jpg';
const campaignSlug = siteContent['campaign__slug'] || 'mangles-1m';
const campaignBadge = siteContent['campaign__badge'] || '26 mayo 2026';
const campaignTitle = siteContent['campaign__title'] || 'Siembra de 1 Millón de mangles';
const campaignDescription = siteContent['campaign__description'] || 'Tu aporte impulsa viveros, transporte, herramientas y jornadas comunitarias para restaurar manglares en El Salvador, con una meta nacional clara y visible.';
const campaignImage = siteContent['campaign__image'] || fallbackCampaignImage;
const campaignGoalLabel = siteContent['campaign__goalLabel'] || '1 Millón';
const campaignUnitLabel = siteContent['campaign__unitLabel'] || 'de mangles';
const campaignProgressPercent = Math.min(100, Math.max(0, Number(siteContent['campaign__progressPercent'] || '18')));
const campaignSuggestedAmount = Math.max(1, Number(siteContent['campaign__suggestedAmount'] || '25'));
const campaignAmountsParsed = (siteContent['campaign__amounts'] || '10,25,50,100,250')
  .split(',')
  .map((value) => Number(value.trim()))
  .filter((value) => Number.isFinite(value) && value > 0);
const campaignAmounts = campaignAmountsParsed.length ? campaignAmountsParsed : [10, 25, 50, 100, 250];
const fallbackCampaignEndsAt = '2026-05-26T23:59:59';
const campaignEndsAt = siteContent['campaign__endsAt'] || fallbackCampaignEndsAt;
const campaignDate = new Date(campaignEndsAt);
const hasCampaignDate = !Number.isNaN(campaignDate.getTime());
const campaignDateLong = hasCampaignDate
  ? campaignDate.toLocaleDateString('es-SV', { day: 'numeric', month: 'long', year: 'numeric' })
  : '26 de mayo de 2026';
const campaignRemainingDays = hasCampaignDate
  ? Math.max(0, Math.ceil((campaignDate.getTime() - Date.now()) / (1000 * 60 * 60 * 24)))
  : 30;
---

<Layout
  title="Donar"
  description="Apoya la misión de Fundación ASISTEDCOS. Tu donación restaura ecosistemas y transforma comunidades en El Salvador."
  image="https://upload.wikimedia.org/wikipedia/commons/thumb/3/3c/Mangroves_%2853575624549%29.jpg/3840px-Mangroves_%2853575624549%29.jpg"
>

<!-- HERO -->
<section
  class="don-hero"
  data-campaign-ends-at={campaignEndsAt}
  data-campaign-date-long={campaignDateLong}
  data-campaign-title={campaignTitle}
  data-campaign-description={campaignDescription}
  data-campaign-goal-label={campaignGoalLabel}
  data-campaign-unit-label={campaignUnitLabel}
  data-campaign-suggested-amount={String(campaignSuggestedAmount)}
  data-campaign-progress-percent={String(campaignProgressPercent)}
  data-campaign-badge={campaignBadge}
  data-campaign-slug={campaignSlug}
>
  <div class="don-hero-bg" style={`background:
      linear-gradient(to right,rgba(8,21,9,.54) 0%,rgba(8,21,9,.30) 48%,rgba(8,21,9,.14) 100%),
      linear-gradient(to bottom,rgba(8,21,9,.10) 0%,rgba(8,21,9,.04) 55%,rgba(8,21,9,.16) 100%),
      url('${campaignImage}') center/cover no-repeat;`}></div>
  <div class="don-container" style="position:relative;z-index:1;">
    <div class="don-hero-card">
    <nav class="don-breadcrumb">
      <a href="/">Inicio</a><span>›</span><span>Donar</span>
    </nav>
    <p class="don-eyebrow">Campaña activa · 26 de mayo de 2026</p>
    <h1 class="don-h1">Dona para sembrar <span class="don-accent">1 Mill&oacute;n de mangles</span></h1>
    <p class="don-hero-sub">Tu aporte impulsa viveros, transporte, herramientas y jornadas comunitarias para restaurar manglares en El Salvador, con una meta nacional clara y visible.</p>
    <div class="don-badge">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
      Donaciones deducibles de impuestos — Art. 32, Ley de Renta de El Salvador
    </div>
    </div>
  </div>
  <div class="don-scroll" aria-hidden="true"><span></span></div>
</section>

<!-- CAMPAÑA STRIP -->
<section class="don-campaign-strip">
  <div class="don-campaign-strip-bg"></div>
  <div class="don-container don-campaign-inner">

    <!-- Left: Info -->
    <div class="don-campaign-info">
      <span class="don-campaign-date">{campaignBadge}</span>
      <h2 class="don-campaign-title">{campaignTitle}</h2>
      <p class="don-campaign-desc">{campaignDescription}</p>

      <!-- Progress bar -->
      <div class="don-progress-wrap">
        <div class="don-progress-bar">
          <div class="don-progress-fill" style={`width:${campaignProgressPercent}%`}></div>
        </div>
        <div class="don-progress-labels">
          <span class="don-progress-pct">{campaignProgressPercent}% alcanzado</span>
          <span class="don-progress-goal">Meta: {campaignGoalLabel} {campaignUnitLabel}</span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="don-campaign-divider"></div>

    <!-- Right: Metrics + Countdown -->
    <div class="don-campaign-right">
      <div class="don-campaign-metrics">
        <div class="don-metric">
          <strong>{campaignGoalLabel}</strong>
          <span>{campaignUnitLabel}</span>
        </div>
        <div class="don-metric">
          <strong>${campaignSuggestedAmount}</strong>
          <span>aporte sugerido</span>
        </div>
        <div class="don-metric">
          <strong>{campaignRemainingDays}</strong>
          <span>días restantes</span>
        </div>
      </div>

      <!-- Countdown -->
      <div class="don-countdown-card">
        <p class="don-countdown-label">Tiempo restante</p>
        <div class="don-countdown-grid don-countdown" data-countdown={campaignEndsAt}>
          <div class="don-countdown-unit">
            <strong data-unit="days">{campaignRemainingDays}</strong>
            <small>Días</small>
          </div>
          <div class="don-countdown-unit">
            <strong data-unit="hours">00</strong>
            <small>Horas</small>
          </div>
          <div class="don-countdown-unit">
            <strong data-unit="minutes">00</strong>
            <small>Min</small>
          </div>
          <div class="don-countdown-unit">
            <strong data-unit="seconds">00</strong>
            <small>Seg</small>
          </div>
        </div>
      </div>

      <a href="#donar-monto" class="don-campaign-cta">Donar ahora &darr;</a>
    </div>

  </div>
</section>

<section id="donar-monto" class="don-section" style="background:#f7f7f7; position:relative;">
  <div class="don-deco-num" aria-hidden="true">.01</div>
  <div class="don-container">
    <div class="don-split">

      <!-- FORM -->
      <div class="don-form-col">
        <p class="don-eyebrow">Elige tu aporte</p>
        <h2 class="don-h2">¿Cuánto quieres <span class="don-accent">sembrar</span>?</h2>
        <p class="don-form-sub">Selecciona un monto para la campaña de manglares</p>

        <div class="don-form-card">
          <!-- Montos -->
          <div class="don-amounts-section">
            <p class="don-amounts-label">Montos sugeridos</p>
            <div class="don-amounts-grid">
              {campaignAmounts.map(n => (
                <button class="amount-btn" data-amount={n}>
                  <span class="don-amt-val">${n}</span>
                  <span class="don-amt-cur">USD</span>
                </button>
              ))}
            </div>
          </div>

          <!-- Custom -->
          <div class="don-custom-section">
            <p class="don-amounts-label">O ingresa tu monto</p>
            <div class="don-custom-row">
              <span class="don-custom-sym">$</span>
              <input id="custom-input" type="number" min="1" max="50000" placeholder="Ejemplo: 75" />
              <span class="don-custom-cur">USD</span>
            </div>
          </div>

          <!-- Summary -->
          <div class="don-summary">
            <div class="don-total-row">
              <div>
                <p class="don-total-label">Total a donar</p>
                <p id="amount-display" class="don-total-val">$0.00</p>
              </div>
              <div style="text-align:right;">
                <p class="don-total-label">Procesado por</p>
                <p class="don-processor">Wompi · Banco Agrícola</p>
              </div>
            </div>

            <button id="wompi-btn" disabled class="don-pay-btn">
              <svg id="wompi-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
              <svg id="wompi-spinner" class="don-spin hidden" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
              </svg>
              <span id="wompi-label">Selecciona un monto para continuar</span>
            </button>

            <p id="wompi-error" class="don-error hidden"></p>

            <div class="don-trust">
              <span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                Pago seguro SSL
              </span>
              <span>·</span>
              <span>Visa · Mastercard · Cuotas</span>
              <span>·</span>
              <span>Recibo por correo</span>
            </div>
          </div>
        </div>
      </div>

      <!-- IMPACTO -->
      <div class="don-impact-col">
        <p class="don-eyebrow">Tu donación en acción</p>
        <h2 class="don-h2">¿Qué activa <span class="don-accent">cada monto</span>?</h2>
        <div class="don-impacts">
          {impactos.map(item => (
            <div class="don-impact-card impact-card" data-amount={item.amount}>
              <div class="don-impact-head">
                <span class="don-impact-amount">${item.amount}</span>
                <span class="don-impact-title">{item.logro}</span>
              </div>
              <p class="don-impact-desc">{item.desc}</p>
            </div>
          ))}
        </div>

        <!-- Transferencia -->
        <div class="don-transfer">
          <div class="don-transfer-head">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
            <div>
              <h3>Transferencia Bancaria</h3>
              <p>El Salvador · Sin comisiones</p>
            </div>
          </div>
          <a href="/contacto" class="don-transfer-btn">Solicitar datos bancarios &rarr;</a>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- QUOTE -->
<section class="don-quote-section">
  <div class="don-container" style="text-align:center;">
    <svg class="don-quote-icon" viewBox="0 0 24 24" fill="currentColor">
      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
    </svg>
    <blockquote class="don-quote">"Donar a ASISTEDCOS fue una de las mejores decisiones. Saber que mi dinero va directo al campo, sin burocracia, me da confianza total."</blockquote>
    <div class="don-quote-divider"></div>
    <p class="don-quote-author">Carlos M.</p>
    <p class="don-quote-role">Donante desde 2021 — San Salvador</p>
  </div>
</section>

<!-- TRANSPARENCIA -->
<section class="don-section" style="background:#fff;">
  <div class="don-container">
    <div class="don-transparency">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p>
        <strong>Transparencia total:</strong> El 100% de las donaciones va directamente a proyectos de campo. Presentamos estados financieros anuales auditados. Para recibo fiscal escríbenos a <a href="mailto:info@asistedcos.org">info@asistedcos.org</a>.
      </p>
    </div>

    <div class="don-ways-grid">
      {[
        { titulo:'Voluntariado', desc:'Únete a nuestras jornadas de reforestación. No se necesita experiencia.', href:'/contacto' },
        { titulo:'Difunde',      desc:'Comparte nuestro trabajo en redes y ayúdanos a llegar a más donantes.', href:'/contacto' },
        { titulo:'Alianza Empresarial', desc:'Tu empresa puede ser parte de nuestros proyectos de RSE ambiental.', href:'/contacto' },
      ].map((w,i) => (
        <div class="don-way-card">
          <span class="don-way-num">0{i+1}</span>
          <h3 class="don-way-title">{w.titulo}</h3>
          <p class="don-way-desc">{w.desc}</p>
          <a href={w.href} class="don-way-link">Contáctanos &rarr;</a>
        </div>
      ))}
    </div>
  </div>
</section>

</Layout>

<style>
  :root {
    --don-accent:#f59e0b; --don-dark:#111; --don-forest:#081509;
    --don-head:'Poppins',system-ui,sans-serif; --don-shadow:0 8px 30px rgba(0,0,0,.08);
  }
  .don-container { max-width:1200px; margin:0 auto; padding:0 1.5rem; }
  .don-section   { padding:5.5rem 0; overflow:hidden; }
  .don-eyebrow {
    font-size:.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.28em; color:var(--don-accent); display:block; margin-bottom:.75rem;
  }
  .don-h1 {
    font-family:var(--don-head); font-weight:800;
    font-size:clamp(2.6rem,6vw,4.5rem); line-height:1.07; color:#fff; margin-bottom:1.25rem;
  }
  .don-h2 {
    font-family:var(--don-head); font-weight:800;
    font-size:clamp(1.7rem,3vw,2.3rem); line-height:1.15; color:#111; margin-bottom:.5rem;
  }
  .don-accent { color:var(--don-accent); }
  .don-deco-num {
    position:absolute; top:3rem; left:-1rem;
    font-family:var(--don-head); font-size:clamp(7rem,15vw,14rem);
    font-weight:900; color:rgba(0,0,0,.035); line-height:1;
    pointer-events:none; user-select:none;
  }

  /* HERO */
  .don-hero {
    position:relative; min-height:65vh; display:flex; align-items:center;
    padding:8rem 0 5rem; overflow:hidden;
  }
  .don-hero-bg {
    position:absolute; inset:0;
    background:
      linear-gradient(to right,rgba(8,21,9,.54) 0%,rgba(8,21,9,.30) 48%,rgba(8,21,9,.14) 100%),
      linear-gradient(to bottom,rgba(8,21,9,.10) 0%,rgba(8,21,9,.04) 55%,rgba(8,21,9,.16) 100%),
      url('https://upload.wikimedia.org/wikipedia/commons/thumb/3/3c/Mangroves_%2853575624549%29.jpg/3840px-Mangroves_%2853575624549%29.jpg') center/cover no-repeat;
    transform:scale(1.02);
  }
  .don-hero-card {
    width:min(760px,100%);
    background:linear-gradient(145deg, rgba(7,22,10,.46) 0%, rgba(7,22,10,.24) 100%);
    border:1px solid rgba(255,255,255,.14);
    box-shadow:0 24px 60px rgba(0,0,0,.22);
    backdrop-filter:blur(8px) saturate(1.08);
    -webkit-backdrop-filter:blur(8px) saturate(1.08);
    padding:clamp(1.5rem,3vw,2.5rem);
  }
  .don-breadcrumb {
    display:flex; gap:.5rem; align-items:center;
    font-size:.8rem; color:rgba(255,255,255,.4); margin-bottom:1.5rem;
  }
  .don-breadcrumb a { color:rgba(255,255,255,.4); text-decoration:none; }
  .don-breadcrumb a:hover { color:var(--don-accent); }
  .don-hero-sub { color:rgba(255,255,255,.90); font-size:1.08rem; max-width:560px; line-height:1.75; margin-bottom:1.5rem; text-shadow:0 2px 14px rgba(0,0,0,.18); }
  .don-badge {
    display:inline-flex; align-items:center; gap:.5rem;
    background:rgba(245,158,11,.16); border:1px solid rgba(245,158,11,.34);
    color:rgba(255,232,193,.95); font-size:.78rem; font-weight:600; padding:.5rem 1rem;
  }
  .don-badge svg { width:.9rem; height:.9rem; fill:var(--don-accent); flex-shrink:0; }
  .don-scroll { position:absolute; bottom:2rem; left:50%; transform:translateX(-50%); }
  .don-scroll span {
    display:block; width:1px; height:60px;
    background:linear-gradient(to bottom,rgba(245,158,11,.8),transparent);
    animation:dscroll 1.8s ease-in-out infinite;
  }
  @keyframes dscroll {
    0%{transform:scaleY(0);transform-origin:top} 50%{transform:scaleY(1);transform-origin:top}
    51%{transform:scaleY(1);transform-origin:bottom} 100%{transform:scaleY(0);transform-origin:bottom}
  }

  /* ── CAMPAIGN STRIP ── */
  .don-campaign-strip {
    position: relative; overflow: hidden;
    padding: 4rem 0; color: #fff;
  }
  .don-campaign-strip-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right, rgba(8,21,9,0.62) 0%, rgba(8,21,9,0.48) 50%, rgba(8,21,9,0.32) 100%),
      url('https://upload.wikimedia.org/wikipedia/commons/thumb/3/3c/Mangroves_%2853575624549%29.jpg/3840px-Mangroves_%2853575624549%29.jpg') center/cover no-repeat;
  }
  .don-campaign-inner {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr auto 1fr;
    gap: 3rem; align-items: center;
  }
  .don-campaign-date {
    display: inline-block; color: var(--don-accent);
    font-size: .65rem; font-weight: 800;
    letter-spacing: .22em; text-transform: uppercase;
    background: rgba(245,158,11,.12);
    border: 1px solid rgba(245,158,11,.3);
    padding: .3rem .75rem; margin-bottom: 1rem;
  }
  .don-campaign-title {
    font-family: var(--don-head); font-weight: 800;
    font-size: clamp(1.4rem,2.5vw,2rem);
    line-height: 1.15; margin-bottom: .75rem; color: #fff;
  }
  .don-campaign-desc {
    color: rgba(255,255,255,.6); font-size: .88rem;
    line-height: 1.7; margin-bottom: 1.5rem;
  }
  .don-progress-wrap { margin-top: .5rem; }
  .don-progress-bar {
    height: 6px; background: rgba(255,255,255,.12);
    border-radius: 3px; overflow: hidden; margin-bottom: .6rem;
  }
  .don-progress-fill {
    height: 100%; background: var(--don-accent);
    border-radius: 3px;
  }
  .don-progress-labels {
    display: flex; justify-content: space-between;
    font-size: .68rem; font-weight: 700;
  }
  .don-progress-pct { color: var(--don-accent); }
  .don-progress-goal { color: rgba(255,255,255,.4); }
  .don-campaign-divider {
    width: 1px; height: 180px;
    background: linear-gradient(to bottom, transparent, rgba(245,158,11,.4) 30%, rgba(245,158,11,.4) 70%, transparent);
  }
  .don-campaign-right { display: flex; flex-direction: column; gap: 1.25rem; }
  .don-campaign-metrics {
    display: grid; grid-template-columns: repeat(3,1fr); gap: .75rem;
  }
  .don-metric {
    text-align: center; padding: .85rem .5rem;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.08); border-radius: 6px;
  }
  .don-metric strong {
    display: block; color: var(--don-accent);
    font-family: var(--don-head); font-size: 1.2rem;
    font-weight: 800; line-height: 1;
  }
  .don-metric span {
    display: block; margin-top: .3rem;
    color: rgba(255,255,255,.45);
    font-size: .58rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase;
  }
  .don-countdown-card { }
  .don-countdown-label {
    font-size: .6rem; font-weight: 800; letter-spacing: .15em;
    text-transform: uppercase; color: rgba(255,255,255,.45);
    margin-bottom: .5rem;
  }
  .don-countdown-grid {
    display: grid; grid-template-columns: repeat(4,1fr); gap: .4rem;
  }
  .don-countdown-unit {
    padding: .6rem .25rem; text-align: center;
    background: rgba(0,0,0,.2);
    border: 1px solid rgba(245,158,11,.18); border-radius: 4px;
  }
  .don-countdown-unit strong { color: #fff; font-size: 1.1rem; font-weight: 800; }
  .don-countdown-unit small {
    display: block; margin-top: .25rem; color: var(--don-accent);
    font-size: .5rem; font-weight: 800;
    letter-spacing: .1em; text-transform: uppercase;
  }
  .don-campaign-cta {
    display: block; text-align: center;
    background: var(--don-accent); color: #fff;
    font-weight: 700; font-size: .8rem; padding: .75rem;
    text-decoration: none; text-transform: uppercase;
    letter-spacing: .1em; border-radius: 4px;
    transition: background .2s;
  }
  .don-campaign-cta:hover { background: #d97706; }
  @media(max-width:900px){
    .don-campaign-inner { grid-template-columns: 1fr; gap: 2rem; }
    .don-campaign-divider { display: none; }
  }
  @media(max-width:560px){
    .don-campaign-metrics { grid-template-columns: repeat(3,1fr); }
    .don-countdown-grid { grid-template-columns: repeat(2,minmax(0,1fr)); }
  }

  /* SPLIT */
  .don-split {
    display:grid; grid-template-columns:1.1fr 1fr; gap:4rem; align-items:start;
  }
  @media(max-width:900px){ .don-split{ grid-template-columns:1fr; gap:3rem; } }

  /* FORM */
  .don-form-sub { color:#888; font-size:.88rem; margin-bottom:1.75rem; }
  .don-form-card {
    background:#fff; box-shadow:var(--don-shadow);
    border-top:3px solid var(--don-accent); overflow:hidden;
  }
  .don-amounts-section { padding:1.5rem; border-bottom:1px solid #f0f0f0; }
  .don-amounts-label { font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:.15em; color:#aaa; margin-bottom:.85rem; }
  .don-amounts-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:.5rem; }
  .amount-btn {
    display:flex; flex-direction:column; align-items:center;
    padding:.9rem .25rem; border:1.5px solid #e5e7eb;
    background:#fff; cursor:pointer; transition:all .2s;
  }
  .amount-btn:hover { border-color:var(--don-accent); }
  .amount-btn.selected { background:var(--don-accent); border-color:var(--don-accent); }
  .don-amt-val { font-family:var(--don-head); font-size:1.1rem; font-weight:800; color:#111; transition:color .2s; }
  .don-amt-cur { font-size:.6rem; color:#aaa; transition:color .2s; }
  .amount-btn.selected .don-amt-val,
  .amount-btn.selected .don-amt-cur { color:#fff; }

  .don-custom-section { padding:1.25rem 1.5rem; background:#fafafa; border-bottom:1px solid #f0f0f0; }
  .don-custom-row { display:flex; align-items:center; gap:.75rem; }
  .don-custom-sym { font-family:var(--don-head); font-size:1.5rem; font-weight:800; color:#ccc; }
  .don-custom-row input {
    flex:1; border:1.5px solid #e5e7eb; padding:.6rem 1rem;
    font-family:var(--don-head); font-size:1.4rem; font-weight:700; color:#111;
    outline:none; transition:border-color .2s; background:#fff;
  }
  .don-custom-row input:focus { border-color:var(--don-accent); }
  .don-custom-cur { font-size:.85rem; font-weight:600; color:#aaa; }

  .don-summary { padding:1.5rem; }
  .don-total-row { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:1.25rem; }
  .don-total-label { font-size:.72rem; color:#aaa; text-transform:uppercase; letter-spacing:.1em; }
  .don-total-val { font-family:var(--don-head); font-size:2.5rem; font-weight:800; color:#111; line-height:1; }
  .don-processor { font-size:.78rem; font-weight:700; color:#555; }

  .don-pay-btn {
    width:100%; display:flex; align-items:center; justify-content:center; gap:.6rem;
    background:var(--don-accent); color:#fff; border:none; cursor:pointer;
    font-weight:700; font-size:.9rem; padding:1rem;
    text-transform:uppercase; letter-spacing:.08em; transition:background .2s;
  }
  .don-pay-btn:disabled { background:#e5e7eb; color:#aaa; cursor:not-allowed; }
  .don-pay-btn:not(:disabled):hover { background:#d97706; }
  .don-pay-btn svg { width:1.1rem; height:1.1rem; flex-shrink:0; }
  .don-spin { animation:spin 1s linear infinite; }
  @keyframes spin { to{ transform:rotate(360deg); } }
  .don-error { color:#ef4444; font-size:.83rem; text-align:center; margin-top:.75rem; font-weight:600; }
  .don-trust {
    display:flex; align-items:center; justify-content:center; gap:.5rem;
    flex-wrap:wrap; margin-top:.85rem; font-size:.68rem; color:#bbb;
  }
  .don-trust span { display:flex; align-items:center; gap:.25rem; }
  .don-trust svg { width:.85rem; height:.85rem; stroke:#22c55e; }

  /* IMPACTS */
  .don-form-col > .don-eyebrow,
  .don-form-col > .don-h2,
  .don-form-col > .don-form-sub { margin-bottom:.3rem; }
  .don-impacts { display:flex; flex-direction:column; gap:.6rem; margin:1.5rem 0; }
  .don-impact-card {
    background:#fff; border:1.5px solid #eee; padding:1rem 1.25rem;
    cursor:pointer; transition:all .2s; border-left:3px solid transparent;
  }
  .don-impact-card:hover { border-left-color:var(--don-accent); }
  .don-impact-card.selected { border-color:var(--don-accent); background:#fffbeb; border-left-color:var(--don-accent); }
  .don-impact-head { display:flex; align-items:baseline; gap:.75rem; margin-bottom:.25rem; }
  .don-impact-amount { font-family:var(--don-head); font-size:1.2rem; font-weight:800; color:var(--don-accent); }
  .don-impact-title { font-weight:700; font-size:.85rem; color:#111; }
  .don-impact-desc { font-size:.78rem; color:#888; line-height:1.55; }

  .don-transfer {
    background:var(--don-forest); padding:1.5rem;
    border-left:3px solid var(--don-accent);
  }
  .don-transfer-head { display:flex; align-items:center; gap:1rem; margin-bottom:1rem; }
  .don-transfer-head svg { width:1.5rem; height:1.5rem; stroke:var(--don-accent); flex-shrink:0; }
  .don-transfer-head h3 { font-family:var(--don-head); font-size:.95rem; font-weight:700; color:#fff; }
  .don-transfer-head p { font-size:.72rem; color:rgba(255,255,255,.45); }
  .don-transfer-btn {
    display:block; text-align:center; background:var(--don-accent); color:#fff;
    font-weight:700; font-size:.78rem; padding:.7rem;
    text-decoration:none; text-transform:uppercase; letter-spacing:.08em; transition:background .2s;
  }
  .don-transfer-btn:hover { background:#d97706; }

  /* QUOTE */
  .don-quote-section {
    background:
      linear-gradient(rgba(8,21,9,.50),rgba(8,21,9,.50)),
      url('/images/voluntaria-plantando.jpg') center/cover no-repeat fixed;
    padding:6rem 0; text-align:center;
  }
  .don-quote-icon { width:2.5rem; height:2.5rem; color:var(--don-accent); opacity:.7; margin:0 auto 1.5rem; display:block; }
  .don-quote {
    font-family:var(--don-head); font-size:clamp(1.1rem,2.5vw,1.6rem);
    font-weight:700; color:#fff; line-height:1.5;
    max-width:700px; margin:0 auto 1.5rem;
  }
  .don-quote-divider { width:3rem; height:3px; background:var(--don-accent); margin:0 auto 1.25rem; }
  .don-quote-author { font-weight:700; color:var(--don-accent); font-size:.9rem; }
  .don-quote-role { color:rgba(255,255,255,.4); font-size:.78rem; margin-top:.2rem; }

  /* TRANSPARENCIA + WAYS */
  .don-transparency {
    display:flex; gap:1rem; align-items:flex-start;
    background:#fffbeb; border:1.5px solid rgba(245,158,11,.3);
    padding:1.25rem 1.5rem; margin-bottom:3rem;
  }
  .don-transparency svg { width:1.2rem; height:1.2rem; stroke:var(--don-accent); flex-shrink:0; margin-top:.15rem; }
  .don-transparency p { font-size:.88rem; color:#92400e; line-height:1.65; }
  .don-transparency a { color:#92400e; font-weight:700; }

  .don-ways-grid {
    display:grid; grid-template-columns:repeat(3,1fr);
    gap:1.5px; background:#e0e0e0;
  }
  @media(max-width:700px){ .don-ways-grid{ grid-template-columns:1fr; } }
  .don-way-card {
    background:#fff; padding:2rem 1.75rem;
    display:flex; flex-direction:column; gap:.5rem;
    transition:transform .3s;
  }
  .don-way-card:hover { transform:translateY(-3px); z-index:1; box-shadow:var(--don-shadow); }
  .don-way-num { font-size:.65rem; font-weight:800; color:var(--don-accent); letter-spacing:.2em; }
  .don-way-title { font-family:var(--don-head); font-size:1rem; font-weight:700; color:#111; }
  .don-way-desc { font-size:.83rem; color:#777; line-height:1.65; flex:1; }
  .don-way-link {
    display:inline-block; color:var(--don-accent); font-weight:700;
    font-size:.78rem; text-decoration:none; text-transform:uppercase;
    letter-spacing:.08em; margin-top:.5rem; transition:letter-spacing .2s;
  }
  .don-way-link:hover { letter-spacing:.12em; }

  .hidden { display:none !important; }
  @media(max-width:640px){
    .don-hero{ min-height:auto; padding:6rem 0 4rem; }
    .don-amounts-grid{ grid-template-columns:repeat(3,1fr); }
  }
</style>

<script>
  const amountBtns   = document.querySelectorAll<HTMLButtonElement>('.amount-btn');
  const impactCards  = document.querySelectorAll<HTMLElement>('.impact-card');
  const customInput  = document.getElementById('custom-input') as HTMLInputElement;
  const amountDisplay= document.getElementById('amount-display') as HTMLElement;
  const wompiBtn     = document.getElementById('wompi-btn') as HTMLButtonElement;
  const wompiLabel   = document.getElementById('wompi-label') as HTMLSpanElement;
  const wompiIcon    = document.getElementById('wompi-icon') as SVGElement;
  const wompiSpinner = document.getElementById('wompi-spinner') as SVGElement;
  const wompiError   = document.getElementById('wompi-error') as HTMLParagraphElement;
  let selectedAmount: number | null = null;

  function updateUI(amount: number | null) {
    selectedAmount = amount;
    if (amount && amount >= 1) {
      amountDisplay.textContent = `$${amount % 1 === 0 ? amount : amount.toFixed(2)}`;
      wompiBtn.disabled = false;
      wompiLabel.textContent = `Donar $${amount % 1 === 0 ? amount : amount.toFixed(2)} con Wompi`;
    } else {
      amountDisplay.textContent = '$0.00';
      wompiBtn.disabled = true;
      wompiLabel.textContent = 'Selecciona un monto para continuar';
    }
    wompiError.classList.add('hidden');
  }

  amountBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      amountBtns.forEach(b => b.classList.remove('selected'));
      impactCards.forEach(c => c.classList.remove('selected'));
      btn.classList.add('selected');
      customInput.value = '';
      const amount = Number(btn.dataset.amount);
      impactCards.forEach(c => { if (Number(c.dataset.amount) === amount) c.classList.add('selected'); });
      updateUI(amount);
    });
  });

  customInput.addEventListener('input', () => {
    amountBtns.forEach(b => b.classList.remove('selected'));
    impactCards.forEach(c => c.classList.remove('selected'));
    const val = parseFloat(customInput.value);
    updateUI(isNaN(val) ? null : val);
  });

  impactCards.forEach(card => {
    card.addEventListener('click', () => {
      const amount = Number(card.dataset.amount);
      customInput.value = '';
      amountBtns.forEach(b => b.classList.toggle('selected', Number(b.dataset.amount) === amount));
      impactCards.forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      updateUI(amount);
      document.getElementById('donar-monto')?.scrollIntoView({ behavior:'smooth' });
    });
  });

  const initialAmount = Number(new URLSearchParams(window.location.search).get('monto'));
  const heroCampaignRoot = document.querySelector<HTMLElement>('.don-hero');
  if (heroCampaignRoot) {
    const dateLong = heroCampaignRoot.dataset.campaignDateLong;
    const title = heroCampaignRoot.dataset.campaignTitle;
    const description = heroCampaignRoot.dataset.campaignDescription;
    const goalLabel = heroCampaignRoot.dataset.campaignGoalLabel;
    const unitLabel = heroCampaignRoot.dataset.campaignUnitLabel;
    const suggestedAmount = heroCampaignRoot.dataset.campaignSuggestedAmount;
    const progressPercent = heroCampaignRoot.dataset.campaignProgressPercent;
    const campaignSlug = heroCampaignRoot.dataset.campaignSlug;
    const eyebrowEl = heroCampaignRoot.querySelector<HTMLElement>('.don-eyebrow');
    const accentEl = heroCampaignRoot.querySelector<HTMLElement>('.don-accent');
    const heroSubEl = heroCampaignRoot.querySelector<HTMLElement>('.don-hero-sub');
    const stripEl = document.querySelector<HTMLElement>('.don-campaign-strip');

    if (eyebrowEl && dateLong) eyebrowEl.textContent = `Campaña activa · ${dateLong}`;
    if (accentEl && title) accentEl.textContent = title;
    if (heroSubEl && description) heroSubEl.textContent = description;

    if (stripEl) {
      const stripParagraph = stripEl.querySelector<HTMLElement>('.don-campaign-grid p');
      const metricBlocks = stripEl.querySelectorAll<HTMLElement>('.don-campaign-metrics div');
      if (stripParagraph && description) stripParagraph.textContent = description;
      if (metricBlocks[0] && goalLabel) {
        const strong = metricBlocks[0].querySelector('strong');
        const span = metricBlocks[0].querySelector('span');
        if (strong) strong.textContent = goalLabel;
        if (span && unitLabel) span.textContent = unitLabel;
      }
      if (metricBlocks[1] && suggestedAmount) {
        const strong = metricBlocks[1].querySelector('strong');
        if (strong) strong.textContent = `$${suggestedAmount}`;
      }
      if (metricBlocks[2] && progressPercent) {
        const status = metricBlocks[2].querySelector('.don-countdown-label');
        if (status) status.textContent = `${progressPercent}% activo`;
      }
    }

    const amountLinks = document.querySelectorAll<HTMLElement>('.amount-btn');
    amountLinks.forEach((button) => {
      const amount = button.getAttribute('data-amount');
      if (!amount || !campaignSlug) return;
      button.setAttribute('data-campaign', campaignSlug);
    });
  }

  function initDonateCountdown() {
    document.querySelectorAll<HTMLElement>('.don-countdown').forEach((root) => {
      const endsAt = root.dataset.countdown;
      if (!endsAt) return;
      const endMs = new Date(endsAt).getTime();
      if (Number.isNaN(endMs)) return;

      const daysEl = root.querySelector<HTMLElement>('[data-unit="days"]');
      const hoursEl = root.querySelector<HTMLElement>('[data-unit="hours"]');
      const minutesEl = root.querySelector<HTMLElement>('[data-unit="minutes"]');
      const secondsEl = root.querySelector<HTMLElement>('[data-unit="seconds"]');

      const paint = () => {
        const diff = Math.max(0, endMs - Date.now());
        const totalSeconds = Math.floor(diff / 1000);
        const days = Math.floor(totalSeconds / 86400);
        const hours = Math.floor((totalSeconds % 86400) / 3600);
        const minutes = Math.floor((totalSeconds % 3600) / 60);
        const seconds = totalSeconds % 60;
        if (daysEl) daysEl.textContent = String(days);
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
      };

      paint();
      window.setInterval(paint, 1000);
    });
  }

  if (initialAmount && initialAmount >= 1) {
    const matchingButton = Array.from(amountBtns).find(btn => Number(btn.dataset.amount) === initialAmount);
    if (matchingButton) {
      matchingButton.click();
    } else {
      customInput.value = String(initialAmount);
      updateUI(initialAmount);
    }
  }

  wompiBtn.addEventListener('click', async () => {
    if (!selectedAmount || selectedAmount < 1) return;
    wompiBtn.disabled = true;
    wompiIcon.classList.add('hidden');
    wompiSpinner.classList.remove('hidden');
    wompiLabel.textContent = 'Redirigiendo a Wompi...';
    wompiError.classList.add('hidden');
    try {
      const res  = await fetch('/api/checkout-wompi', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ amount: selectedAmount }),
      });
      const data = await res.json();
      if (!res.ok || !data.url) throw new Error(data.error ?? 'Error');
      window.location.href = data.url;
    } catch {
      wompiError.textContent = 'No pudimos procesar tu donación. Intenta de nuevo.';
      wompiError.classList.remove('hidden');
      wompiBtn.disabled = false;
      wompiIcon.classList.remove('hidden');
      wompiSpinner.classList.add('hidden');
      wompiLabel.textContent = `Donar $${selectedAmount} con Wompi`;
    }
  });

  initDonateCountdown();
</script>
