---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="¡Gracias!" description="Gracias por apoyar a Fundación ASISTEDCOS.">

  <!-- Estado: contacto (default) -->
  <section id="state-contacto" class="min-h-[70vh] flex items-center justify-center bg-gray-50">
    <div class="text-center max-w-lg mx-auto px-4">
      <div class="w-20 h-20 bg-verde-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="h-10 w-10 text-verde-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="font-heading text-3xl font-bold text-verde-900 mb-3">¡Gracias por escribirnos!</h1>
      <p class="text-gray-500 mb-8">Hemos recibido tu mensaje y te responderemos a la brevedad posible.</p>
      <a href="/" class="inline-flex items-center gap-2 bg-verde-600 hover:bg-verde-700 text-white font-semibold px-8 py-3 rounded-full transition-colors">
        Volver al inicio
      </a>
    </div>
  </section>

  <!-- Estado: donación exitosa -->
  <section id="state-donacion" class="hidden">

    <!-- Hero de celebración -->
    <div class="relative bg-verde-700 overflow-hidden py-24">
      <div class="absolute inset-0">
        <img src="/images/reforestacion-aerea.jpg" alt="" class="w-full h-full object-cover opacity-20" />
      </div>
      <!-- Confetti particles decorativos -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        {Array.from({length: 12}).map((_, i) => (
          <div
            class={`absolute w-3 h-3 rounded-full opacity-60 animate-bounce`}
            style={`
              background: ${['#f59e0b','#10b981','#f59e0b','#34d399','#fbbf24'][i % 5]};
              left: ${8 + i * 7.5}%;
              top: ${10 + (i % 4) * 20}%;
              animation-delay: ${i * 0.15}s;
              animation-duration: ${1.2 + (i % 3) * 0.3}s;
            `}
          />
        ))}
      </div>

      <div class="relative max-w-3xl mx-auto px-4 text-center">
        <!-- Icono corazón animado -->
        <div class="inline-flex items-center justify-center w-28 h-28 rounded-full bg-amber-500 shadow-2xl mb-8 animate-pulse">
          <svg class="h-14 w-14 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
          </svg>
        </div>

        <span class="inline-block text-amber-400 font-bold text-sm uppercase tracking-widest mb-3">Donación confirmada</span>
        <h1 class="font-heading text-4xl md:text-6xl font-extrabold text-white mb-4 leading-tight">
          ¡Muchas gracias<br/>por tu generosidad!
        </h1>
        <p class="text-verde-100 text-lg md:text-xl max-w-xl mx-auto">
          Tu donación llegará directamente al campo. Estás ayudando a restaurar ecosistemas y transformar comunidades en El Salvador.
        </p>
      </div>
    </div>

    <!-- Impacto de tu donación -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="text-amber-500 font-bold text-sm uppercase tracking-wider">Lo que lograste hoy</span>
        <h2 class="font-heading text-2xl md:text-3xl font-extrabold text-verde-900 mt-2 mb-10">Tu donación en acción</h2>

        <div class="grid sm:grid-cols-3 gap-6 mb-12">
          {[
            { icon: '🌱', titulo: 'Plántulas nativas', desc: 'Que llegarán a manos de familias rurales para reforestar sus terrenos.' },
            { icon: '💧', titulo: 'Agua protegida', desc: 'Tu aporte contribuye al monitoreo de cuencas hidrográficas para comunidades.' },
            { icon: '🌍', titulo: 'CO₂ capturado', desc: 'Cada árbol plantado ayuda a mitigar el cambio climático en El Salvador.' },
          ].map(item => (
            <div class="bg-gray-50 rounded-lg border border-gray-100 p-6 hover:shadow-md transition-shadow">
              <div class="text-4xl mb-3">{item.icon}</div>
              <p class="font-heading font-extrabold text-verde-900 mb-2">{item.titulo}</p>
              <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>

        <!-- Mensaje personalizado -->
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-10 max-w-2xl mx-auto">
          <svg class="h-6 w-6 text-amber-500 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <p class="text-amber-800 text-sm leading-relaxed">
            <strong>Recibirás un recibo por correo electrónico</strong> con los detalles de tu donación, válido para deducción fiscal según el Art. 32 de la Ley de Renta de El Salvador.
          </p>
        </div>

        <!-- Comparte -->
        <div class="mb-10">
          <p class="text-gray-500 text-sm mb-4 font-semibold">Comparte y multiplica el impacto</p>
          <div class="flex justify-center gap-3 flex-wrap">
            <a
              href="https://www.facebook.com/sharer/sharer.php?u=https://asistedcosong.vercel.app"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2.5 rounded-sm text-sm transition-colors"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Compartir en Facebook
            </a>
            <a
              href="https://wa.me/?text=Acabo%20de%20donar%20a%20Fundaci%C3%B3n%20ASISTEDCOS%20para%20reforestar%20El%20Salvador.%20%C3%BAnete%20t%C3%BA%20tambi%C3%A9n%3A%20https://asistedcosong.vercel.app/donar"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-semibold px-5 py-2.5 rounded-sm text-sm transition-colors"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
              Compartir por WhatsApp
            </a>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="inline-flex items-center justify-center gap-2 bg-verde-700 hover:bg-verde-800 text-white font-bold px-8 py-4 rounded-sm transition-colors">
            Volver al inicio
          </a>
          <a href="/proyectos" class="inline-flex items-center justify-center gap-2 border-2 border-verde-700 text-verde-700 hover:bg-verde-700 hover:text-white font-bold px-8 py-4 rounded-sm transition-colors">
            Ver nuestros proyectos
          </a>
        </div>
      </div>
    </section>

  </section>

</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('donated') === 'true') {
    document.getElementById('state-contacto')!.classList.add('hidden');
    document.getElementById('state-donacion')!.classList.remove('hidden');
  }
</script>
