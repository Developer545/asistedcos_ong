---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="¡Gracias!" description="Gracias por apoyar a Fundación ASISTEDCOS.">
  <section id="state-contacto" class="thanks-contact">
    <div class="thanks-contact-card">
      <div class="thanks-contact-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1>¡Gracias por escribirnos!</h1>
      <p>Hemos recibido tu mensaje y te responderemos a la brevedad posible.</p>
      <a href="/" class="thanks-contact-btn">Volver al inicio</a>
    </div>
  </section>

  <section id="state-donacion" class="thanks-page hidden">
    <div class="thanks-hero">
      <div class="thanks-hero-media" aria-hidden="true">
        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/3/3c/Mangroves_%2853575624549%29.jpg/3840px-Mangroves_%2853575624549%29.jpg" alt="" loading="eager" />
      </div>

      <div class="thanks-shell">
        <div class="thanks-grid">
          <div class="thanks-copy">
            <p class="thanks-eyebrow">Donación confirmada</p>
            <h1 class="thanks-title">Tu aporte ya es parte de la restauración</h1>
            <p class="thanks-sub">
              Gracias por sumarte a Fundación ASISTEDCOS. Tu donación nos acerca a proteger manglares, fortalecer comunidades costeras y sembrar futuro en El Salvador.
            </p>

            <div class="thanks-actions">
              <a href="/proyectos" class="thanks-btn">Ver proyectos</a>
              <a href="/donar" class="thanks-btn thanks-btn-ghost">Donar de nuevo</a>
            </div>
          </div>

          <aside class="thanks-panel">
            <div class="thanks-panel-head">
              <strong>Pago exitoso</strong>
            </div>

            <div class="thanks-panel-grid">
              <div>
                <span>Estado</span>
                <strong>Confirmado</strong>
              </div>
              <div>
                <span>Campaña</span>
                <strong>1 Millón</strong>
              </div>
            </div>

            <div class="thanks-detail-list">
              <div class="thanks-detail-item">
                <span>Referencia</span>
                <strong id="thanks-ref">Se generará al confirmar</strong>
              </div>
              <div class="thanks-detail-item">
                <span>Transacción</span>
                <strong id="thanks-tx">Se generará al confirmar</strong>
              </div>
              <div class="thanks-detail-item">
                <span>Comprobante</span>
                <strong>Recibirás confirmación por correo</strong>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>

    <div class="thanks-body">
      <div class="thanks-shell">
        <div class="thanks-summary">
          <div class="thanks-summary-text">
            <p class="thanks-eyebrow thanks-eyebrow-dark">Lo que activaste hoy</p>
            <h2>Tu apoyo se convierte en acciones visibles en territorio</h2>
            <p>
              Cada donación impulsa plántulas, logística, jornadas comunitarias y seguimiento técnico. Esto no se queda en promesas: se convierte en trabajo real sobre la costa salvadoreña.
            </p>
          </div>

          <div class="thanks-impact-grid">
            <article class="thanks-impact-card">
              <div class="thanks-impact-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 22V12m0 0C12 7 8 4 4 5c0 4 3 7 8 7zm0 0c0-5 4-8 8-7-1 4-4 7-8 7" />
                </svg>
              </div>
              <h3>Viveros y plántulas</h3>
              <p>Preparación de mangles nativos para restauración y siembra comunitaria.</p>
            </article>

            <article class="thanks-impact-card">
              <div class="thanks-impact-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 19c2.5-4 5.5-6 8-6s5.5 2 8 6M5 9c1.5 2 3.8 3 7 3s5.5-1 7-3M12 4v15" />
                </svg>
              </div>
              <h3>Jornadas en costa</h3>
              <p>Movilización, herramientas y acompañamiento para sembrar en campo.</p>
            </article>

            <article class="thanks-impact-card">
              <div class="thanks-impact-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M12 3a15.3 15.3 0 014 9 15.3 15.3 0 01-4 9 15.3 15.3 0 01-4-9 15.3 15.3 0 014-9z" />
                </svg>
              </div>
              <h3>Protección costera</h3>
              <p>Manglares más fuertes significan ecosistemas más vivos y comunidades más resilientes.</p>
            </article>
          </div>
        </div>

        <div class="thanks-bottom">
          <div class="thanks-receipt">
            <h3>Revisa tu correo</h3>
            <p>Recibirás el comprobante de tu donación. Si necesitas respaldo fiscal, nuestro equipo puede apoyarte con el proceso.</p>
            <a href="mailto:info@asistedcos.org">info@asistedcos.org</a>
          </div>

          <div class="thanks-share">
            <h3>Multiplica el impacto</h3>
            <p>Comparte tu donación e invita a más personas a sumarse a esta causa.</p>
            <div class="thanks-share-actions">
              <a
                href="https://www.facebook.com/sharer/sharer.php?u=https://asistedcosong.vercel.app"
                target="_blank"
                rel="noopener noreferrer"
                class="thanks-share-btn"
              >
                Facebook
              </a>
              <a
                href="https://wa.me/?text=Acabo%20de%20donar%20a%20Fundaci%C3%B3n%20ASISTEDCOS%20para%20restaurar%20manglares.%20S%C3%BAmate%20aqu%C3%AD:%20https://asistedcosong.vercel.app/donar"
                target="_blank"
                rel="noopener noreferrer"
                class="thanks-share-btn thanks-share-btn-wa"
              >
                WhatsApp
              </a>
            </div>
          </div>
        </div>

        <div class="thanks-footer">
          <img src="/images/logo.png" alt="ASISTEDCOS" />
          <p>Fundación ASISTEDCOS · El Salvador · Desde 1997</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root {
    --thanks-accent: #f59e0b;
    --thanks-dark: #081509;
    --thanks-ink: #111111;
    --thanks-muted: #6b7280;
    --thanks-shell: min(1180px, calc(100% - 3rem));
  }

  .hidden { display: none !important; }

  .thanks-contact {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
    padding: 2rem 1.5rem;
  }
  .thanks-contact-card {
    width: min(560px, 100%);
    background: #fff;
    border-top: 4px solid var(--thanks-accent);
    box-shadow: 0 20px 60px rgba(17, 24, 39, 0.08);
    padding: 3rem 2rem;
    text-align: center;
  }
  .thanks-contact-icon {
    width: 5rem;
    height: 5rem;
    margin: 0 auto 1.5rem;
    border-radius: 999px;
    background: rgba(22, 163, 74, 0.12);
    color: #15803d;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .thanks-contact-icon svg { width: 2rem; height: 2rem; }
  .thanks-contact-card h1 {
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 800;
    color: var(--thanks-dark);
    margin-bottom: 0.8rem;
  }
  .thanks-contact-card p {
    color: var(--thanks-muted);
    line-height: 1.75;
    margin-bottom: 1.8rem;
  }
  .thanks-contact-btn {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    background: var(--thanks-dark);
    color: #fff;
    padding: 0.95rem 1.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .thanks-page {
    background: #f4f4f1;
  }
  .thanks-shell {
    width: var(--thanks-shell);
    margin: 0 auto;
  }

  .thanks-hero {
    position: relative;
    overflow: hidden;
    padding: 8rem 0 5rem;
    min-height: 76vh;
  }
  .thanks-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(8,21,9,0.72) 0%, rgba(8,21,9,0.42) 44%, rgba(8,21,9,0.10) 100%),
      linear-gradient(180deg, rgba(8,21,9,0.08) 0%, rgba(8,21,9,0.03) 55%, rgba(8,21,9,0.18) 100%);
    z-index: 1;
  }
  .thanks-hero-media {
    position: absolute;
    inset: 0;
  }
  .thanks-hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    filter: saturate(1.12) contrast(1.03) brightness(1.04);
  }
  .thanks-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.78fr);
    gap: 3rem;
    align-items: center;
  }
  .thanks-copy {
    max-width: 640px;
  }
  .thanks-eyebrow {
    display: block;
    margin-bottom: 0.9rem;
    color: rgba(245,158,11,0.9);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.74rem;
    font-weight: 800;
  }
  .thanks-eyebrow-dark {
    color: var(--thanks-accent);
  }
  .thanks-title {
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: clamp(2.7rem, 6vw, 5.25rem);
    line-height: 1.02;
    font-weight: 800;
    color: #fff;
    max-width: 700px;
    margin-bottom: 1.25rem;
  }
  .thanks-sub {
    max-width: 560px;
    color: rgba(255,255,255,0.76);
    line-height: 1.78;
    font-size: 1.02rem;
    margin-bottom: 2rem;
  }
  .thanks-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .thanks-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 190px;
    padding: 1rem 1.4rem;
    background: var(--thanks-accent);
    color: #fff;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 2px solid var(--thanks-accent);
    transition: 0.2s ease;
  }
  .thanks-btn:hover {
    background: #d97706;
    border-color: #d97706;
  }
  .thanks-btn-ghost {
    background: transparent;
    border-color: rgba(255,255,255,0.28);
    color: #fff;
  }
  .thanks-btn-ghost:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.42);
  }

  .thanks-panel {
    position: relative;
    isolation: isolate;
    background: linear-gradient(145deg, rgba(13,31,16,0.54) 0%, rgba(6,13,8,0.34) 58%, rgba(28,19,7,0.42) 100%);
    backdrop-filter: blur(7px) saturate(1.08);
    -webkit-backdrop-filter: blur(7px) saturate(1.08);
    color: #fff;
    padding: 2rem;
    border-top: 4px solid var(--thanks-accent);
    border-right: 1px solid rgba(245,158,11,0.18);
    border-bottom: 1px solid rgba(245,158,11,0.14);
    border-left: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 24px 70px rgba(0,0,0,0.36);
  }
  .thanks-panel-grid span,
  .thanks-detail-item span {
    display: block;
    color: rgba(255,255,255,0.48);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.68rem;
    font-weight: 800;
  }
  .thanks-panel-head strong {
    display: block;
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
    color: #fff;
  }
  .thanks-panel-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    margin: 1.5rem 0;
    background: rgba(255,255,255,0.10);
  }
  .thanks-panel-grid div {
    background: rgba(255,255,255,0.08);
    padding: 1rem 0.9rem;
  }
  .thanks-panel-grid strong {
    display: block;
    margin-top: 0.35rem;
    color: var(--thanks-accent);
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 800;
    font-size: 1rem;
  }
  .thanks-detail-list {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .thanks-detail-item {
    padding: 0.9rem 1rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .thanks-detail-item strong {
    display: block;
    margin-top: 0.35rem;
    color: #fff;
    font-size: 0.92rem;
    line-height: 1.55;
    word-break: break-word;
  }

  .thanks-body {
    padding: 4.5rem 0 5rem;
  }
  .thanks-summary {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 2rem;
    align-items: start;
    margin-bottom: 2.6rem;
  }
  .thanks-summary-text {
    background: transparent;
    padding: 0.4rem 0;
  }
  .thanks-summary-text h2 {
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(1.7rem, 3vw, 2.3rem);
    color: var(--thanks-ink);
    line-height: 1.16;
    margin-bottom: 1rem;
  }
  .thanks-summary-text p {
    color: var(--thanks-muted);
    line-height: 1.78;
    font-size: 0.94rem;
  }
  .thanks-impact-grid {
    background: transparent;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .thanks-impact-card {
    border: 1px solid #e5e7eb;
    background: #fff;
    padding: 1.35rem;
    box-shadow: 0 14px 38px rgba(15, 23, 42, 0.05);
  }
  .thanks-impact-icon {
    width: 2.9rem;
    height: 2.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--thanks-accent);
    border: 1px solid rgba(245,158,11,0.32);
    background: rgba(245,158,11,0.06);
    margin-bottom: 1rem;
  }
  .thanks-impact-icon svg {
    width: 1.35rem;
    height: 1.35rem;
  }
  .thanks-impact-card h3 {
    color: var(--thanks-ink);
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.45rem;
  }
  .thanks-impact-card p {
    color: var(--thanks-muted);
    font-size: 0.84rem;
    line-height: 1.65;
  }

  .thanks-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5px;
    background: #dddcd6;
    margin-bottom: 2.6rem;
  }
  .thanks-receipt,
  .thanks-share {
    background: #fff;
    padding: 2rem;
  }
  .thanks-receipt {
    border-left: 4px solid var(--thanks-accent);
  }
  .thanks-receipt h3,
  .thanks-share h3 {
    font-family: 'Poppins', system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--thanks-ink);
    margin-bottom: 0.45rem;
  }
  .thanks-receipt p,
  .thanks-share p {
    color: var(--thanks-muted);
    line-height: 1.72;
    font-size: 0.86rem;
  }
  .thanks-receipt a {
    display: inline-block;
    margin-top: 0.9rem;
    color: var(--thanks-accent);
    font-weight: 800;
  }
  .thanks-share-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.15rem;
  }
  .thanks-share-btn {
    flex: 1;
    min-width: 150px;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    background: #1877f2;
    color: #fff;
    padding: 0.85rem 1rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .thanks-share-btn-wa {
    background: #25d366;
  }

  .thanks-footer {
    padding-top: 2rem;
    border-top: 1px solid #dfded7;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  .thanks-footer img {
    height: 2rem;
    width: auto;
    opacity: 0.5;
  }
  .thanks-footer p {
    color: #9ca3af;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
  }

  @media (max-width: 900px) {
    .thanks-hero {
      padding: 6.5rem 0 4rem;
      min-height: auto;
    }
    .thanks-grid,
    .thanks-summary,
    .thanks-bottom {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .thanks-shell {
      width: min(100% - 2rem, 1180px);
    }
    .thanks-title {
      font-size: clamp(2.2rem, 12vw, 3.6rem);
    }
    .thanks-actions,
    .thanks-share-actions {
      flex-direction: column;
    }
    .thanks-btn,
    .thanks-share-btn {
      width: 100%;
      min-width: 0;
    }
    .thanks-panel,
    .thanks-summary-text,
    .thanks-impact-grid,
    .thanks-receipt,
    .thanks-share {
      padding: 1.4rem;
    }
    .thanks-panel-grid {
      grid-template-columns: 1fr;
    }
    .thanks-footer {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  const params = new URLSearchParams(window.location.search);
  const isDonationSuccess = params.get('donated') === 'true';

  if (isDonationSuccess) {
    document.getElementById('state-contacto')?.classList.add('hidden');
    document.getElementById('state-donacion')?.classList.remove('hidden');

    const rawRef = params.get('identificadorEnlaceComercio');
    const rawTx = params.get('idTransaccion');

    const refTarget = document.getElementById('thanks-ref');
    const txTarget = document.getElementById('thanks-tx');

    if (refTarget && rawRef) {
      refTarget.textContent = rawRef;
    }

    if (txTarget && rawTx) {
      txTarget.textContent = rawTx.length > 18 ? `${rawTx.slice(0, 18)}...` : rawTx;
      txTarget.title = rawTx;
    }
  }
</script>
