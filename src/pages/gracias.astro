---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="¡Gracias!" description="Gracias por apoyar a Fundación ASISTEDCOS.">

  <!-- Estado: contacto (default) -->
  <section id="state-contacto" class="min-h-[70vh] flex items-center justify-center bg-gray-50">
    <div class="text-center max-w-lg mx-auto px-4">
      <div class="w-20 h-20 bg-verde-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="h-10 w-10 text-verde-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="font-heading text-3xl font-bold text-verde-900 mb-3">¡Gracias por escribirnos!</h1>
      <p class="text-gray-500 mb-8">Hemos recibido tu mensaje y te responderemos a la brevedad posible.</p>
      <a href="/" class="inline-flex items-center gap-2 bg-verde-600 hover:bg-verde-700 text-white font-semibold px-8 py-3 rounded-full transition-colors">
        Volver al inicio
      </a>
    </div>
  </section>

  <!-- Estado: donación exitosa -->
  <section id="state-donacion" class="hidden gr-page">

    <!-- Hero banner -->
    <div class="gr-hero">
      <div class="gr-hero-bg"></div>
      <div class="gr-hero-content">
        <div class="gr-confirmed-badge">
          <svg class="gr-confirmed-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <p class="gr-eyebrow">Donación confirmada</p>
        <h1 class="gr-h1">¡Eres parte<br/>del cambio!</h1>
        <p class="gr-hero-sub">Tu apoyo ya está en camino a las comunidades y ecosistemas de El Salvador.</p>
      </div>
      <div class="gr-scroll" aria-hidden="true"><span></span></div>
    </div>

    <!-- Contenido principal -->
    <div class="gr-body">
      <div class="gr-container">

        <!-- Mensaje de impacto -->
        <div class="gr-message-row">
          <div class="gr-message-text">
            <p class="gr-eyebrow-dark">Tu huella</p>
            <h2 class="gr-h2">Cada árbol que nazca<br/>llevará <span class="gr-accent">tu nombre</span></h2>
            <p class="gr-desc">Tu donación se convierte en plántulas, en cuencas monitoreadas, en familias rurales con ingresos dignos. El Salvador necesita más personas como tú.</p>
          </div>
          <div class="gr-impact-list">
            {[
              {
                label: 'Plántulas hacia comunidades rurales',
                svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22V12m0 0C12 7 8 4 4 5c0 4 3 7 8 7zm0 0c0-5 4-8 8-7-1 4-4 7-8 7"/></svg>`,
                color: '#16a34a'
              },
              {
                label: 'Cuencas monitoreadas y protegidas',
                svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2C6 8 4 12 4 15a8 8 0 0016 0c0-3-2-7-8-13z"/></svg>`,
                color: '#2563eb'
              },
              {
                label: 'CO₂ siendo capturado por la naturaleza',
                svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3a6 6 0 00-6 6c0 3 1.5 4.5 3 6h6c1.5-1.5 3-3 3-6a6 6 0 00-6-6z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 21h6M12 18v3"/></svg>`,
                color: '#f59e0b'
              },
            ].map(item => (
              <div class="gr-impact-item">
                <div class="gr-impact-icon" style={`color:${item.color}; border-color:${item.color}22;`} set:html={item.svg} />
                <p class="gr-impact-label">{item.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Aviso recibo + compartir en dos columnas -->
        <div class="gr-bottom-row">

          <!-- Aviso comprobante -->
          <div class="gr-receipt-card">
            <div class="gr-receipt-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="gr-receipt-title">Revisa tu correo</p>
              <p class="gr-receipt-desc">Recibirás el comprobante de tu donación, válido para deducción fiscal según el <strong>Art. 32 de la Ley de Renta de El Salvador</strong>.</p>
            </div>
          </div>

          <!-- Compartir -->
          <div class="gr-share-card">
            <p class="gr-share-title">Inspira a otros</p>
            <p class="gr-share-desc">Comparte y multiplica el impacto.</p>
            <div class="gr-share-btns">
              <a
                href="https://www.facebook.com/sharer/sharer.php?u=https://asistedcosong.vercel.app"
                target="_blank" rel="noopener noreferrer"
                class="gr-share-fb"
              >
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
              <a
                href="https://wa.me/?text=Acabo%20de%20donar%20a%20Fundaci%C3%B3n%20ASISTEDCOS%20para%20reforestar%20El%20Salvador.%20%C3%BAnete%3A%20https://asistedcosong.vercel.app/donar"
                target="_blank" rel="noopener noreferrer"
                class="gr-share-wa"
              >
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="gr-ctas">
          <a href="/" class="gr-btn-primary">Volver al inicio</a>
          <a href="/proyectos" class="gr-btn-outline">Ver proyectos &rarr;</a>
          <a href="/donar" class="gr-btn-ghost">Hacer otra donación</a>
        </div>

        <!-- Firma -->
        <div class="gr-footer">
          <img src="/images/logo.png" alt="ASISTEDCOS" class="gr-logo" />
          <p class="gr-footer-text">Fundación ASISTEDCOS · El Salvador · Desde 1997</p>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  :root {
    --gr-accent: #f59e0b;
    --gr-dark:   #111;
    --gr-forest: #081509;
    --gr-head:   'Poppins', system-ui, sans-serif;
    --gr-shadow: 0 8px 30px rgba(0,0,0,.08);
  }

  .gr-page { background:#f7f7f7; }
  .gr-container { max-width:900px; margin:0 auto; padding:0 1.5rem; }

  .gr-eyebrow {
    font-size:.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.28em; color:rgba(245,158,11,.75); display:block; margin-bottom:.75rem;
  }
  .gr-eyebrow-dark {
    font-size:.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.28em; color:var(--gr-accent); display:block; margin-bottom:.75rem;
  }
  .gr-accent { color:var(--gr-accent); }

  /* ── HERO ── */
  .gr-hero {
    position:relative; min-height:60vh;
    display:flex; align-items:center; justify-content:center;
    padding:8rem 1.5rem 5rem; overflow:hidden; text-align:center;
  }
  .gr-hero-bg {
    position:absolute; inset:0;
    background:
      linear-gradient(to bottom, rgba(8,21,9,.88) 0%, rgba(8,21,9,.70) 100%),
      url('https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?w=1920&q=80') center/cover no-repeat;
  }
  .gr-hero-content { position:relative; z-index:1; max-width:640px; }

  .gr-confirmed-badge {
    width:5rem; height:5rem; margin:0 auto 1.75rem;
    background:rgba(245,158,11,.15);
    border:2px solid rgba(245,158,11,.4);
    display:flex; align-items:center; justify-content:center;
  }
  .gr-confirmed-icon { width:2.25rem; height:2.25rem; stroke:var(--gr-accent); }

  .gr-h1 {
    font-family:var(--gr-head); font-weight:900;
    font-size:clamp(2.4rem,6vw,4rem); line-height:1.1;
    color:#fff; margin-bottom:1rem;
  }
  .gr-hero-sub {
    color:rgba(255,255,255,.65); font-size:1.05rem; line-height:1.75; max-width:480px; margin:0 auto;
  }

  .gr-scroll { position:absolute; bottom:2rem; left:50%; transform:translateX(-50%); }
  .gr-scroll span {
    display:block; width:1px; height:50px;
    background:linear-gradient(to bottom, rgba(245,158,11,.7), transparent);
    animation:gr-scroll-anim 1.8s ease-in-out infinite;
  }
  @keyframes gr-scroll-anim {
    0%   { transform:scaleY(0); transform-origin:top    }
    50%  { transform:scaleY(1); transform-origin:top    }
    51%  { transform:scaleY(1); transform-origin:bottom }
    100% { transform:scaleY(0); transform-origin:bottom }
  }

  /* ── BODY ── */
  .gr-body { padding:4rem 0 5rem; }

  /* Mensaje + impacto */
  .gr-message-row {
    display:grid; grid-template-columns:1fr 1fr;
    gap:1.5px; background:#e0e0e0;
    margin-bottom:1.5px;
  }
  @media(max-width:680px) { .gr-message-row { grid-template-columns:1fr; } }

  .gr-message-text { background:#fff; padding:2.5rem 2rem; }
  .gr-h2 {
    font-family:var(--gr-head); font-weight:800;
    font-size:clamp(1.5rem,3vw,2rem); line-height:1.2;
    color:var(--gr-dark); margin-bottom:1rem;
  }
  .gr-desc { font-size:.9rem; color:#777; line-height:1.8; }

  .gr-impact-list {
    background:var(--gr-forest); padding:2.5rem 2rem;
    display:flex; flex-direction:column; gap:1.5rem;
  }
  .gr-impact-item { display:flex; align-items:center; gap:1rem; }
  .gr-impact-icon {
    width:2.75rem; height:2.75rem; flex-shrink:0;
    border:1.5px solid; display:flex; align-items:center; justify-content:center;
  }
  .gr-impact-icon svg { width:1.35rem; height:1.35rem; }
  .gr-impact-label { font-size:.82rem; color:rgba(255,255,255,.7); line-height:1.5; font-weight:500; }

  /* Recibo + compartir */
  .gr-bottom-row {
    display:grid; grid-template-columns:1fr 1fr;
    gap:1.5px; background:#e0e0e0;
    margin-bottom:2.5rem;
  }
  @media(max-width:680px) { .gr-bottom-row { grid-template-columns:1fr; } }

  .gr-receipt-card {
    background:#fff; padding:2rem;
    display:flex; gap:1.25rem; align-items:flex-start;
    border-left:4px solid var(--gr-accent);
  }
  .gr-receipt-icon {
    width:2.5rem; height:2.5rem; flex-shrink:0;
    color:var(--gr-accent);
  }
  .gr-receipt-icon svg { width:100%; height:100%; }
  .gr-receipt-title {
    font-family:var(--gr-head); font-weight:700;
    font-size:.9rem; color:var(--gr-dark); margin-bottom:.4rem;
  }
  .gr-receipt-desc { font-size:.82rem; color:#777; line-height:1.7; }

  .gr-share-card {
    background:#fff; padding:2rem;
  }
  .gr-share-title {
    font-family:var(--gr-head); font-weight:700;
    font-size:.9rem; color:var(--gr-dark); margin-bottom:.25rem;
    text-transform:uppercase; letter-spacing:.08em;
  }
  .gr-share-desc { font-size:.8rem; color:#aaa; margin-bottom:1.25rem; }
  .gr-share-btns { display:flex; gap:.75rem; flex-wrap:wrap; }

  .gr-share-fb, .gr-share-wa {
    flex:1; display:inline-flex; align-items:center; justify-content:center; gap:.5rem;
    font-weight:700; font-size:.78rem; text-decoration:none;
    text-transform:uppercase; letter-spacing:.06em;
    padding:.75rem 1rem; transition:opacity .2s;
  }
  .gr-share-fb:hover, .gr-share-wa:hover { opacity:.85; }
  .gr-share-fb svg, .gr-share-wa svg { width:1rem; height:1rem; }

  .gr-share-fb { background:#1877f2; color:#fff; }
  .gr-share-wa { background:#25d366; color:#fff; }

  /* CTAs */
  .gr-ctas { display:flex; gap:.75rem; flex-wrap:wrap; margin-bottom:3rem; }

  .gr-btn-primary {
    flex:1; display:inline-flex; align-items:center; justify-content:center;
    background:var(--gr-forest); color:#fff;
    font-family:var(--gr-head); font-weight:700; font-size:.85rem;
    text-transform:uppercase; letter-spacing:.08em;
    padding:1rem 1.5rem; text-decoration:none;
    transition:background .2s;
  }
  .gr-btn-primary:hover { background:#0f2b10; }

  .gr-btn-outline {
    flex:1; display:inline-flex; align-items:center; justify-content:center;
    border:2px solid var(--gr-accent); color:var(--gr-accent);
    font-family:var(--gr-head); font-weight:700; font-size:.85rem;
    text-transform:uppercase; letter-spacing:.08em;
    padding:1rem 1.5rem; text-decoration:none;
    transition:all .2s;
  }
  .gr-btn-outline:hover { background:var(--gr-accent); color:#fff; }

  .gr-btn-ghost {
    flex:1; display:inline-flex; align-items:center; justify-content:center;
    border:2px solid #ddd; color:#888;
    font-family:var(--gr-head); font-weight:700; font-size:.85rem;
    text-transform:uppercase; letter-spacing:.08em;
    padding:1rem 1.5rem; text-decoration:none;
    transition:all .2s;
  }
  .gr-btn-ghost:hover { border-color:#aaa; color:#555; }

  /* Footer */
  .gr-footer {
    display:flex; align-items:center; justify-content:center;
    gap:1rem; padding-top:2rem;
    border-top:1px solid #e5e5e5;
  }
  .gr-logo { height:2rem; width:auto; opacity:.45; }
  .gr-footer-text { font-size:.72rem; color:#bbb; letter-spacing:.06em; }

  @media(max-width:640px) {
    .gr-hero { min-height:auto; padding:6rem 1.5rem 4rem; }
    .gr-ctas { flex-direction:column; }
    .gr-btn-primary, .gr-btn-outline, .gr-btn-ghost { flex:unset; }
  }
</style>

<script>
  if (new URLSearchParams(window.location.search).get('donated') === 'true') {
    document.getElementById('state-contacto')!.classList.add('hidden');
    document.getElementById('state-donacion')!.classList.remove('hidden');
  }
</script>
