---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="¡Gracias!" description="Gracias por apoyar a Fundación ASISTEDCOS.">

  <!-- Estado: contacto (default) -->
  <section id="state-contacto" class="min-h-[70vh] flex items-center justify-center bg-gray-50">
    <div class="text-center max-w-lg mx-auto px-4">
      <div class="w-20 h-20 bg-verde-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="h-10 w-10 text-verde-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="font-heading text-3xl font-bold text-verde-900 mb-3">¡Gracias por escribirnos!</h1>
      <p class="text-gray-500 mb-8">Hemos recibido tu mensaje y te responderemos a la brevedad posible.</p>
      <a href="/" class="inline-flex items-center gap-2 bg-verde-600 hover:bg-verde-700 text-white font-semibold px-8 py-3 rounded-full transition-colors">
        Volver al inicio
      </a>
    </div>
  </section>

  <!-- Estado: donación exitosa -->
  <section id="state-donacion" class="hidden min-h-screen" style="background: linear-gradient(to bottom, #f9fafb 0%, #f0faf1 100%);">

    <!-- Barra superior decorativa -->
    <div class="h-2 bg-gradient-to-r from-amber-400 via-verde-500 to-amber-400"></div>

    <div class="max-w-2xl mx-auto px-4 py-16">

      <!-- Tarjeta principal -->
      <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100">

        <!-- Cabecera de la tarjeta -->
        <div class="relative bg-gradient-to-br from-amber-400 to-amber-500 px-8 py-12 text-center overflow-hidden">
          <!-- Círculos decorativos -->
          <div class="absolute -top-10 -left-10 w-40 h-40 bg-white/10 rounded-full"></div>
          <div class="absolute -bottom-8 -right-8 w-32 h-32 bg-white/10 rounded-full"></div>
          <div class="absolute top-4 right-12 w-6 h-6 bg-white/20 rounded-full"></div>
          <div class="absolute bottom-8 left-16 w-4 h-4 bg-white/20 rounded-full"></div>

          <!-- Icono -->
          <div class="relative inline-flex items-center justify-center w-24 h-24 rounded-full bg-white shadow-lg mb-5">
            <svg class="h-12 w-12 text-amber-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
            </svg>
          </div>

          <div class="relative">
            <p class="text-amber-100 text-xs font-bold uppercase tracking-widest mb-2">Donación confirmada ✓</p>
            <h1 class="font-heading text-3xl md:text-4xl font-extrabold text-white leading-tight">
              ¡Eres parte<br/>del cambio!
            </h1>
          </div>
        </div>

        <!-- Cuerpo de la tarjeta -->
        <div class="px-8 py-8">

          <!-- Mensaje -->
          <p class="text-gray-600 text-center text-base leading-relaxed mb-8">
            Tu donación ya está en camino a las comunidades y ecosistemas de El Salvador.
            Cada árbol que nazca de esto llevará tu huella.
          </p>

          <!-- Lo que lograste -->
          <div class="bg-gray-50 rounded-xl p-5 mb-8">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4 text-center">Lo que lograste hoy</p>
            <div class="grid grid-cols-3 gap-4">
              {[
                {
                  label: 'Plántulas hacia comunidades rurales',
                  svg: `<svg class="h-9 w-9 text-verde-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22V12m0 0C12 7 8 4 4 5c0 4 3 7 8 7zm0 0c0-5 4-8 8-7-1 4-4 7-8 7"/></svg>`
                },
                {
                  label: 'Cuencas monitoreadas protegidas',
                  svg: `<svg class="h-9 w-9 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2C6 8 4 12 4 15a8 8 0 0016 0c0-3-2-7-8-13z"/></svg>`
                },
                {
                  label: 'CO₂ siendo capturado por la naturaleza',
                  svg: `<svg class="h-9 w-9 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3a6 6 0 00-6 6c0 3 1.5 4.5 3 6h6c1.5-1.5 3-3 3-6a6 6 0 00-6-6z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 21h6M12 18v3"/></svg>`
                },
              ].map(item => (
                <div class="text-center">
                  <div class="flex justify-center mb-2" set:html={item.svg} />
                  <p class="text-gray-500 text-xs leading-tight">{item.label}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Aviso recibo -->
          <div class="flex items-start gap-3 bg-verde-50 border border-verde-100 rounded-lg px-4 py-3 mb-8">
            <svg class="h-5 w-5 text-verde-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <p class="text-verde-800 text-sm">
              <strong>Revisa tu correo</strong> — recibirás el comprobante de tu donación válido para deducción fiscal (Art. 32, Ley de Renta de El Salvador).
            </p>
          </div>

          <!-- Compartir -->
          <div class="mb-8">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider text-center mb-3">Comparte e inspira a otros</p>
            <div class="flex gap-3 justify-center">
              <a
                href="https://www.facebook.com/sharer/sharer.php?u=https://asistedcosong.vercel.app"
                target="_blank" rel="noopener noreferrer"
                class="flex-1 flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg text-sm transition-colors"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
              <a
                href="https://wa.me/?text=Acabo%20de%20donar%20a%20Fundaci%C3%B3n%20ASISTEDCOS%20para%20reforestar%20El%20Salvador.%20%C3%BAnete%3A%20https://asistedcosong.vercel.app/donar"
                target="_blank" rel="noopener noreferrer"
                class="flex-1 flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white font-semibold py-2.5 rounded-lg text-sm transition-colors"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/" class="flex-1 flex items-center justify-center gap-2 bg-verde-700 hover:bg-verde-800 text-white font-bold py-3.5 rounded-lg transition-colors">
              Volver al inicio
            </a>
            <a href="/proyectos" class="flex-1 flex items-center justify-center gap-2 border-2 border-gray-200 hover:border-verde-400 text-gray-700 hover:text-verde-700 font-bold py-3.5 rounded-lg transition-colors">
              Ver proyectos
            </a>
          </div>
        </div>

        <!-- Pie de tarjeta -->
        <div class="px-8 py-4 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
          <img src="/images/logo.png" alt="ASISTEDCOS" class="h-8 w-auto opacity-60" />
          <p class="text-gray-400 text-xs">Fundación ASISTEDCOS · El Salvador</p>
        </div>
      </div>

      <!-- Dona de nuevo -->
      <p class="text-center mt-6 text-gray-400 text-sm">
        ¿Quieres donar de nuevo?
        <a href="/donar" class="text-amber-500 hover:text-amber-600 font-semibold ml-1">Haz otra donación →</a>
      </p>

    </div>
  </section>

</Layout>

<script>
  if (new URLSearchParams(window.location.search).get('donated') === 'true') {
    document.getElementById('state-contacto')!.classList.add('hidden');
    document.getElementById('state-donacion')!.classList.remove('hidden');
  }
</script>
