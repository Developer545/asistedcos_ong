---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

const testimonios = [
  {
    nombre: 'María Elena Ramos',
    rol: 'Voluntaria — Jornada de reforestación',
    img: '/images/voluntaria-plantando.jpg',
    initials: 'MR',
    texto:
      'Participar en la jornada de reforestación con ASISTEDCOS fue una experiencia que cambió mi perspectiva. Ver a toda la comunidad unida plantando árboles nativos me llenó de esperanza. Ahora vuelvo cada año y traigo a mis hijos para que aprendan a cuidar la naturaleza.',
    año: '2024',
    categoria: 'Voluntariado',
  },
  {
    nombre: 'Carlos Mejía',
    rol: 'Agricultor — Comunidad de Sonsonate',
    img: '/images/distribucion-plantas.jpg',
    initials: 'CM',
    texto:
      'Gracias a las plántulas que nos distribuyeron mis parcelas ahora tienen más sombra y el suelo retiene mejor el agua. Mis cultivos mejoraron notablemente y pude generar ingresos adicionales vendiendo las plantas que sobraron. ASISTEDCOS no solo planta árboles, transforma vidas.',
    año: '2023',
    categoria: 'Comunidad',
  },
  {
    nombre: 'Ana Sofía Villanueva',
    rol: 'Estudiante universitaria — Biología',
    img: '/images/monitoreo-rio.jpg',
    initials: 'AV',
    texto:
      'Realicé mis horas sociales monitoreando cuencas hidrográficas con el equipo técnico. La metodología que aplican es rigurosa y el impacto real. Me enseñaron a identificar especies indicadoras de calidad del agua. Fue la mejor experiencia de mi carrera universitaria.',
    año: '2024',
    categoria: 'Academia',
  },
  {
    nombre: 'Roberto Castillo',
    rol: 'Empresario — Sector privado',
    img: '/images/evento-playa.jpg',
    initials: 'RC',
    texto:
      'Nuestra empresa apoya a ASISTEDCOS desde 2021 y el retorno en imagen y propósito es invaluable. Pero más allá del negocio, ver a nuestros empleados involucrados en las jornadas de limpieza de playa y sintiéndose parte del cambio es lo que más nos enorgullece.',
    año: '2023',
    categoria: 'Empresa',
  },
  {
    nombre: 'Dra. Lucía Hernández',
    rol: 'Investigadora ambiental',
    img: '/images/area-conservacion.jpg',
    initials: 'LH',
    texto:
      'He colaborado con muchas ONGs ambientales en Centroamérica, y ASISTEDCOS destaca por su seriedad técnica y su profundo arraigo comunitario. Sus datos de monitoreo son confiables y han servido de referencia para tesis doctorales y reportes gubernamentales.',
    año: '2022',
    categoria: 'Investigación',
  },
  {
    nombre: 'Familia López-Guardado',
    rol: 'Beneficiarios — Programa plántulas',
    img: '/images/vivero-comunidad.jpg',
    initials: 'FL',
    texto:
      'Recibimos 50 plántulas de árboles frutales y maderables. Nos enseñaron cómo cuidarlas y ahora tenemos un pequeño vivero en casa. Nuestros hijos aprendieron el valor de la naturaleza y nosotros tenemos frutas frescas cada temporada. Estamos muy agradecidos.',
    año: '2024',
    categoria: 'Comunidad',
  },
];

const alianzas = [
  { nombre: 'Concentrix', tipo: 'Empresa aliada', testimonio: 'Un socio comprometido con el medio ambiente y las comunidades de El Salvador.', initials: 'CO' },
  { nombre: 'Ministerio de Medio Ambiente', tipo: 'Entidad gubernamental', testimonio: 'ASISTEDCOS aporta datos técnicos clave para las políticas ambientales nacionales.', initials: 'MM' },
  { nombre: 'Universidades locales', tipo: 'Academia', testimonio: 'Espacio invaluable para la formación práctica de nuevas generaciones de ambientalistas.', initials: 'UL' },
];

const videos = [
  {
    youtubeId: 'X_y7B2hi6i4',
    titulo: 'Nuestro trabajo en el territorio',
    descripcion: 'Un vistazo al impacto real de Fundación ASISTEDCOS en las comunidades de El Salvador.',
  },
  {
    youtubeId: 'TQhCGhQF5H0',
    titulo: 'Jornada de reforestación comunitaria',
    descripcion: 'Voluntarios y comunidades unidas plantando árboles nativos para restaurar ecosistemas.',
  },
  {
    youtubeId: 'YmH2SopQWVo',
    titulo: 'Conservación y medio ambiente',
    descripcion: 'Conoce nuestras iniciativas de conservación de manglares y cuencas hidrográficas.',
  },
  {
    youtubeId: '7O5_4ns1ot8',
    titulo: 'Impacto en las comunidades',
    descripcion: 'Familias y comunidades transformadas gracias a los programas de Fundación ASISTEDCOS.',
  },
];
---

<Layout
  title="Testimonios"
  description="Conoce las historias de voluntarios, comunidades y aliados que han sido transformados por el trabajo de Fundación ASISTEDCOS en El Salvador."
  image="/images/voluntaria-plantando.jpg"
>

<!-- ══════════════════════════════════════════════
     HERO
══════════════════════════════════════════════════ -->
<section class="t-hero">
  <div class="t-hero-bg"></div>
  <div class="t-container t-hero-inner">
    <nav class="t-breadcrumb">
      <a href="/">Inicio</a>
      <span>›</span>
      <span>Testimonios</span>
    </nav>
    <p class="t-eyebrow">Voces reales</p>
    <h1 class="t-h1">Lo que dice nuestra <span class="t-accent">comunidad</span></h1>
    <p class="t-hero-sub">
      Voluntarios, familias, investigadores y aliados comparten cómo el trabajo de ASISTEDCOS ha transformado su relación con el medio ambiente.
    </p>
  </div>
  <div class="t-hero-scroll" aria-hidden="true">
    <span></span>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     STATS BAR
══════════════════════════════════════════════════ -->
<section class="t-stats-bar">
  {[
    { value: '+500', label: 'Voluntarios formados' },
    { value: '+50',  label: 'Comunidades beneficiadas' },
    { value: '27+',  label: 'Años de confianza' },
  ].map(stat => (
    <div class="t-stat-item">
      <p class="t-stat-value">{stat.value}</p>
      <p class="t-stat-label">{stat.label}</p>
    </div>
  ))}
</section>

<!-- ══════════════════════════════════════════════
     TESTIMONIALS GRID
══════════════════════════════════════════════════ -->
<section class="t-section" style="background:#f7f7f7; position:relative;">
  <div class="t-deco-num" aria-hidden="true">.01</div>
  <div class="t-container">
    <div class="t-section-head t-center">
      <p class="t-eyebrow">Historias de impacto</p>
      <h2 class="t-h2">Ellos lo <span class="t-accent">vivieron</span></h2>
      <p class="t-section-sub">Cada testimonio es una muestra del impacto que generamos juntos en El Salvador.</p>
    </div>

    <div class="t-cards-grid">
      {testimonios.map((t, i) => (
        <article class="t-card">
          <div class="t-card-img">
            <img src={t.img} alt={`Actividad — ${t.nombre}`} loading="lazy" />
            <span class="t-card-tag">{t.categoria}</span>
            <span class="t-card-year">{t.año}</span>
          </div>
          <div class="t-card-body">
            <svg class="t-quote-icon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <p class="t-card-text">"{t.texto}"</p>
            <div class="t-card-author">
              <div class="t-avatar">{t.initials}</div>
              <div>
                <p class="t-author-name">{t.nombre}</p>
                <p class="t-author-role">{t.rol}</p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     FEATURED QUOTE
══════════════════════════════════════════════════ -->
<section class="t-featured-quote">
  <div class="t-container t-center">
    <svg class="t-big-quote" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
    </svg>
    <blockquote class="t-blockquote">
      "Cuando una comunidad cuida su entorno, el entorno cuida a la comunidad. ASISTEDCOS nos enseñó que la conservación empieza por las personas."
    </blockquote>
    <div class="t-quote-divider"></div>
    <p class="t-quote-author">Ing. Jorge Flores</p>
    <p class="t-quote-role">Coordinador municipal de medio ambiente — La Libertad</p>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     VIDEOS
══════════════════════════════════════════════════ -->
<section class="t-section" style="background:#fff; position:relative;">
  <div class="t-deco-num t-deco-right" aria-hidden="true">.02</div>
  <div class="t-container">
    <div class="t-section-head t-center">
      <p class="t-eyebrow">Nuestro trabajo en video</p>
      <h2 class="t-h2">Míralo con tus <span class="t-accent">propios ojos</span></h2>
      <p class="t-section-sub">Documentamos cada jornada para que el impacto sea visible para toda la comunidad.</p>
    </div>

    <div class="t-videos-grid">
      {videos.map(v => (
        <div class="t-video-card">
          <div class="t-video-frame">
            <iframe
              src={`https://www.youtube.com/embed/${v.youtubeId}`}
              title={v.titulo}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            />
          </div>
          <div class="t-video-info">
            <div class="t-video-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </div>
            <div>
              <h3 class="t-video-title">{v.titulo}</h3>
              <p class="t-video-desc">{v.descripcion}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     ALIANZAS
══════════════════════════════════════════════════ -->
<section class="t-section" style="background:#f7f7f7; position:relative;">
  <div class="t-container">
    <div class="t-section-head t-center">
      <p class="t-eyebrow">Aliados que nos respaldan</p>
      <h2 class="t-h2">Lo que dicen nuestros <span class="t-accent">socios</span></h2>
    </div>
    <div class="t-alianzas-grid">
      {alianzas.map(a => (
        <div class="t-alianza-card">
          <div class="t-alianza-avatar">{a.initials}</div>
          <svg class="t-quote-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="t-alianza-text">"{a.testimonio}"</p>
          <div class="t-alianza-footer">
            <p class="t-alianza-name">{a.nombre}</p>
            <p class="t-alianza-tipo">{a.tipo}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════
     CTA FINAL
══════════════════════════════════════════════════ -->
<section class="t-cta">
  <div class="t-container t-center">
    <p class="t-eyebrow" style="color:rgba(245,158,11,0.8);">Tu voz importa</p>
    <h2 class="t-h2" style="color:#fff;">¿Tienes una historia que <span class="t-accent">compartir</span>?</h2>
    <p class="t-cta-sub">
      Si has participado en nuestros proyectos o tu comunidad ha sido beneficiada, nos encantaría escucharte.
    </p>
    <div class="t-cta-actions">
      <a href="/contacto" class="t-btn">Escríbenos</a>
      <a href="/donar" class="t-btn-ghost">♥ Donar ahora</a>
    </div>
  </div>
</section>

</Layout>

<style>
  /* ══════════════════════════════════════
     DESIGN TOKENS
  ══════════════════════════════════════ */
  :root {
    --t-accent:  #f59e0b;
    --t-dark:    #111111;
    --t-forest:  #081509;
    --t-heading: 'Poppins', system-ui, sans-serif;
    --t-body:    'Inter', system-ui, sans-serif;
    --t-shadow:  -6px -6px 20px rgba(0,0,0,0.07), 6px 6px 20px rgba(0,0,0,0.07);
  }

  /* ══════════════════════════════════════
     LAYOUT HELPERS
  ══════════════════════════════════════ */
  .t-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .t-section {
    padding: 6rem 0;
    overflow: hidden;
  }
  .t-center { text-align: center; }
  .t-section-head { margin-bottom: 3.5rem; }

  /* ══════════════════════════════════════
     TYPOGRAPHY
  ══════════════════════════════════════ */
  .t-eyebrow {
    font-family: var(--t-body);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--t-accent);
    display: block;
    margin-bottom: 0.75rem;
  }
  .t-h1 {
    font-family: var(--t-heading);
    font-weight: 800;
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    line-height: 1.07;
    color: #fff;
    margin-bottom: 1.25rem;
  }
  .t-h2 {
    font-family: var(--t-heading);
    font-weight: 800;
    font-size: clamp(1.9rem, 3.5vw, 2.6rem);
    line-height: 1.15;
    color: var(--t-dark);
    margin-bottom: 0.75rem;
  }
  .t-accent { color: var(--t-accent); }
  .t-section-sub {
    color: #666;
    font-size: 1rem;
    max-width: 500px;
    margin: 0.5rem auto 0;
    line-height: 1.7;
  }

  /* Decorative numbers */
  .t-deco-num {
    position: absolute;
    top: 3rem; left: -1rem;
    font-family: var(--t-heading);
    font-size: clamp(7rem, 15vw, 14rem);
    font-weight: 900;
    color: rgba(0,0,0,0.04);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }
  .t-deco-right { left: auto; right: -1rem; }

  /* ══════════════════════════════════════
     HERO
  ══════════════════════════════════════ */
  .t-hero {
    position: relative;
    min-height: 72vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 8rem 0 5rem;
  }
  .t-hero-bg {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right, rgba(8,21,9,0.88) 0%, rgba(8,21,9,0.70) 60%, rgba(8,21,9,0.55) 100%),
      url('https://images.unsplash.com/photo-1448375240586-882707db888b?w=1920&q=80') center center / cover no-repeat;
  }
  .t-hero-inner { position: relative; z-index: 1; }
  .t-breadcrumb {
    display: flex; gap: 0.5rem; align-items: center;
    font-size: 0.8rem; color: rgba(255,255,255,0.45);
    margin-bottom: 1.5rem;
  }
  .t-breadcrumb a { color: rgba(255,255,255,0.45); text-decoration: none; }
  .t-breadcrumb a:hover { color: var(--t-accent); }
  .t-hero-sub {
    color: rgba(255,255,255,0.75);
    font-size: 1.1rem;
    max-width: 560px;
    line-height: 1.75;
    margin-top: 1rem;
  }
  /* Animated scroll indicator */
  .t-hero-scroll {
    position: absolute; bottom: 2rem; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center;
  }
  .t-hero-scroll span {
    display: block; width: 1px; height: 60px;
    background: linear-gradient(to bottom, rgba(245,158,11,0.8), transparent);
    animation: scroll-line 1.8s ease-in-out infinite;
  }
  @keyframes scroll-line {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  /* ══════════════════════════════════════
     STATS BAR
  ══════════════════════════════════════ */
  .t-stats-bar {
    background: var(--t-forest);
    display: flex;
    justify-content: center;
    gap: 0;
  }
  .t-stat-item {
    flex: 1;
    max-width: 240px;
    text-align: center;
    padding: 2.5rem 1rem;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .t-stat-item:last-child { border-right: none; }
  .t-stat-value {
    font-family: var(--t-heading);
    font-size: 2.6rem;
    font-weight: 800;
    color: var(--t-accent);
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .t-stat-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* ══════════════════════════════════════
     TESTIMONIAL CARDS
  ══════════════════════════════════════ */
  .t-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: #e5e5e5;
  }
  @media(max-width:900px){ .t-cards-grid { grid-template-columns: repeat(2,1fr); } }
  @media(max-width:560px){ .t-cards-grid { grid-template-columns: 1fr; } }

  .t-card {
    background: #fff;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .t-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--t-shadow);
    position: relative; z-index: 1;
  }

  .t-card-img {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  .t-card-img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.6s ease;
  }
  .t-card:hover .t-card-img img { transform: scale(1.07); }

  .t-card-tag {
    position: absolute; top: 1rem; left: 1rem;
    background: var(--t-accent);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.6rem;
  }
  .t-card-year {
    position: absolute; bottom: 1rem; right: 1rem;
    background: rgba(8,21,9,0.75);
    color: rgba(255,255,255,0.85);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
  }

  .t-card-body {
    padding: 1.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .t-quote-icon {
    width: 1.5rem; height: 1.5rem;
    color: var(--t-accent);
    margin-bottom: 0.75rem;
    flex-shrink: 0;
  }
  .t-card-text {
    color: #555;
    font-size: 0.875rem;
    line-height: 1.75;
    flex: 1;
  }
  .t-card-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid #f0f0f0;
  }
  .t-avatar {
    width: 2.25rem; height: 2.25rem;
    background: var(--t-forest);
    color: var(--t-accent);
    font-size: 0.7rem;
    font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0.05em;
  }
  .t-author-name {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--t-dark);
  }
  .t-author-role {
    font-size: 0.72rem;
    color: #999;
    margin-top: 0.1rem;
  }

  /* ══════════════════════════════════════
     FEATURED QUOTE
  ══════════════════════════════════════ */
  .t-featured-quote {
    background:
      linear-gradient(rgba(8,21,9,0.82), rgba(8,21,9,0.82)),
      url('https://images.unsplash.com/photo-1516026672322-bc52d61a55d5?w=1920&q=80') center / cover no-repeat fixed;
    padding: 7rem 0;
    text-align: center;
  }
  .t-big-quote {
    width: 3rem; height: 3rem;
    color: var(--t-accent);
    opacity: 0.7;
    margin: 0 auto 2rem;
  }
  .t-blockquote {
    font-family: var(--t-heading);
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.45;
    max-width: 780px;
    margin: 0 auto 2rem;
  }
  .t-quote-divider {
    width: 3rem; height: 3px;
    background: var(--t-accent);
    margin: 0 auto 1.5rem;
  }
  .t-quote-author {
    font-weight: 700;
    color: var(--t-accent);
    font-size: 0.95rem;
    letter-spacing: 0.05em;
  }
  .t-quote-role {
    color: rgba(255,255,255,0.45);
    font-size: 0.8rem;
    margin-top: 0.25rem;
  }

  /* ══════════════════════════════════════
     VIDEOS
  ══════════════════════════════════════ */
  .t-videos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  @media(max-width:700px){ .t-videos-grid { grid-template-columns: 1fr; } }

  .t-video-card {
    background: #fff;
