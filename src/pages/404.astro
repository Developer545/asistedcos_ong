---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada" description="La página que buscas no existe.">
  <section class="min-h-[70vh] flex items-center justify-center bg-gray-50">
    <div class="text-center max-w-lg mx-auto px-4">
      <p class="font-heading text-8xl font-extrabold text-verde-200 mb-4">404</p>
      <h1 class="font-heading text-2xl font-bold text-verde-900 mb-3">Página no encontrada</h1>
      <p class="text-gray-400 mb-8">El árbol que buscas no está en este bosque.</p>
      <a href="/" class="inline-flex items-center gap-2 bg-verde-600 hover:bg-verde-700 text-white font-semibold px-8 py-3 rounded-full transition-colors">
        Volver al inicio
      </a>
    </div>
  </section>
</Layout>
