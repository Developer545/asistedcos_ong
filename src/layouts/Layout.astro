---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title,
  description = 'Fundación ASISTEDCOS — Recuperando Ecosistemas para la Biodiversidad y la Humanidad en El Salvador desde 1997.',
  image = '/images/reforestacion-aerea.jpg',
  canonical = Astro.url.href,
} = Astro.props;

const siteName = 'Fundación ASISTEDCOS';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO primario -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_SV" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/logo.png" />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Montserrat:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org para ONGs -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "NGO",
        "name": "Fundación ASISTEDCOS",
        "alternateName": "ASISTEDCOS",
        "url": "https://asistedcos.org",
        "logo": "https://asistedcos.org/images/logo.png",
        "foundingDate": "1997",
        "description": "Organización sin fines de lucro que provee asistencia técnica en gestión socioambiental a comunidades rurales, semi-rurales y urbanas de El Salvador.",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "SV"
        },
        "areaServed": "El Salvador",
        "knowsAbout": ["Restauración de ecosistemas", "Reforestación", "Manglares", "Biodiversidad", "Desarrollo comunitario"]
      }
    </script>
  </head>
  <body class="font-sans text-gray-800 bg-white">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
